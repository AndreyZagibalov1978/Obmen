&НаСервереБезКонтекста
Функция АвторизацияПоОС(Знач Пользователь, Знач Пароль)
	
	ПараметрыВхода = Новый Структура;
	ПараметрыВхода.Вставить("ПользовательОС", Пользователь.ПользовательОС); 
	ПараметрыВхода.Вставить("Пароль", Пароль); 
		
	Возврат ОбменСервер.Идентификация(ПараметрыВхода);
	
КонецФункции

&НаКлиенте
Функция РеквизитыФормыЗаполненыКорректно()
	
	Если ЭтотОбъект.Логин = ЭтотОбъект.СлужебныйПользователь Тогда
		Возврат Истина;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Логин)  Тогда
		ТекстПредупреждения = НСтр("ru = 'Форма заполнена некорректно. Заполните поле ""Логин""';");
		ПоказатьПредупреждение( , ТекстПредупреждения, 4);
		Возврат Ложь;
	Иначе
		Если ЗначениеЗаполнено(ЭтотОбъект.Логин) Тогда
			УстановитьТекущегоПользователя(ЭтотОбъект.Логин);
		Иначе
			ТекстПредупреждения 
				= СтрШаблон(НСтр("ru = 'Пользователь с логином %1 не найден в базе.';"), ЭтотОбъект.Логин);
			ПоказатьПредупреждение( , ТекстПредупреждения, 4);
			Возврат Ложь;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект.ГруппаСкладовОбменаДанными) Тогда
			ТекстПредупреждения = НСтр("ru = 'Форма заполнена некорректно. Заполните поле ""Склад""';");
			ПоказатьПредупреждение( , ТекстПредупреждения, 4);
			Возврат Ложь;
		Иначе
			УстановитьСклад(ЭтотОбъект.ГруппаСкладовОбменаДанными);
		КонецЕсли;
		
		Возврат Истина;

	КонецЕсли;

КонецФункции

&НаСервереБезКонтекста
Функция ЕстьПользователиВБазе()
	
	Возврат Справочники.Пользователи.ЕстьПользователиВБазе();
	
КонецФункции

&НаСервереБезКонтекста
Процедура УстановитьТекущегоПользователя(Пользователь)
	
	УстановитьПривилегированныйРежим(Истина);
	Константы.ТекущийПользователь.Установить(Пользователь);
	
	РеквизитыПользователя = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Пользователь, "Организация,Подразделение");
	Константы.ОрганизацияПользователя.Установить(РеквизитыПользователя.Организация);
	Константы.ПодразделениеПользователя.Установить(РеквизитыПользователя.Подразделение);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьСклад(Склад)
	
	Константы.ГруппаСкладовОбменаДанными.Установить(Склад);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РолиПользователяИзСправочника(Знач Логин)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПользователиРоли.Роль КАК Роль
	|ИЗ
	|	Справочник.Пользователи.Роли КАК ПользователиРоли
	|ГДЕ
	|	ПользователиРоли.Ссылка = &Логин
	|	И НЕ ПользователиРоли.Роль = """"";
	
	Запрос.УстановитьПараметр("Логин", Логин);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Роль");

КонецФункции
	
&НаСервереБезКонтекста
Функция ИмяПользователяОС(Знач Логин)

	ТекПользователь = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
	ЛогинОС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Логин, "ПользовательОС");
	Если ПустаяСтрока(ЛогинОС) Тогда
		Возврат Неопределено;
	Иначе
		ЛогинОС = СтрЗаменить(ЛогинОС, "\\mechel\", "");
		ЛогинОС = СтрЗаменить(ЛогинОС, "\\MECHEL\", "");
	КонецЕсли;
	
	ПользовательМП = ПользователиИнформационнойБазы.НайтиПоИмени(ЛогинОС);

	Если ТекПользователь <> ЛогинОС Тогда
		ОбщегоНазначенияВызовСервера.ОчиститьПользователейИнфБазы(Истина);
	КонецЕсли;
	Если ПользовательМП = Неопределено Тогда
		НовыйПользователь = ПользователиИнформационнойБазы.СоздатьПользователя();
		НовыйПользователь.Имя = ЛогинОС;
		НовыйПользователь.Роли.Добавить(Метаданные.Роли.мп_ОбщиеПрава);
		НовыйПользователь.Записать();
		ПользовательМП = ПользователиИнформационнойБазы.НайтиПоИмени(ЛогинОС);
	КонецЕсли;
	Если ТекПользователь <> ЛогинОС Тогда
		ПользовательМП.Роли.Очистить();
	КонецЕсли;

	Если Не ПользовательМП.Роли.Содержит(Метаданные.Роли.мп_ОбщиеПрава) Тогда
		ПользовательМП.Роли.Добавить(Метаданные.Роли.мп_ОбщиеПрава);
	КонецЕсли;

	РолиИзСправочника = РолиПользователяИзСправочника(Логин);

	РолиКонфигуратора = Новый Массив;
	Для Каждого ТекРоль Из ПользовательМП.Роли Цикл
		Если ТекРоль.Имя = "мп_ОбщиеПрава" Тогда
			Продолжить;
		КонецЕсли;

		РолиКонфигуратора.Добавить(ТекРоль.Имя);
	КонецЦикла;

	ЛогинСтруктура = Новый Структура;
	ЛогинСтруктура.Вставить("ЛогинОС", ЛогинОС);
	ЛогинСтруктура.Вставить("ДанныеСовпадают", Ложь);
	Если Логин.ПометкаУдаления Или Логин.Недействителен Тогда
		НетПравИспользования = Истина;
	Иначе
		НетПравИспользования = Ложь;
	КонецЕсли;
	ЛогинСтруктура.Вставить("НетПравИспользования", НетПравИспользования);
	Если ОбщегоНазначения.ДанныеСовпадают(РолиИзСправочника, РолиКонфигуратора) Тогда
		ЛогинСтруктура.ДанныеСовпадают = Истина;
	Иначе 
		ЛогинСтруктура.ДанныеСовпадают = Ложь;
		// добавить роли
		Для Каждого ТекРоль Из РолиИзСправочника Цикл
			Если ТекРоль = "ОбъектXDTO" Тогда
				Продолжить;
			КонецЕсли;
			Если РолиКонфигуратора.Найти(ТекРоль) = Неопределено Тогда
				ПользовательМП.Роли.Добавить(Метаданные.Роли[ТекРоль]);
			КонецЕсли;
		КонецЦикла;

		// удалить лишние роли из конфигуратора
		УдаляемыеРоли = Новый Массив;
		Для Каждого ТекРоль Из РолиКонфигуратора Цикл
			Если РолиИзСправочника.Найти(ТекРоль) = Неопределено Тогда
				УдаляемыеРоли.Добавить(Метаданные.Роли[ТекРоль]);
			КонецЕсли;
		КонецЦикла;

		Для Каждого ТекРоль Из УдаляемыеРоли Цикл
			ПользовательМП.Роли.Удалить(ТекРоль);
		КонецЦикла;

		Если Логин.Служебный Тогда
			Если Не ПользовательМП.Роли.Содержит(Метаданные.Роли.ПолныеПрава) Тогда
				ПользовательМП.Роли.Добавить(Метаданные.Роли.ПолныеПрава);
			КонецЕсли;
		КонецЕсли;

		ПользовательМП.Записать();
	КонецЕсли;

	Возврат ЛогинСтруктура;

КонецФункции

#КонецОбласти