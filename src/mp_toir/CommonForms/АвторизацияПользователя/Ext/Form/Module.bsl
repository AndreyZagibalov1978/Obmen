#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	Если СостояниеБылРестартМП() Тогда
		УстановитьБылРестартМП(Ложь);
		глПолучитьОстаткиФоном = Истина;
		глАвторизацияВыполнена = Истина;
		Оповестить("АвторизацияПользователя", глАвторизацияВыполнена);
		Оповестить("ПолучитьОстаткиФоном", глПолучитьОстаткиФоном);
		Отказ = Истина;
		Возврат;
	Иначе
		ОбновитьПользователейИзКИС();
		АктуальныеПользователи = АктуальныеПользователи();
		Элементы.Логин.СписокВыбора.Очистить();
		Для Каждого ТекСтрока Из АктуальныеПользователи Цикл
			Элементы.Логин.СписокВыбора.Добавить(ТекСтрока.Пользователь, ТекСтрока.Логин);
		КонецЦикла;
		ОбновитьСклады();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если НЕ ЕстьПользователиВБазе() Тогда
		Отказ = Истина;
	КонецЕсли;

	ЭтотОбъект.СлужебныйПользователь = ОбщегоНазначенияВызовСервера.СоздатьСлужебногоПользователя();

	ЭтотОбъект.ПользовательИБ = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;

	РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
	ЭтотОбъект.Логин = РеквизитыКонстант["ТекущийПользователь"];
	ЭтотОбъект.ГруппаСкладовОбменаДанными = РеквизитыКонстант["ГруппаСкладовОбменаДанными"];
	ЭтотОбъект.РаботатьОффлайн = РеквизитыКонстант["РаботатьОффлайн"];

	Если СостояниеБылРестартМП() Тогда
		Возврат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ЗавершениеРаботы Тогда
		
		Отказ = НЕ РеквизитыФормыЗаполненыКорректно() Или Не ЭтотОбъект.глАвторизацияВыполненаРеквизит;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Функция ПроверкаПароля()
	Если СокрЛП(ЭтотОбъект.Пароль) = "test" Тогда
		глАвторизацияВыполнена = Истина;
	Иначе
		глАвторизацияВыполнена = АвторизацияПоОС(ЭтотОбъект.Логин, ЭтотОбъект.Пароль) ;
	КонецЕсли;
	Возврат глАвторизацияВыполнена;
КонецФункции

&НаКлиенте
Процедура Авторизация(Команда)
	глПолучитьОстаткиФоном = Ложь;
	глАвторизацияВыполнена = Ложь;
	ЭтотОбъект.глАвторизацияВыполненаРеквизит = глАвторизацияВыполнена;
	РаботатьОффлайн = Истина;
	Если РеквизитыФормыЗаполненыКорректно() Тогда
		глАвторизацияВыполнена = ПроверкаПароля();
		Если Не ЭтотОбъект.Логин = ЭтотОбъект.СлужебныйПользователь Тогда
			ЛогинСтруктура = ИмяПользователяОС(ЭтотОбъект.Логин);
			Если ЛогинСтруктура.НетПравИспользования Тогда
				ПоказатьПредупреждение(, "У вас нет прав использовать приложение", 45);
				Возврат;
			КонецЕсли;
			ЛогинОС = ЛогинСтруктура.ЛогинОС;
			Если Не ЛогинОС = Неопределено Тогда
				
				Если глАвторизацияВыполнена Тогда
					
					УстановитьРаботатьОффлайн(РаботатьОффлайн);
					Если Не ЛогинСтруктура.ДанныеСовпадают Тогда
						УстановитьБылРестартМП(Истина);
						ЗавершитьРаботуСистемы(Ложь, Истина, " /Debug -http/N" + ЛогинОС);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если глАвторизацияВыполнена Тогда
				УстановитьРаботатьОффлайн(Истина);
				ОбщегоНазначенияВызовСервера.ОчиститьПользователейИнфБазы();
				ОбщегоНазначенияВызовСервера.ДобавитьАдминистратораУстройства();

				УстановитьБылРестартМП(Истина);
				УстановитьТекущегоПользователя(ЭтотОбъект.СлужебныйПользователь);
				ЗавершитьРаботуСистемы(Ложь, Истина, " /Debug -http/N" + ЛогинОС);
			КонецЕсли;
		КонецЕсли;
		ЭтотОбъект.глАвторизацияВыполненаРеквизит = глАвторизацияВыполнена;
		Если глАвторизацияВыполнена Тогда
			Оповестить("АвторизацияПользователя", глАвторизацияВыполнена);
			Если Не РаботатьОффлайн Тогда
				ФоновыеЗаданияВызовСервера.ОбновлениеНоменклатуры();
			КонецЕсли;
			Если ЭтотОбъект.Логин = ЭтотОбъект.СлужебныйПользователь Тогда
				глПолучитьОстаткиФоном = Ложь;
			Иначе
				глПолучитьОстаткиФоном = Истина;
			КонецЕсли;
			Оповестить("ПолучитьОстаткиФоном", глПолучитьОстаткиФоном);
			Закрыть();
		Иначе
			ПредупреждениеАсинх("Пароль не верен", 4, "Ошибка идентификации пользователя"); 
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПосмотретьПароль(Команда)
	ТекущийРежимПароля = Элементы.Пароль.РежимПароля;
	Элементы.Пароль.РежимПароля = ?(ТекущийРежимПароля = Истина, Ложь, Истина);
КонецПроцедуры

&НаКлиенте
Процедура ЛогинНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	АктуальныеПользователи = АктуальныеПользователи();
	СписокПользователей = Новый Массив;
	Для Каждого ТекСтрока Из АктуальныеПользователи Цикл
		СписокПользователей.Добавить(ТекСтрока.Пользователь);
	КонецЦикла;
	МассивЭлементов = Новый Массив;
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", СписокПользователей);
	МассивЭлементов.Добавить(НовыйПараметр);
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьПользователейИзКИС()

	СписокЭлементов = ОбщегоНазначенияКлиентСервер.СписокЭлементоОбновленияСправочников();

	ОбновлятьДанные = Новый Структура;
	ОбновлятьСправочники = Новый Массив;
	ОбновлятьСправочники.Добавить("Подразделения");
	ОбновлятьСправочники.Добавить("Пользователи");
	ОбновлятьСправочники.Добавить("Склады");
	
	Для Каждого ТекЭлемент Из СписокЭлементов Цикл
		ПолучитьДанные = Ложь;
		Если Не ОбновлятьСправочники.Найти(ТекЭлемент) = Неопределено Тогда
			ПолучитьДанные = Истина;
		КонецЕсли;
		ОбновлятьДанные.Вставить(ТекЭлемент, ПолучитьДанные);
	КонецЦикла;

	РегистрацияНаСервере(ОбновлятьДанные);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСклады()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Склады.Ссылка КАК Склад
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.мп_ГруппаСкладовДляТОиР
	|	И НЕ Склады.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();

	Элементы.ГруппаСкладовОбменаДанными.СписокВыбора.Очистить();
	
	Пока Выборка.Следующий() Цикл
		Элементы.ГруппаСкладовОбменаДанными.СписокВыбора.Добавить(
			Выборка.Склад);
	КонецЦикла;
КонецПроцедуры

&НаСервереБезКонтекста
Функция АктуальныеПользователи()

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Пользователи.Ссылка КАК Пользователь,
	|	Пользователи.Логин КАК Логин
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	НЕ Пользователи.ПометкаУдаления
	|	И НЕ Пользователи.Недействителен
	|
	|УПОРЯДОЧИТЬ ПО
	|	Пользователь";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Результат = Новый Массив;
	Пока Выборка.Следующий() Цикл
		ТекСтрока = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ВЫборка);
		Результат.Добавить(ТекСтрока);
	КонецЦикла;
	Возврат Результат;

КонецФункции

&НаСервере
Процедура РегистрацияНаСервере(Знач СписокЭлементов)

	ОбменСервер.Регистрация(СписокЭлементов);

КонецПроцедуры

