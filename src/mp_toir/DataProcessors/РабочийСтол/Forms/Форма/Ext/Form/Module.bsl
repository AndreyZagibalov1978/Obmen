#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПроверитьРезультат(Результат, ВидПроцедуры)
	
	Информация = "";
	Если Результат = Истина Тогда
		Информация = СтрШаблон("%1 завершилась успешно", ВидПроцедуры);
	Иначе
		Информация = СтрШаблон("%1 завершилась с ошибками. %2 Смотрите журнал результатов.", ВидПроцедуры, Символы.ПС);
	КонецЕсли;
	
	ОбщегоНазначенияКлиент.СообщитьПользователю(Информация);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьОстаткиПриАвторизации()

	ЗапускФоновогоЗаданияНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура СостояниеОбновленияДанных()
	Элементы.СтатусОбновленияНоменклатуры.Заголовок = ДатаОбновленияНоменклатуры();
	Элементы.СтатусОбновленияДокументов.Заголовок = ДатаСинхронизацииДокументов();
	Элементы.СтатусОбновленияОстатковТМЦ.Заголовок = ДатаСинхронизацииОстатковТМЦ();
	Элементы.КачествоСвязи.Заголовок = КачествоСвязи();
КонецПроцедуры

&НаКлиенте
Процедура ЗапускФоновогоЗадания()

	СостояниеОбмена = СостояниеОбмена();

	Если СостояниеОбмена.Синхронизация Тогда
		ФоновыеЗаданияВызовСервера.ЗапуститьФоновыйОбмен();
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция СостояниеОбмена()

	ДатаПоследнейСинхронизации = Константы.ДатаПоследнейСинхронизации.Получить();
	ИнтервалОбмена = ИнтервалОбменаСинхронизация();
	Синхронизация = (ТекущаяДатаСеанса() >= (ДатаПоследнейСинхронизации + ИнтервалОбмена));

	ДатаПолученияОстатковТМЦ = Константы.ДатаПолученияОстатковТМЦ.Получить();
	ИнтервалПолученияОстатковТМЦ = ИнтервалПолученияОстатковТМЦ();

	ПолучитьОстаткиТМЦ = (ТекущаяДатаСеанса() >= (ДатаПолученияОстатковТМЦ + ИнтервалПолученияОстатковТМЦ));

	Результат = Новый Структура;
	Результат.Вставить("Синхронизация", Синхронизация);
	Результат.Вставить("ПолучитьОстаткиТМЦ", ПолучитьОстаткиТМЦ);

	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ЗапускЗагрузкиОстатковТМЦ()

	СостояниеОбмена = СостояниеОбмена();
	Если СостояниеОбмена.ПолучитьОстаткиТМЦ Тогда
		ЗапускЗагрузкиОстатковТМЦНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗапускЗагрузкиОстатковТМЦНаСервере()
	ФоновыеЗадания.Выполнить("ФоновыеЗаданияВызовСервера.ОстаткиТМЦ");
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДатаОбновленияНоменклатуры()
	ДатаОбновления = Константы.ДатаОбновленияНоменклатуры.Получить();
	Если ДатаОбновления = Дата(1, 1, 1) Тогда
		Возврат "Остатки номенклатуры устарели";
	Иначе
		Возврат "Остатки номенклатуры актуальны на: " + Строка(ДатаОбновления);
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция ДатаСинхронизацииДокументов()
	ДатаОбновления = Константы.ДатаПоследнейСинхронизации.Получить();
	Если ДатаОбновления = Дата(1, 1, 1) Тогда
		Возврат "Синхронизация документов не производилась";
	Иначе
		Возврат "Дата синхронизация документов: " + Строка(ДатаОбновления);
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция ДатаСинхронизацииОстатковТМЦ()
	ДатаОбновления = Константы.ДатаПолученияОстатковТМЦ.Получить();
	Если ДатаОбновления = Дата(1, 1, 1) Тогда
		Возврат "Синхронизация остатков ТМЦ не производилась";
	Иначе
		Возврат "Дата синхронизация остатков ТМЦ: " + Строка(ДатаОбновления);
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Процедура ЗапускФоновогоЗаданияНаСервере()
	
	ДатаОбновленияНоменклатуры = КонецДня(Константы.ДатаОбновленияНоменклатуры.Получить());
	ТекДата = КонецДня(ТекущаяДатаСеанса());
	
	Если ТекДата > ДатаОбновленияНоменклатуры  Тогда
		ФоновыеЗадания.Выполнить("ФоновыеЗаданияВызовСервера.ОбновлениеНоменклатуры");
	КонецЕсли;

КонецПроцедуры

