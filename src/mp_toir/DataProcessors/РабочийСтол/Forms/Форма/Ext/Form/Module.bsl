	Возврат ЗначенияКонстант["ИнтервалОбмена"];
КонецФункции

&НаСервереБезКонтекста
Функция КачествоСвязи()

#Если МобильноеПриложениеСервер Тогда

	Инфо = Новый ИнформацияОбИнтернетСоединении;
	Скорость = Инфо.ПолучитьОжидаемуюСкоростьСоединения(); // kbps

	Если Скорость < 64 Тогда
		КачествоСоединения = "Нет связи";
	ИначеЕсли Скорость < 128 Тогда
		КачествоСоединения = "Очень медленно (≈2G)";
	ИначеЕсли Скорость < 512 Тогда
		КачествоСоединения = "Медленно (слабый интернет)";
	ИначеЕсли Скорость < 2048 Тогда
		КачествоСоединения = "Средне (≈3G)";
	ИначеЕсли Скорость < 10000 Тогда
		КачествоСоединения = "Хорошо (≈4G)";
	Иначе
		КачествоСоединения = "Отлично";
	КонецЕсли;

	Возврат "Связь: " + КачествоСоединения;

#Иначе

	Возврат "";

#КонецЕсли

КонецФункции

&НаСервере
Процедура ЗаблокироватьРабочийСтол(Знач УстановитьПросмотр)
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, "ГруппаИнформация, ГруппаКоманды, ГруппаКнопки", "Доступность", Не УстановитьПросмотр, Истина);
КонецПроцедуры

