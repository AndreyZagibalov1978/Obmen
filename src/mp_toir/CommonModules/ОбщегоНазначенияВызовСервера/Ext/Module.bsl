// Функция - Проверка ТЧ документа на необработанные строки, не заполнен штрихкод и факт
// 				или незаполнен штрихкод, а факт заполнен
//
// Параметры:
//  Товары	 - ТаблицаЗначений - Табличная часть документа
// 
// Возвращаемое значение:
//   - Булево - Истина, проверка не пройдена, Ложь в противном случае.
//
Функция ЕстьНеобработанныеСтрокиВДокументе(Товары) Экспорт
	
	Отбор = Новый Структура("СерияНомер, КоличествоФакт", "", 0);
	НеобработанныеСтроки = Товары.НайтиСтроки(Отбор);
	Если НеобработанныеСтроки.Количество() > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Отбор = Новый Структура("СерияНомер, КоличествоФакт", "", 1);
	НеобработанныеСтроки = Товары.НайтиСтроки(Отбор);
	Если НеобработанныеСтроки.Количество() > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Процедура - Установить стиль оформления
//
Процедура УстановитьСтильОформления() Экспорт
	
	ИндексТемы = Константы.СтильОформления.Получить();
	Если НЕ ЗначениеЗаполнено(ИндексТемы) Тогда
		ГлавныйСтиль = БиблиотекаСтилей.Получить(4);
		Константы.СтильОформления.Установить(4);
	Иначе
		ГлавныйСтиль = БиблиотекаСтилей[Число(ИндексТемы)];
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Создание каталогов для обмена файлами
//
// Параметры:
//  Каталог	 - Каталог - Созданный каталог для файлов обмена
//
Процедура СоздатьКаталоги(Каталог) Экспорт
	
	Разделитель = ПолучитьРазделительПути();
	мПути = СтрРазделить(Каталог, Разделитель);
	
	Для Сч = 1 По мПути.ВГраница() Цикл
		
		КаталогНаДиске = Новый Файл(мПути[Сч - 1] + Разделитель + мПути[Сч]);
		Если НЕ КаталогНаДиске.Существует() Тогда
			Попытка
				СоздатьКаталог(Каталог);
			Исключение
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не удалось создать каталог: " + Каталог;
				Сообщение.Сообщить();
			КонецПопытки;
		КонецЕсли;
		Сч = Сч + 1;
	КонецЦикла;
	
КонецПроцедуры

#Область ИнициализацияУстройства

Процедура ПервоначальнаяНастройка() Экспорт
	
	// Формируем UUID устройства
	Если НЕ ИдентификаторУстановлен() Тогда
		Константы.ID.Установить(Новый УникальныйИдентификатор);
		
	КонецЕсли;
	
	ПланыОбмена.мп_ОбменМобильноеПриложениеТОИР.УИДУзлаОбменаОстатков();
	
	// Заполняем параметры соединения
	ЗаполнитьПараметрыСоединения();
	
	// Интервал обмена 5 минут
	Константы.ИнтервалОбмена.Установить(5);
	
	// Очистка журнала
	РегистрыСведений.ЖурналРезультатов.ОчиститьЖурналРезультатов();
	
КонецПроцедуры

Функция ИдентификаторУстановлен() Экспорт
	
	Возврат ?(ЗначениеЗаполнено(Константы.ID.Получить()), Истина, Ложь);
	
КонецФункции

// Функция - Создать служебного пользователя
// 
// Возвращаемое значение:
//  Элемент служебного пользователя - СправочникиСсылка.Пользователи
//
Функция СоздатьСлужебногоПользователя() Экспорт
	
	НайденныйПользователь = Справочники.Пользователи.НайтиПоРеквизиту("Логин", "mechel");
	Если НайденныйПользователь.Пустая() Тогда
		ДанныеПользователя = Новый Структура;
		ДанныеПользователя.Вставить("Служебный", Истина);
		ДанныеПользователя.Вставить("Недействителен", Ложь);
		ДанныеПользователя.Вставить("Наименование", "mechel");
		ДанныеПользователя.Вставить("Логин", "mechel");
		ДанныеПользователя.Вставить("ИдентификаторПользователяИБ", Новый УникальныйИдентификатор);
		
		НовыйПользователь = Справочники.Пользователи.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(НовыйПользователь, ДанныеПользователя);
		
		НовыйПользователь.Записать();
	Иначе
		НовыйПользователь = НайденныйПользователь.Ссылка;
	КонецЕсли;
	
	Возврат НовыйПользователь.Ссылка;
	
КонецФункции

Процедура ДобавитьАдминистратораУстройства() Экспорт
	
	ПользовательНайден = Справочники.Пользователи.НайтиПоНаименованию("mechel", Истина);
	Если ПользовательНайден = Неопределено ИЛИ ПользовательНайден = Справочники.Пользователи.ПустаяСсылка() Тогда
		НовыйПользователь = СоздатьСлужебногоПользователя();
		ЗаполнитьСлужебногоПользователяИнфБазы(НовыйПользователь);
	Иначе
		ОчиститьПользователейИнфБазы();
		ЗаполнитьСлужебногоПользователяИнфБазы(ПользовательНайден);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСлужебногоПользователяИнфБазы(Пользователь) Экспорт
	ИмяПользователя = Пользователь.Наименование;
	ИмяВходаПользователя = Пользователь.Логин;
	ВходВПрограммуРазрешен = НЕ Пользователь.Недействителен;
	АутентификацияСтандартная = Истина;
	АутентификацияWIndows = Ложь;
	ЗапрещеноИзменятьПароль = Истина;
	ПоказыватьВСпискеВыбора = Ложь;
	
	ОбновляемыеСвойства = Новый Структура;
	ОбновляемыеСвойства.Вставить("Действие", "Записать");
	ОбновляемыеСвойства.Вставить("ВходВПрограммуРазрешен", ВходВПрограммуРазрешен);
	ОбновляемыеСвойства.Вставить("Имя", ИмяВходаПользователя);
	ОбновляемыеСвойства.Вставить("ПолноеИмя", ИмяПользователя);
	ОбновляемыеСвойства.Вставить("АутентификацияOpenID", Ложь);
	ОбновляемыеСвойства.Вставить("АутентификацияСтандартная", АутентификацияСтандартная);
	ОбновляемыеСвойства.Вставить("АутентификацияWindows", АутентификацияWindows);
	ОбновляемыеСвойства.Вставить("ПарольУстановлен", Ложь);
	ОбновляемыеСвойства.Вставить("ЗапрещеноИзменятьПароль", ЗапрещеноИзменятьПароль);
	ОбновляемыеСвойства.Вставить("ПоказыватьВСпискеВыбора", ПоказыватьВСпискеВыбора);
	
	ПользовательНайден = ПользователиИнформационнойБазы.НайтиПоИмени("mechel");
	Если ПользовательНайден = Неопределено Тогда
		НовыйПользовательИБ = ПользователиИнформационнойБазы.СоздатьПользователя();
		ЗаполнитьЗначенияСвойств(НовыйПользовательИБ, ОбновляемыеСвойства);
		НовыйПользовательИБ.Роли.Добавить(Метаданные.Роли.ПолныеПрава);
		НовыйПользовательИБ.Записать();
	КонецЕсли;
КонецПроцедуры

Процедура ОчиститьПользователейИнфБазы(Полностью = Истина) Экспорт
	СписокПользователей = ПользователиИнформационнойБазы.ПолучитьПользователей();
	Для Каждого ТекПользователь Из СписокПользователей Цикл
		Если ТекПользователь.Имя = "mechel" И Полностью = Ложь Тогда
			Продолжить;
		КонецЕсли;
		ТекПользователь.Удалить();
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

// Функция - Список значений штрихкодов номенклатуры
//
// Параметры:
//  Номенклатура - СправочникСсылка.Номенклатура - Ссылка на номенклатуру
//
// Возвращаемое значение:
//   - СписокЗначений - Штрихкоды маркированной номенклатуры списком значений
//
Функция СписокШтрихкодовПоНоменклатуре(Номенклатура, ИсключитьСерии) Экспорт
	
	СписокЗначенийШтрихкоды = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Мечел_ЛазернаяМаркировка.СерияНомер КАК Штрихкод
		|ИЗ
		|	РегистрСведений.Мечел_ЛазернаяМаркировка КАК Мечел_ЛазернаяМаркировка
		|ГДЕ
		|	Мечел_ЛазернаяМаркировка.Номенклатура = &Номенклатура
		|	И Мечел_ЛазернаяМаркировка.ДатаМаркировки <> ДАТАВРЕМЯ(1, 1, 1)
		|	И НЕ Мечел_ЛазернаяМаркировка.Серия В (&ИсключитьСерии)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Штрихкод";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ИсключитьСерии", ИсключитьСерии);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат СписокЗначенийШтрихкоды;
	КонецЕсли;
	
	ТЗ = РезультатЗапроса.Выгрузить();
	МассивШтрихкодов = ТЗ.ВыгрузитьКолонку("Штрихкод");
	СписокЗначенийШтрихкоды.ЗагрузитьЗначения(МассивШтрихкодов);
	
	Возврат СписокЗначенийШтрихкоды;
	
КонецФункции

#Область ДанныеТОиР

// Функция - Объекты эксплуатации по тех месту
//
// Параметры:
//  ТехнологическоеМесто - Справочник.Мечел_ТехнологическиеМеста - Элемент справочника
//  ВернутьЭлемент - Булево - Если значение Истина то вернет 1 элемент справочника, иначе массив объектов эксплуатации
// 
// Возвращаемое значение:
//  Массив - объектов эксплуатации  - если ничего не найдено вернет Неопределено
//
Функция ОбъектыЭксплуатацииПоТехМесту(Знач ТехнологическоеМесто, ВернутьЭлемент = Ложь) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОбъектыЭксплуатации.Ссылка КАК ОбъектЭксплуатации
	|ИЗ
	|	Справочник.ОбъектыЭксплуатации КАК ОбъектыЭксплуатации
	|ГДЕ
	|	ОбъектыЭксплуатации.ТехнологическоеМесто В ИЕРАРХИИ(&ТехнологическоеМесто)
	|	И НЕ ОбъектыЭксплуатации.ПометкаУдаления
	|	И НЕ ОбъектыЭксплуатации.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("ТехнологическоеМесто", ТехнологическоеМесто);
	
	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		СписокОЭ = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ОбъектЭксплуатации");
		Если ВернутьЭлемент Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Если Выборка.Количество() = 1 Тогда
				Выборка.Следующий();
				Возврат Выборка.ОбъектЭксплуатации;
			Иначе
				Возврат СписокОЭ;
			КонецЕсли;
		Иначе
			Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ОбъектЭксплуатации");
		КонецЕсли;
	КонецЕсли;

КонецФункции

// Функция - Узлы объекта эксплуатации
// Получаем массив узлов объектов эксплуатации по выбранному параметру ОбъектЭксплуатации
// Если узлов нет, возвразает Неопределено
//
// Параметры:
//  ОбъектЭксплуатации - Справочник.ОбъектыЭксплуатации - Элемент справочника
// 
// Возвращаемое значение:
//  Массив - узлы объекта эксплуатации 
//
Функция УзлыОбъектаЭксплуатации(Знач ОбъектЭксплуатации) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УзлыОбъектовЭксплуатации.Ссылка КАК Узлы
	|ИЗ
	|	Справочник.УзлыОбъектовЭксплуатации КАК УзлыОбъектовЭксплуатации
	|ГДЕ
	|	УзлыОбъектовЭксплуатации.Владелец В ИЕРАРХИИ(&ОбъектЭксплуатации)
	|	И НЕ УзлыОбъектовЭксплуатации.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ОбъектЭксплуатации", ОбъектЭксплуатации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Узлы");
	КонецЕсли;

КонецФункции

// Функция - Редактирование формы документа ТОиР
// определяет доступность редактирвоания документа по ролям
//
// Параметры:
//  Подразделение	 - Справочник.СтруктураПредприятия 	  - Подразделение документа
//  Ответственный	  - Справочник.Пользователи 	 - Ответственный документа
//  СтатусОбмена	-  Перечисление.мп_СтатусыОбмена 	 - Статус обмена документа
// 
// Возвращаемое значение:
// Булево - Истина, если разрешено изменять форму документа, иначе Ложь
//
Функция РедактированиеФормыДокументаТОиР(Знач Подразделение, Знач Ответственный, Знач СтатусОбмена) Экспорт
	
	Если РольДоступна("ПолныеПрава") Или РольДоступна("мп_АдминистрированиеТОиР") Тогда
		Возврат Истина;
	ИначеЕсли РольДоступна("мп_ПросмотрДокументовТОиР") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
	ПодразделениеПользователя = РеквизитыКонстант["ПодразделениеПользователя"];
	ТекущийПользователь = РеквизитыКонстант["ТекущийПользователь"];
	
	Если РольДоступна("мп_БригадирТОиР") Тогда
		Если ПодразделениеПользователя = Подразделение 
			И (Перечисления.мп_СтатусыОбмена.Создан = СтатусОбмена) Тогда
			Возврат Истина;
		ИначеЕсли ПодразделениеПользователя = Подразделение И Не ЗначениеЗаполнено(Ответственный) Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	СтатусыДляРедактирования = Новый Массив;
	СтатусыДляРедактирования.Добавить(Перечисления.мп_СтатусыОбмена.Создан);
	СтатусыДляРедактирования.Добавить(Перечисления.мп_СтатусыОбмена.ЗагруженИзКИС);
	
	Если РольДоступна("мп_ДобавлениеИзменениеДокументовТОиР") Тогда
		Если ПодразделениеПользователя = Подразделение И ТекущийПользователь = Ответственный
			И (Не СтатусыДляРедактирования.Найти(СтатусОбмена) = Неопределено) Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Возврат Ложь;

КонецФункции

// Функция - Доступность параметра отбора документов
//
// Параметры:
//  ТекущийПользователь	 - Справочник.Пользователи 	 - Ответственный документа
// 
// Возвращаемое значение:
//  Структура - 
//
Функция ДоступностьПараметраОтбораДокументов(ТекущийПользователь) Экспорт

	ДоступностьОтбора = Новый Структура;
	ДоступностьОтбора.Вставить("Подразделение", Ложь);
	ДоступностьОтбора.Вставить("Ответственный", Ложь);

	Если РольДоступна("ПолныеПрава") Или РольДоступна("мп_АдминистрированиеТОиР") 
		Или РольДоступна("мп_ПросмотрДокументовТОиР")
		Или РольДоступна("мп_БригадирТОиР") Тогда
		
		ДоступностьОтбора.Подразделение = Истина;
		ДоступностьОтбора.Ответственный = Истина;

		Возврат ДоступностьОтбора;

	КонецЕсли;

	Если РольДоступна("мп_ДобавлениеИзменениеДокументовТОиР") Тогда

		ДоступностьОтбора.Подразделение = Ложь;
		ДоступностьОтбора.Ответственный = Ложь;

		Возврат ДоступностьОтбора;
	Иначе

		Возврат Неопределено;

	КонецЕсли;

КонецФункции

// Функция - Подразделения пользователей
// Получает массив подразделений из справочника пользователи и ранее использованных подразделения в документах
//
// Возвращаемое значение:
// Подразделения  - Массив - Список подразделений
//
Функция ПодразделенияПользователей() Экспорт

	Запрос = Новый Запрос;

	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Пользователи.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ вт_Подразделения
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	НЕ Пользователи.Подразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	мп_РегистрацияПроверокОборудования.Подразделение
	|ИЗ
	|	Документ.мп_РегистрацияПроверокОборудования КАК мп_РегистрацияПроверокОборудования
	|ГДЕ
	|	НЕ мп_РегистрацияПроверокОборудования.Подразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НаработкаОбъектовЭксплуатации.Подразделение
	|ИЗ
	|	Документ.НаработкаОбъектовЭксплуатации КАК НаработкаОбъектовЭксплуатации
	|ГДЕ
	|	НЕ НаработкаОбъектовЭксплуатации.Подразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Подразделения.Подразделение КАК Подразделение
	|ИЗ
	|	вт_Подразделения КАК вт_Подразделения";

	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		
		Возврат Новый Массив;
		
	Иначе
		
		Возврат Результат.Выгрузить().ВыгрузитьКолонку("Подразделение");
		
	КонецЕсли;

КонецФункции

Функция ХарактеристикиПоНоменклатуре(Знач Номенклатура) Экспорт

	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

	Запрос.Текст = 
	 "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ХарактеристикиНоменклатуры.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ вт_Характеристика
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|		ПО (ВЫРАЗИТЬ(ХарактеристикиНоменклатуры.Владелец КАК Справочник.Номенклатура).ВидНоменклатуры = ВидыНоменклатуры.Ссылка)
	|			И ((ВЫРАЗИТЬ(ХарактеристикиНоменклатуры.Владелец КАК Справочник.Номенклатура)) = &Номенклатура)
	|			И (ВидыНоменклатуры.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ХарактеристикиНоменклатуры.Ссылка
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|		ПО ((ВЫРАЗИТЬ(ХарактеристикиНоменклатуры.Владелец КАК Справочник.ВидыНоменклатуры)) = ВЫРАЗИТЬ(&Номенклатура КАК Справочник.Номенклатура).ВидНоменклатуры)
	|			И (НЕ ВидыНоменклатуры.ИспользованиеХарактеристик В (ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры), ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Характеристика.Ссылка КАК Характеристика
	|ИЗ
	|	вт_Характеристика КАК вт_Характеристика";

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат Результат.Выгрузить().ВыгрузитьКолонку("Характеристика");
	КонецЕсли;

КонецФункции

Функция СерииПоНоменклатуре(Знач Номенклатура) Экспорт
	
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВидыНоменклатуры.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ вт_ВидыНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|		ПО (Номенклатура.ВидНоменклатуры = ВидыНоменклатуры.Ссылка)
	|			И (ВидыНоменклатуры.ИспользоватьСерии)
	|			И (Номенклатура.Ссылка = &Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СерииНоменклатуры.Ссылка КАК Серия
	|ИЗ
	|	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_ВидыНоменклатуры КАК вт_ВидыНоменклатуры
	|		ПО (СерииНоменклатуры.ВидНоменклатуры = вт_ВидыНоменклатуры.Ссылка)";

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат Результат.Выгрузить().ВыгрузитьКолонку("Серия");
	КонецЕсли;
	
