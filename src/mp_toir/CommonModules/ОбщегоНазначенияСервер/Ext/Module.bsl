	Информация.Вставить("ID", Константы.ID.Получить());
	Информация.Вставить("ГруппаСкладов", Строка(Константы.ГруппаСкладовОбменаДанными.Получить()));

	ИнформацияСтруктура = Новый Структура;
	ИнформацияСтруктура.Вставить("ВерсияОС", Строка(Инфо.ВерсияОС));
	ИнформацияСтруктура.Вставить("ВерсияПриложения", Строка(Инфо.ВерсияПриложения));
	ИнформацияСтруктура.Вставить("ИдентификаторКлиента", Строка(Инфо.ИдентификаторКлиента));
	ИнформацияСтруктура.Вставить("ОперативнаяПамять", Строка(Инфо.ОперативнаяПамять));
	ИнформацияСтруктура.Вставить("Процессор", Строка(Инфо.Процессор));
	ИнформацияСтруктура.Вставить("ТипПлатформы", Строка(Инфо.ТипПлатформы));
	
	ИнформацияСтруктура.Вставить("Конфигурация", Строка(Метаданные.Имя));
