#Область ПрограммныйИнтерфейс

#Область Константы

Функция ПолучитьЗначенияКонстант() Экспорт
	
	Результат = Новый Соответствие;
	
	Результат.Вставить("ТекущийПользователь", Константы.ТекущийПользователь.Получить());
	Результат.Вставить("ОрганизацияПользователя", Константы.ОрганизацияПользователя.Получить());
	Результат.Вставить("ПодразделениеПользователя", Константы.ПодразделениеПользователя.Получить());
	Результат.Вставить("ГруппаСкладовОбменаДанными", Константы.ГруппаСкладовОбменаДанными.Получить());
	Результат.Вставить("РаботатьОффлайн", Константы.РаботатьОффлайн.Получить());
	Результат.Вставить("МаксимальныйРазмерФото", Константы.МаксимальныйРазмерФото.Получить());
	Результат.Вставить("УИДУзелОбменаОстатков", Константы.УИДУзелОбменаОстатков.Получить());
	Результат.Вставить("ID", Константы.ID.Получить());
	ИнтервалОбмена = Константы.ИнтервалОбмена.Получить();
	Результат.Вставить("ИнтервалОбмена", ИнтервалОбмена * 60);
	
	Возврат Результат;
	
КонецФункции

Процедура УстановитьЗначенияКонстант(Данные) Экспорт
	
	Для Каждого ЗначениеКонстанты Из Данные Цикл
		Константы[ЗначениеКонстанты.Ключ].Установить(ЗначениеКонстанты.Значение);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

