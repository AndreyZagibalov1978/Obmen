#Область ТОиР

Функция ЗапретПометкиУдаленияДокументовТОиР(Знач СтатусОбмена, Знач Источник = Неопределено) Экспорт
	
	Если Не Источник = Неопределено Тогда
		Если Перечисления.мп_ИсточникиДокументов.КИС = Источник Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ИмеетПолныеПраваТОиР() Тогда
		Возврат Ложь;
	КонецЕсли;

		
	ДоступныеСтатусы = Новый Массив;
	ДоступныеСтатусы.Добавить(Перечисления.мп_СтатусыОбмена.Создан);

	Возврат ДоступныеСтатусы.Найти(СтатусОбмена) = Неопределено;
	
КонецФункции

Функция ИмеетПолныеПраваТОиР() Экспорт
	
	Если РольДоступна("мп_АдминистрированиеТОиР") Или РольДоступна("ПолныеПрава") Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции

#Область Справочники

Функция ЗапретОткрытияЭлементаФормы() Экспорт

	ПраваДоступа = ОбщегоНазначенияВызовСервера.ДоступныеПрава();
	Если ПраваДоступа.АдминТОиР Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;

КонецФункции

Функция ОткрытиеПросмотр() Экспорт

	ПраваДоступа = ОбщегоНазначенияВызовСервера.ДоступныеПрава();
	Если ПраваДоступа.АдминТОиР Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;

КонецФункции

