//	Возврат Информация;
	
	Возврат ИнформацияСтруктура;
	
КонецФункции

Функция ПараметрыСинхронизации() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеСинхронизации = Новый Структура;
	УИДГруппаСкладовОбменаДанными = "";
	Склад = Константы.ГруппаСкладовОбменаДанными.Получить();
	Если ЗначениеЗаполнено(Склад) Тогда
		УИДГруппаСкладовОбменаДанными = Строка(Склад.УникальныйИдентификатор());
	КонецЕсли;
	ДанныеСинхронизации.Вставить("УИДГруппаСкладовОбменаДанными", УИДГруппаСкладовОбменаДанными);

	Возврат ДанныеСинхронизации;
	
КонецФункции

#КонецОбласти

#Область Связь

Функция СоединениеВозможно() Экспорт
	
	#Если МобильноеПриложениеСервер Тогда
		ИнформацияОбСоединении = Новый ИнформацияОбИнтернетСоединении;
		ТипСоединения = ИнформацияОбСоединении.ПолучитьТипСоединения();
		Если ТипСоединения = ТипИнтернетСоединения.НетСоединения Тогда
			Возврат Ложь;
		Иначе
			СкоростьСоединения = ИнформацияОбСоединении.ПолучитьОжидаемуюСкоростьСоединения();
			Если СкоростьСоединения > 100 Тогда
				Возврат Истина;
			Иначе
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
	#Иначе
		Возврат Истина;
	#КонецЕсли
	
КонецФункции

Функция ПолучитьОжидаемуюСкоростьСоединения() Экспорт
	
	#Если МобильноеПриложениеСервер Тогда
		ИнформацияОбСоединении = Новый ИнформацияОбИнтернетСоединении;
		Возврат ИнформацияОбСоединении.ПолучитьОжидаемуюСкоростьСоединения();
	#Иначе
		Возврат 1000;
	#КонецЕсли
	
КонецФункции

