	Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Номенклатура));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Номенклатура);
	Если Не СсылкаСуществует Тогда
