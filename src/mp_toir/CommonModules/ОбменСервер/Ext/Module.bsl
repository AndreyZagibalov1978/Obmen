	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);

	Если СсылкаСуществует Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.ТехнологическиеОперации.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;

	НовыйЭлемент.ОбменДанными.Загрузка = Истина;

	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);
	НовыйЭлемент.Мечел_СпособВыполнения = СпособыВыполнения[Строка(ОбъектXDTO.Мечел_СпособВыполнения)];
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	НовыйЭлемент.МожноПовторить = ?(ОбъектXDTO.МожноПовторить = "true", Истина, Ложь);
	НовыйЭлемент.МожноПропустить = ?(ОбъектXDTO.МожноПропустить = "true", Истина, Ложь);
	НовыйЭлемент.Мечел_ФотоотчетОбязателен = ?(ОбъектXDTO.Мечел_ФотоотчетОбязателен = "true", Истина, Ложь);
	НовыйЭлемент.Мечел_ИзмерениеОбязательно = ?(ОбъектXDTO.Мечел_ИзмерениеОбязательно = "true", Истина, Ложь);
	НовыйЭлемент.мп_ПроверкаОбязательна = ?(ОбъектXDTO.мп_ПроверкаОбязательна = "true", Истина, Ложь);

	мп_ПоказательИзмерения = Справочники.ПоказателиНаработки.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.мп_ПоказательИзмерения));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(мп_ПоказательИзмерения);

	Если СсылкаСуществует Тогда
		НовыйЭлемент.мп_ПоказательИзмерения = мп_ПоказательИзмерения; 
	КонецЕсли;

	мп_ВидПроверки = Справочники.мп_ВидыПроверокОборудования.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.мп_ВидПроверки));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(мп_ВидПроверки);

	Если СсылкаСуществует Тогда
		НовыйЭлемент.мп_ВидПроверки = мп_ВидПроверки; 
	КонецЕсли;

	Попытка
		НовыйЭлемент.Записать();

	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.ТехнологическиеОперации | Ошибка записи элемента ТехнологическиеОперации %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
	КонецПопытки;


КонецПроцедуры

#Область Номенклатура

Процедура ЗаписатьВидыНоменклатуры(Знач ОбъектXDTO, СтруктураДанных, ТаблицаНастроекВидыНоменклатуры = Неопределено)

	Если ТипЗнч(ОбъектXDTO) = Тип("ЧтениеXML") Тогда
		ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ОбъектXDTO);
	КонецЕсли;
	НоваяСсылка = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);

	Если СсылкаСуществует Тогда
		Если ОбщегоНазначенияПовтИсп.СовпадаетВерсияДанныхЕРП(НоваяСсылка.ВерсияДанныхЕРП, ОбъектXDTO.ВерсияДанныхЕРП) Тогда
			Возврат;
		КонецЕсли;
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		Если ОбъектXDTO.IsFolder = "true" Тогда
			НовыйЭлемент = Справочники.ВидыНоменклатуры.СоздатьГруппу();
		Иначе
			НовыйЭлемент = Справочники.ВидыНоменклатуры.СоздатьЭлемент();
		КонецЕсли;
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	
	Родитель = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Parent));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Родитель);
	Если Не СсылкаСуществует Тогда
		Родитель = Справочники.ВидыНоменклатуры.ПустаяСсылка();
	КонецЕсли;

	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);
	Если Не ОбъектXDTO.IsFolder = "true" Тогда
		НовыйЭлемент.ИспользоватьСерии = ?(СокрЛП(ОбъектXDTO.ИспользоватьСерии) = "true", Истина, Ложь);
		
		ИспользованиеХарактеристик = Новый Соответствие;
		Для Каждого ТекСтрока Из Перечисления.ВариантыИспользованияХарактеристикНоменклатуры Цикл
			ИспользованиеХарактеристик.Вставить(XMLСтрока(ТекСтрока), ТекСтрока);
		КонецЦикла;
		ИспользованиеХарактеристик.Вставить("ОбъектXDTO", Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать);
		НовыйЭлемент.ИспользованиеХарактеристик = ИспользованиеХарактеристик[Строка(ОбъектXDTO.ИспользованиеХарактеристик)];
		
	КонецЕсли;
	НовыйЭлемент.Родитель = Родитель;
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);

	Попытка
		НовыйЭлемент.Записать();
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.ВидыНоменклатуры | Ошибка записи элемента ВидыНоменклатуры %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;
	
	
	Если ТипЗнч(ТаблицаНастроекВидыНоменклатуры) = Тип("ТаблицаЗначений") Тогда
		КодНастройки = ?(Строка(ОбъектXDTO.КодНастройки) = "ОбъектXDTO", "", Строка(ОбъектXDTO.КодНастройки));
		УИДНастройки = ?(Строка(ОбъектXDTO.УИДНастройки) = "ОбъектXDTO", "", Строка(ОбъектXDTO.УИДНастройки));
		ВерсияДанныхНастройки = 
			?(Строка(ОбъектXDTO.ВерсияДанныхНастройки) = "ОбъектXDTO", "", Строка(ОбъектXDTO.ВерсияДанныхНастройки));
		
		Если Не ПустаяСтрока(КодНастройки) И Не ПустаяСтрока(УИДНастройки) Тогда
			Отбор = Новый Структура;
			Отбор.Вставить("ВидНоменклатуры", НовыйЭлемент.Ссылка);
			Отбор.Вставить("КодНастройки", КодНастройки);
			СтрокиНастроек = ТаблицаНастроекВидыНоменклатуры.НайтиСтроки(Отбор);
			Если СтрокиНастроек.Количество() = 0 Тогда
				НоваяСтрока = ТаблицаНастроекВидыНоменклатуры.Добавить();
				НоваяСтрока.ВидНоменклатуры = НовыйЭлемент.Ссылка;
				НоваяСтрока.КодНастройки = КодНастройки;
				НоваяСтрока.УИДНастройки = УИДНастройки;
				НоваяСтрока.ВерсияДанныхЕРП = ВерсияДанныхНастройки;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

