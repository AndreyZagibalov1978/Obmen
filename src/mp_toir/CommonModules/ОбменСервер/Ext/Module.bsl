Процедура ЗаписатьУзелОбъектовЭксплуатации(ЧтениеXML, СтруктураДанных, Отправитель = Неопределено)
	СтатусОС = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.СтатусыОбъектовЭксплуатации Цикл 
	
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СтатусОС.Вставить(ИдентификаторЗначения, ТекЗначПер);
		
	КонецЦикла;
	
	ГруппаТиповУзлов = Новый Соответствие;
	ГруппаТиповУзлов.Вставить("ОбъектXDTO", Перечисления.Мечел_ГруппаТиповУзлов.ПустаяСсылка());
	Для Каждого ТекСтрока Из Перечисления.Мечел_ГруппаТиповУзлов Цикл
		ИдентификаторЗначения = XMLСтрока(ТекСтрока);
		ГруппаТиповУзлов.Вставить(ИдентификаторЗначения, ТекСтрока);
	КонецЦикла;
	
	Если ТипЗнч(ЧтениеXML) = Тип("ОбъектXDTO") Тогда
		ОбъектXDTO = ЧтениеXML;
	Иначе
		ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	КонецЕсли;
	
	НоваяСсылка = Справочники.УзлыОбъектовЭксплуатации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаСуществует Тогда
		Если ОбщегоНазначенияПовтИсп.СовпадаетВерсияДанныхЕРП(НоваяСсылка.ВерсияДанныхЕРП, ОбъектXDTO.ВерсияДанныхЕРП) Тогда
			Возврат;
		КонецЕсли;
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.УзлыОбъектовЭксплуатации.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	Родитель = Справочники.УзлыОбъектовЭксплуатации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Parent));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Родитель);
	Если СсылкаСуществует Тогда
		НовыйЭлемент.Родитель = Родитель;
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO, "СерийныйНомер,Description,ВерсияДанныхЕРП");

	НовыйЭлемент.СерийныйНомер = ?(Строка(ОбъектXDTO.СерийныйНомер) = "ОбъектXDTO", "", ОбъектXDTO.СерийныйНомер);
	НовыйЭлемент.КаталожныйНомер = ?(Строка(ОбъектXDTO.КаталожныйНомер) = "ОбъектXDTO", "", ОбъектXDTO.КаталожныйНомер);
	
	Владелец = Справочники.ОбъектыЭксплуатации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Владелец));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Владелец);
	Если СсылкаСуществует Тогда
		НовыйЭлемент.Владелец = Владелец;
	КонецЕсли;
	Класс =  Справочники.КлассыОбъектовЭксплуатации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Класс));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Класс);
	Если СсылкаСуществует Тогда
		НовыйЭлемент.Класс = Класс;
	КонецЕсли;
	НовыйЭлемент.Статус = СтатусОС[ОбъектXDTO.Статус];
	НовыйЭлемент.ГруппаТиповУзлов = ГруппаТиповУзлов[Строка(ОбъектXDTO.ГруппаТиповУзлов)];
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	Попытка
		НовыйЭлемент.Записать();
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.УзлыОбъектовЭксплуатации | Ошибка записи элемента %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

Процедура ЗаписатьОбъектыЭксплуатации(ЧтениеXML, СтруктураДанных, Знач Отправитель = Неопределено)
	
	СтатусОС = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.СтатусыОбъектовЭксплуатации Цикл 
	
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СтатусОС.Вставить(ИдентификаторЗначения, ТекЗначПер);
		
	КонецЦикла;
	
	Если ТипЗнч(ЧтениеXML) = Тип("ОбъектXDTO") Тогда
		ОбъектXDTO = ЧтениеXML;
	Иначе
		ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	КонецЕсли;
	
	НоваяСсылка = Справочники.ОбъектыЭксплуатации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаСуществует Тогда
		Если ОбщегоНазначенияПовтИсп.СовпадаетВерсияДанныхЕРП(НоваяСсылка.ВерсияДанныхЕРП, ОбъектXDTO.ВерсияДанныхЕРП) Тогда
			Возврат;
		КонецЕсли;
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.ОбъектыЭксплуатации.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO, "Code,Description,ИнвентарныйНомер,ВерсияДанныхЕРП");
	НовыйЭлемент.ДатаПринятияКУчету = СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.ДатаПринятияКУчету);
	НовыйЭлемент.Статус = СтатусОС[ОбъектXDTO.Статус];
	
	ТехнологическоеМесто = Справочники.Мечел_ТехнологическиеМеста.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.ТехнологическоеМесто));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ТехнологическоеМесто);
	Если Не СсылкаСуществует Тогда
		ТехнологическоеМесто = Справочники.Мечел_ТехнологическиеМеста.ПустаяСсылка();
	КонецЕсли;
	НовыйЭлемент.ТехнологическоеМесто = ТехнологическоеМесто;
	
	Класс = Справочники.КлассыОбъектовЭксплуатации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Класс));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Класс);
	Если Не СсылкаСуществует Тогда
		Класс = Справочники.КлассыОбъектовЭксплуатации.ПустаяСсылка();
	КонецЕсли;
	НовыйЭлемент.Класс = Класс;
	
	Попытка
		НовыйЭлемент.Записать();
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.КлассыОбъектовЭксплуатации | Ошибка записи элемента %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
	КонецПопытки;
			
КонецПроцедуры

Процедура ЗаписатьПоказателиНаработки(ЧтениеXML, СтруктураДанных, Отправитель)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НоваяСсылка = Справочники.ПоказателиНаработки.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаСуществует Тогда
		Если ОбщегоНазначенияПовтИсп.СовпадаетВерсияДанныхЕРП(НоваяСсылка.ВерсияДанныхЕРП, ОбъектXDTO.ВерсияДанныхЕРП) Тогда
			Возврат;
		КонецЕсли;
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		Если ОбъектXDTO.IsFolder = "true" Тогда
			НовыйЭлемент = Справочники.ПоказателиНаработки.СоздатьГруппу();
		Иначе
			НовыйЭлемент = Справочники.ПоказателиНаработки.СоздатьЭлемент();
		КонецЕсли;
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	
	Родитель = Справочники.ПоказателиНаработки.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Parent));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Родитель);
	Если Не СсылкаСуществует Тогда
		Родитель = Справочники.ПоказателиНаработки.ПустаяСсылка();
	КонецЕсли;
	
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO, ",Description,ЕдиницаИзмерения,ВерсияДанныхЕРП");
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	
	НовыйЭлемент.Родитель = Родитель;
	Попытка
		НовыйЭлемент.Записать();
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.ПоказателиНаработки | Ошибка записи элемента показатели наработки %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;

КонецПроцедуры

