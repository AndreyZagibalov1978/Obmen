Процедура ЗаписатьНоменклатуру(ОбъектXDTO, СтруктураДанных)

//	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);

	НоваяСсылка = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);

	Если СсылкаСуществует Тогда
		Если ОбщегоНазначенияПовтИсп.СовпадаетВерсияДанныхЕРП(НоваяСсылка.ВерсияДанныхЕРП, ОбъектXDTO.ВерсияДанныхЕРП) Тогда
			Возврат;
		КонецЕсли;
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		Если ОбъектXDTO.IsFolder = "true" Тогда
			НовыйЭлемент = Справочники.Номенклатура.СоздатьГруппу();
		Иначе
			НовыйЭлемент = Справочники.Номенклатура.СоздатьЭлемент();
		КонецЕсли;
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	
	Родитель = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Parent));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Родитель);
	
	Если Не СсылкаСуществует Тогда
		Родитель = Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	ГрадацииКачества = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.ГрадацииКачества Цикл 
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		ГрадацииКачества.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	ГрадацииКачества.Вставить("ОбъектXDTO", Перечисления.ГрадацииКачества.ПустаяСсылка());
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);
	
	НовыйЭлемент.Артикул = ?(Строка(ОбъектXDTO.Артикул) = "ОбъектXDTO", "", ОбъектXDTO.Артикул);

	ВидНоменклатуры = Справочники.ВидыНоменклатуры.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.ВидНоменклатуры));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ВидНоменклатуры);
	
	Если СсылкаСуществует Тогда

		НовыйЭлемент.ВидНоменклатуры = ВидНоменклатуры;

	КонецЕсли;
	
	ЕдиницаИзмерения = Справочники.УпаковкиЕдиницыИзмерения.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.ЕдиницаИзмерения));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ЕдиницаИзмерения);
	
	Если СсылкаСуществует Тогда

		НовыйЭлемент.ЕдиницаИзмерения = ЕдиницаИзмерения;

	КонецЕсли;
	
	Если Не ОбъектXDTO.IsFolder = "true" Тогда
		НовыйЭлемент.Мечел_ПодлежитЛазернойМаркировке = ?(ОбъектXDTO.Мечел_ПодлежитЛазернойМаркировке = "true", Истина, Ложь);
		НовыйЭлемент.Качество = ГрадацииКачества[ОбъектXDTO.Качество];
		НовыйЭлемент.Мечел_БУ = ?(ОбъектXDTO.Мечел_БУ = "true", Истина, Ложь);
	КонецЕсли;
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	НовыйЭлемент.Цена = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ОбъектXDTO.Цена);
	НовыйЭлемент.Родитель = Родитель;
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);

	Попытка
		НовыйЭлемент.Записать();

	Исключение
		СтрокаОшибки = СтрШаблон(
			"ОбменСервер.Номенклатура | Ошибка записи элемента Номенклатура %1",
			ОбъектXDTO.Description);
		HTTPCore.ЗаписатьМобильнуюОшибку(СтрокаОшибки, СтруктураДанных, , ОписаниеОшибки());

	КонецПопытки;

КонецПроцедуры

Процедура ЗаписатьХарактеристикиНоменклатуры(ОбъектXDTO, СтруктураДанных)

	НоваяСсылка = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);

	Если СсылкаСуществует Тогда
		Если ОбщегоНазначенияПовтИсп.СовпадаетВерсияДанныхЕРП(НоваяСсылка.ВерсияДанныхЕРП, ОбъектXDTO.ВерсияДанныхЕРП) Тогда
			Возврат;
		КонецЕсли;
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;

	НовыйЭлемент.ОбменДанными.Загрузка = Истина;

	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);

	Если ОбъектXDTO.ТипВладельца = "ВИДЫНОМЕНКЛАТУРЫ" Тогда
		Владелец = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Владелец));
	Иначе
		Владелец = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Владелец));
	КонецЕсли;

	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Владелец);

	Если СсылкаСуществует Тогда
		НовыйЭлемент.Владелец = Владелец;
	КонецЕсли;
	
	ОС = Справочники.ОбъектыЭксплуатации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ОС));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ОС);

	Если СсылкаСуществует Тогда
		
		НовыйЭлемент.ОС = ОС;
		
	КонецЕсли;
	
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);

	Попытка
		НовыйЭлемент.Записать();

	Исключение
		СтрокаОшибки = СтрШаблон(
			"ОбменСервер.ХарактеристикиНоменклатуры | Ошибка записи элемента ХарактеристикиНоменклатуры %1",
			ОбъектXDTO.Description);
		HTTPCore.ЗаписатьМобильнуюОшибку(СтрокаОшибки	, СтруктураДанных, , ОписаниеОшибки());

	КонецПопытки;
КонецПроцедуры

Процедура ЗаписатьНазначения(ОбъектXDTO, СтруктураДанных)

	НоваяСсылка = Справочники.Назначения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	
	Если СсылкаСуществует Тогда
		Если ОбщегоНазначенияПовтИсп.СовпадаетВерсияДанныхЕРП(НоваяСсылка.ВерсияДанныхЕРП, ОбъектXDTO.ВерсияДанныхЕРП) Тогда
			Возврат;
		КонецЕсли;
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.Назначения.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;

	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);
	
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	
	Попытка
		НовыйЭлемент.Записать();
		
	Исключение
		СтрокаОшибки = СтрШаблон(
			"ОбменСервер.СерииНоменклатуры | Ошибка записи элемента СерииНоменклатуры %1",
			ОбъектXDTO.Description);
		HTTPCore.ЗаписатьМобильнуюОшибку(СтрокаОшибки, СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;

КонецПроцедуры

Процедура ЗаписатьНаборТМЦ(ОбъектXDTO, СтруктураДанных, НаборТМЦ, Период)
	ОбъектЭксплуатации = Справочники.ОбъектыЭксплуатации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Объект));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ОбъектЭксплуатации);
	Если Не СсылкаСуществует Тогда
		ОбъектЭксплуатации = Справочники.ОбъектыЭксплуатации.ПустаяСсылка();
	КонецЕсли;
	
	Узел = Справочники.УзлыОбъектовЭксплуатации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Узел));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Узел);
	Если Не СсылкаСуществует Тогда
		Узел = Справочники.УзлыОбъектовЭксплуатации.ПустаяСсылка();
	КонецЕсли;
	
	Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Номенклатура));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Номенклатура);
	Если Не СсылкаСуществует Тогда
		Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Характеристика));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Характеристика);
	Если Не СсылкаСуществует Тогда
		Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	
	Серия = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Серия));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Серия);
	Если Не СсылкаСуществует Тогда
		Серия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	Количество = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ОбъектXDTO.Количество);
	
	НоваяЗапись = НаборТМЦ.Добавить();
	НоваяЗапись.Период = Период;
	НоваяЗапись.Объект = ОбъектЭксплуатации;
	НоваяЗапись.Узел = Узел;
	НоваяЗапись.Номенклатура = Номенклатура;
	НоваяЗапись.Характеристика = Характеристика;
	НоваяЗапись.Серия = Серия;
	НоваяЗапись.Количество = Количество;

КонецПроцедуры

Процедура ЗаписатьОстаткиПоНоменклатуре(ОбъектXDTO, СтруктураДанных, ОстаткиПоНоменклатуре)

	Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Номенклатура));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Номенклатура);
	Если Не СсылкаСуществует Тогда
		Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Характеристика));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Характеристика);
	Если Не СсылкаСуществует Тогда
		Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	
	Назначение = Справочники.Назначения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Назначение));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Назначение);
	Если Не СсылкаСуществует Тогда
		Назначение = Справочники.Назначения.ПустаяСсылка();
	КонецЕсли;
	
	Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Склад));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Склад);
	Если Не СсылкаСуществует Тогда
		Склад = Справочники.Склады.ПустаяСсылка();
	КонецЕсли;
	
	Серия = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Серия));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Серия);
	Если Не СсылкаСуществует Тогда
		Серия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	
	НоваяЗапись = ОстаткиПоНоменклатуре.Добавить();
	НоваяЗапись.Период = НачалоДня(ТекущаяДатаСеанса());
	НоваяЗапись.Номенклатура = Номенклатура;
	НоваяЗапись.Характеристика = Характеристика;
	НоваяЗапись.Назначение = Назначение;
	НоваяЗапись.Склад = Склад;
	НоваяЗапись.Серия = Серия;
	НоваяЗапись.ВНаличии = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ОбъектXDTO.ВНаличии);
	НоваяЗапись.КОтгрузке = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ОбъектXDTO.КОтгрузке);
	НоваяЗапись.Остаток = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ОбъектXDTO.Остаток);
	
КонецПроцедуры

