#Область ПрограммныйИнтерфейс

#Область ИдентификацияПользователяОС

 Функция Идентификация(ПараметрыВхода) Экспорт
	
	СтруктураДанных = HTTPCore.ПолучитьСтруктуруОбрабатываемыхДанных();
	ПараметрыПодключения = HTTPExchange.ПолучитьПараметрыСоединения();
	Если ПараметрыПодключения = Неопределено Тогда
		HTTPCore.ЗаписатьМобильнуюОшибку("ОбменСервер.Регистрация | Не заполнены параметры подключения.",
			СтруктураДанных);
		
	КонецЕсли;
	
	ПланыОбмена.мп_ОбменМобильноеПриложениеТОИР.ДанныеПланаОбмена(СтруктураДанных);
	СтруктураДанных.ИнформацияОбустройстве = ОбщегоНазначенияСервер.ПолучитьИнформациюОбУстройстве();
	СтруктураДанных.ИдентификацияПользователя = ПараметрыВхода;
	СтруктураДанных.БазаЕРП = XmlСтрока(Константы.БазаЕРП.Получить());
	СоединениеHTTP = HTTPExchange.ПолучитьСоединениеHTTP(СтруктураДанных, ПараметрыПодключения);
	
	Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
		Возврат Ложь;
		
	КонецЕсли;
	
	HTTPExchange.DataTransferHTTP("identification", СтруктураДанных, СоединениеHTTP, ПараметрыПодключения);
	Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область Регистрация

Функция Регистрация(СписокОбновленийДанных = Неопределено) Экспорт

	СтруктураДанных = HTTPCore.ПолучитьСтруктуруОбрабатываемыхДанных();
	ПараметрыПодключения = HTTPExchange.ПолучитьПараметрыСоединения();
	Если ПараметрыПодключения = Неопределено Тогда
		HTTPCore.ЗаписатьМобильнуюОшибку("ОбменСервер.Регистрация | Не заполнены параметры подключения.",
			СтруктураДанных);
		
	КонецЕсли;
	
	ПланыОбмена.мп_ОбменМобильноеПриложениеТОИР.ДанныеПланаОбмена(СтруктураДанных);
	СтруктураДанных.ИнформацияОбустройстве = ОбщегоНазначенияСервер.ПолучитьИнформациюОбУстройстве();
	СтруктураДанных.СписокОбновленийДанных = СписокОбновленийДанных;
	СтруктураДанных.БазаЕРП = XmlСтрока(Константы.БазаЕРП.Получить());
	СтруктураДанных.ПользователиМП = Справочники.Пользователи.АктуальныеПользователиМП();
	СтруктураДанных.ДанныеПользователя = Справочники.Пользователи.ДанныеПользователя();
	СоединениеHTTP = HTTPExchange.ПолучитьСоединениеHTTP(СтруктураДанных, ПараметрыПодключения);
	
	Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
		Возврат Ложь;
		
	КонецЕсли;
	ФункцияHTTP = "registration";
	HTTPExchange.DataTransferHTTP(ФункцияHTTP, СтруктураДанных, СоединениеHTTP, ПараметрыПодключения);
	Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
		Возврат Ложь;
		
	КонецЕсли;
	
	Если НЕ Константы.ID.Получить() = СтруктураДанных.ИнформацияОбУстройстве["ID"] Тогда
		Константы.ID.Установить(СтруктураДанных.ИнформацияОбУстройстве["ID"]);
		
	КонецЕсли;
	УИДУзелОбменаОстатков = СтруктураДанных.ПланОбменаОстатки.УИДУзелОбменаОстатков;
	
	Если НЕ Константы.УИДУзелОбменаОстатков.Получить() = УИДУзелОбменаОстатков Тогда
		Константы.УИДУзелОбменаОстатков.Установить(УИДУзелОбменаОстатков);
		
	КонецЕсли;
	
	ПланыОбмена.мп_ОбменМобильноеПриложениеТОИР.ИнициализацияПланаОбмена(СтруктураДанных);

	Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
		Возврат Ложь;
		
	КонецЕсли;
	
	ПрочитатьПакетСервер(СтруктураДанных, ФункцияHTTP);
	Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
		Возврат Ложь;
		
	КонецЕсли;
	
	Если НЕ Справочники.Пользователи.ЕстьПользователиВБазе() Тогда
		HTTPCore.ЗаписатьОшибкуВЖурналСтрокой(
			"ОбменСервер.Регистрация", "Не смог загрузить пользователей. Повторите процедуру регистрации.");
		Возврат Ложь;
		
	КонецЕсли;
	
	Константы.ДатаПоследнейСинхронизации.Установить(ТекущаяДатаСеанса());
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область Синхронизация

Функция Синхронизация(ГруппаСкладов = Неопределено) Экспорт

	СтруктураДанных = HTTPCore.ПолучитьСтруктуруОбрабатываемыхДанных();

	ПараметрыПодключения = HTTPExchange.ПолучитьПараметрыСоединения();
	
	Если ПараметрыПодключения = Неопределено Тогда
		HTTPCore.ЗаписатьМобильнуюОшибку("Синхронизация | Не заполнены параметры подключения.", СтруктураДанных);
	КонецЕсли;
	РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
	ТекущийПользователь = РеквизитыКонстант["ТекущийПользователь"];
	ПланыОбмена.мп_ОбменМобильноеПриложениеТОИР.ДанныеПланаОбмена(СтруктураДанных);
	СтруктураДанных.ИнформацияОбустройстве = ОбщегоНазначенияСервер.ПолучитьИнформациюОбУстройстве();
	СтруктураДанных.БазаЕРП = XmlСтрока(Константы.БазаЕРП.Получить());
	СтруктураДанных.ПараметрыСинхронизации = ОбщегоНазначенияСервер.ПараметрыСинхронизации();
	СтруктураДанных.ПользователиМП = Справочники.Пользователи.АктуальныеПользователиМП();
	СтруктураДанных.ДанныеПользователя = Справочники.Пользователи.ДанныеПользователя();
	
	СоединениеHTTP = HTTPExchange.ПолучитьСоединениеHTTP(СтруктураДанных, ПараметрыПодключения);
	Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
		Возврат Ложь;
		
	КонецЕсли;
	
	Результат = ОтправитьДанныеНаСервер(СтруктураДанных, СоединениеHTTP, ПараметрыПодключения);
	
	Константы.ДатаПоследнейСинхронизации.Установить(ТекущаяДатаСеанса());
	Константы.ОшибкаСинхронизацииДокументов.Установить(Не Результат);
	
	Возврат Результат;
	
КонецФункции

