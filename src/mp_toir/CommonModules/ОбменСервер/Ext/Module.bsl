#Область СлужебныеПроцедурыИФункции

Функция РеквизитСправочникаПоУИД(Знач ИмяСправочника, Знач ЗначениеРеквизита)

	Элемент = Справочники[ИмяСправочника].ПолучитьСсылку(
		Новый УникальныйИдентификатор(ЗначениеРеквизита));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Элемент);
	Если Не СсылкаСуществует Тогда
		Элемент = Справочники[ИмяСправочника].ПустаяСсылка();
	КонецЕсли;
	Возврат Элемент;

КонецФункции

Функция РеквизитДокументаПоУИД(Знач ИмяДокумента, Знач ЗначениеРеквизита)

	Элемент = Документы[ИмяДокумента].ПолучитьСсылку(
		Новый УникальныйИдентификатор(ЗначениеРеквизита));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Элемент);
	Если Не СсылкаСуществует Тогда
		Элемент = Документы[ИмяДокумента].ПустаяСсылка();
	КонецЕсли;
	Возврат Элемент;

КонецФункции

Функция ТаблицаЗначенийИзДвоичныхДанных(ОбъектXDTO, ИмяЭлемента)
	ДвоичныеДанные = Base64Значение(ОбъектXDTO[ИмяЭлемента]);
	РезультатСтрBase64 = ПолучитьСтрокуИзДвоичныхДанных(ДвоичныеДанные,"UTF-8");
	РезультатХранилище = XMLЗначение(Тип("ХранилищеЗначения"), РезультатСтрBase64);
	ТЗРезультат = РезультатХранилище.Получить();
	Возврат ТЗРезультат;
	
КонецФункции

Функция ОтправитьДанныеНаСервер(СтруктураДанных, СоединениеHTTP, ПараметрыПодключения)
	
	ВыгрузкаПрошлаБезОшибок = Истина;
	
	РезультатНаработкиЭксплуатации = Документы.НаработкаОбъектовЭксплуатации.ВыбратьИзменения();
	ОтправитьДанныеНаСерверОбработкаРезультатов(
		СтруктураДанных, СоединениеHTTP, ПараметрыПодключения, ВыгрузкаПрошлаБезОшибок, РезультатНаработкиЭксплуатации);
		
	РезультатРегистрацияПроверокОборудования = Документы.мп_РегистрацияПроверокОборудования.ВыбратьИзменения();
	ОтправитьДанныеНаСерверОбработкаРезультатов(
		СтруктураДанных, СоединениеHTTP, ПараметрыПодключения, ВыгрузкаПрошлаБезОшибок, РезультатРегистрацияПроверокОборудования);
		
	РегистрацияДефекта = Документы.РегистрацияДефекта.ВыбратьИзменения();
	ОтправитьДанныеНаСерверОбработкаРезультатов(
		СтруктураДанных, СоединениеHTTP, ПараметрыПодключения, ВыгрузкаПрошлаБезОшибок, РегистрацияДефекта);
		
	ЗаданиеНаРемонт = Документы.мп_ЗаданиеНаРемонт.ВыбратьИзменения();
	ОтправитьДанныеНаСерверОбработкаРезультатов(
		СтруктураДанных, СоединениеHTTP, ПараметрыПодключения, ВыгрузкаПрошлаБезОшибок, ЗаданиеНаРемонт);
		
	НарядНаРемонт = Документы.мп_НарядНаРемонт.ВыбратьИзменения();
	ОтправитьДанныеНаСерверОбработкаРезультатов(
		СтруктураДанных, СоединениеHTTP, ПараметрыПодключения, ВыгрузкаПрошлаБезОшибок, НарядНаРемонт);
	
	Если ВыгрузкаПрошлаБезОшибок Тогда
		HTTPCore.ОчиститьСодержимоеПакетов(СтруктураДанных);
		
		ЗаписатьПакетКлиент(СтруктураДанных);
		Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
			ВыгрузкаПрошлаБезОшибок = Ложь;
			Возврат ВыгрузкаПрошлаБезОшибок;
		КонецЕсли;
		ФункцияHTTP = "dataformobile";
		HTTPExchange.DataTransferHTTP(ФункцияHTTP, СтруктураДанных, СоединениеHTTP, ПараметрыПодключения);
		Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
			HTTPCore.ЗаписатьОшибкиВЖурнал(СтруктураДанных);
			ВыгрузкаПрошлаБезОшибок = Ложь;
		КонецЕсли;
		
		Если СтруктураДанных.КодОтветаHTTP = 200 Тогда
 			ПрочитатьПакетСервер(СтруктураДанных, ФункцияHTTP);
		КонецЕсли;
		
	КонецЕсли;

	Возврат ВыгрузкаПрошлаБезОшибок;

КонецФункции

Процедура ОтправитьДанныеНаСерверОбработкаРезультатовПачкой(
		СтруктураДанных,
		Знач СоединениеHTTP,
		Знач ПараметрыПодключения,
		ВыгрузкаПрошлаБезОшибок,
		РезультатЗапроса,
		ОтветДляКИС = Ложь)
		
		Если РезультатЗапроса.Пустой() Тогда
			Возврат;
		КонецЕсли;
		ОбъектыОтвета = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
		HTTPCore.ОчиститьСодержимоеПакетов(СтруктураДанных);
			
		ЗаписатьПакетКлиентПачкой(СтруктураДанных, ОбъектыОтвета, ОтветДляКИС);
		Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
			ВыгрузкаПрошлаБезОшибок = Ложь;
			Возврат;
		КонецЕсли;
		ФункцияHTTP = "synchronization";
		HTTPExchange.DataTransferHTTP(ФункцияHTTP, СтруктураДанных, СоединениеHTTP, ПараметрыПодключения);
		Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
			HTTPCore.ЗаписатьОшибкиВЖурнал(СтруктураДанных);
			ВыгрузкаПрошлаБезОшибок = Ложь;
			
		КонецЕсли;
			
		Если СтруктураДанных.КодОтветаHTTP = 200 Тогда
			
			УзелОбмена = ОбщегоНазначенияПовтИсп.ПолучитьУзелЦентральнойБазы();
			ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ОбъектыОтвета);
			
			ПрочитатьПакетСервер(СтруктураДанных, ФункцияHTTP);
			
		КонецЕсли;

		Если ВыгрузкаПрошлаБезОшибок Тогда
			Попытка
				ЭтотУзел = ПланыОбмена.мп_ОбменМобильноеПриложениеТОИР.ЭтотУзел();
				УзелОбъект = ЭтотУзел.ПолучитьОбъект();
				УзелОбъект.ДатаВремяПоследнегоОбмена = ТекущаяДатаСеанса();
				УзелОбъект.Записать();
			Исключение
				
			КонецПопытки;
		КонецЕсли;

КонецПроцедуры

Процедура ОтправитьДанныеНаСерверОбработкаРезультатов(
		СтруктураДанных,
		Знач СоединениеHTTP,
		Знач ПараметрыПодключения,
		ВыгрузкаПрошлаБезОшибок,
		РезультатЗапроса)
	
	Если РезультатЗапроса.Пустой() Тогда
		
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			HTTPCore.ОчиститьСодержимоеПакетов(СтруктураДанных);
			
			ЗаписатьПакетКлиент(СтруктураДанных, Выборка.Ссылка);
			Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
				ВыгрузкаПрошлаБезОшибок = Ложь;
				Продолжить;
				
			КонецЕсли;
			ФункцияHTTP = "synchronization";
			HTTPExchange.DataTransferHTTP(ФункцияHTTP, СтруктураДанных, СоединениеHTTP, ПараметрыПодключения);
			Если HTTPCore.ЕстьОшибка(СтруктураДанных) Тогда
				HTTPCore.ЗаписатьОшибкиВЖурнал(СтруктураДанных);
				ВыгрузкаПрошлаБезОшибок = Ложь;
				
			КонецЕсли;
			
			Если СтруктураДанных.КодОтветаHTTP = 200 Тогда
		//		ПрочитатьПакетСервер(СтруктураДанных, ФункцияHTTP);
			КонецЕсли;
			
		КонецЦикла;
		
		Если ВыгрузкаПрошлаБезОшибок Тогда
			ВыгруженВКИС = Перечисления.мп_СтатусыОбмена.ВыгруженВКИС;
			Попытка
				УзелОбмена = ОбщегоНазначенияПовтИсп.ПолучитьУзелЦентральнойБазы();
				ВыгруженныеДокументы = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
				
				Для Каждого ВыгруженныйДокумент Из ВыгруженныеДокументы Цикл
					ДокументОбъект = ВыгруженныйДокумент.ПолучитьОбъект();
					ТипДокумента = ТипЗнч(ДокументОбъект);
					Если ТипДокумента = Тип("ДокументОбъект.НаработкаОбъектовЭксплуатации") Тогда
						ДокументОбъект.мп_СтатусОбмена = ВыгруженВКИС;
					ИначеЕсли ТипДокумента = Тип("ДокументОбъект.мп_РегистрацияПроверокОборудования") Тогда
						ДокументОбъект.СтатусОбмена = ВыгруженВКИС;
					ИначеЕсли ТипДокумента = Тип("ДокументОбъект.РегистрацияДефекта") Тогда
						ДокументОбъект.СтатусОбмена = ВыгруженВКИС;
					ИначеЕсли ТипДокумента = Тип("ДокументОбъект.мп_ЗаданиеНаРемонт") Тогда
						ДокументОбъект.СтатусОбмена = ВыгруженВКИС;
					ИначеЕсли ТипДокумента = Тип("ДокументОбъект.мп_НарядНаРемонт") Тогда
						ДокументОбъект.СтатусОбмена = ВыгруженВКИС;
					КонецЕсли;
					ДокументОбъект.ОбменДанными.Загрузка = Истина;
					ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
				КонецЦикла;
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ВыгруженныеДокументы);
				УзелОбмена = УзелОбмена.ПолучитьОбъект();
				УзелОбмена.ДатаВремяПоследнегоОбмена = ТекущаяДатаСеанса();
				УзелОбмена.Записать();
			Исключение
				
			КонецПопытки;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры


#Область ЧтениеЗаписьПакетов

Процедура ЗаписатьНастройкиВидовНаоменклатуры(ТаблицаНастроекВидыНоменклатуры)

	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("ТаблицаНастроекВидыНоменклатуры", ТаблицаНастроекВидыНоменклатуры);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаНастроекВидыНоменклатуры.ВидНоменклатуры КАК ВидНоменклатуры,
	|	ТаблицаНастроекВидыНоменклатуры.КодНастройки КАК КодНастройки,
	|	ТаблицаНастроекВидыНоменклатуры.УИДНастройки КАК УИДНастройки,
	|	ТаблицаНастроекВидыНоменклатуры.ВерсияДанныхЕРП КАК ВерсияДанныхЕРП
	|ПОМЕСТИТЬ вт_таблица
	|ИЗ
	|	&ТаблицаНастроекВидыНоменклатуры КАК ТаблицаНастроекВидыНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_таблица.КодНастройки КАК Код,
	|	вт_таблица.КодНастройки КАК Наименование,
	|	вт_таблица.УИДНастройки КАК УИДНастройки,
	|	вт_таблица.ВерсияДанныхЕРП КАК ВерсияДанныхЕРП
	|ИЗ
	|	вт_таблица КАК вт_таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_таблица.ВидНоменклатуры КАК ВидНоменклатуры,
	|	вт_таблица.КодНастройки КАК Код,
	|	вт_таблица.КодНастройки КАК Наименование,
	|	вт_таблица.УИДНастройки КАК УИДНастройки,
	|	вт_таблица.ВерсияДанныхЕРП КАК ВерсияДанныхЕРП
	|ИЗ
	|	вт_таблица КАК вт_таблица";

	ПакетРезультатов = Запрос.ВыполнитьПакет();

	ИндексПоследнегоПакета = ПакетРезультатов.ВГраница();
	
	РезультатЗапросаТаблица = ПакетРезультатов[ИндексПоследнегоПакета];
	ВыборкаТаблица = РезультатЗапросаТаблица.Выбрать();
	
	РезультатКоды = ПакетРезультатов[ИндексПоследнегоПакета - 1];
	Выборка = РезультатКоды.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СсылкаНастройки = Справочники.ОбщиеНастройки.НайтиПоКоду(Выборка.Код);
		Если ЗначениеЗаполнено(СсылкаНастройки) Тогда
			Если СсылкаНастройки.ВерсияДанныхЕРП = Выборка.ВерсияДанныхЕРП Тогда
				Продолжить;
			КонецЕсли;

			НастройкиОбъект = СсылкаНастройки.ПолучитьОбъект();
		Иначе
			НастройкиОбъект = Справочники.ОбщиеНастройки.СоздатьЭлемент();
		КонецЕсли;
		
		ОтборПоКодам = Новый Структура;
		ОтборПоКодам.Вставить("Код", Выборка.Код);
		ОтборПоКодам.Вставить("УИДНастройки", Выборка.УИДНастройки);
		ОтборПоКодам.Вставить("ВерсияДанныхЕРП", Выборка.ВерсияДанныхЕРП);
		СписокВидовНоменклатуры = Новый СписокЗначений;
		ВыборкаТаблица.Сбросить();
		Пока ВыборкаТаблица.НайтиСледующий(ОтборПоКодам) Цикл
			СписокВидовНоменклатуры.Добавить(ВыборкаТаблица.ВидНоменклатуры);
		КонецЦикла;
		
		ЗаполнитьЗначенияСвойств(НастройкиОбъект, Выборка);
		НастройкиОбъект.ЭтоСписокЗначений = Истина;
		НастройкиОбъект.Значение = Новый ХранилищеЗначения(СписокВидовНоменклатуры);
		НастройкиОбъект.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьНаработкуОЭ(ТаблицаНаработок)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗНаработка.ОбъектЭксплуатации КАК ОбъектЭксплуатации,
	|	ТЗНаработка.Наработка КАК Наработка,
	|	ТЗНаработка.Значение КАК Значение
	|ПОМЕСТИТЬ вт_ТаблицаНаработок
	|ИЗ
	|	&ТаблицаНаработок КАК ТЗНаработка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыЭксплуатации.Ссылка КАК ОбъектЭксплуатации,
	|	ЕСТЬNULL(вт_ТаблицаНаработок.Наработка, ЗНАЧЕНИЕ(Справочник.ПоказателиНаработки.ПустаяСсылка)) КАК Наработка,
	|	ЕСТЬNULL(вт_ТаблицаНаработок.Значение, 0) КАК Значение
	|ИЗ
	|	Справочник.ОбъектыЭксплуатации КАК ОбъектыЭксплуатации
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ТаблицаНаработок КАК вт_ТаблицаНаработок
	|		ПО (ОбъектыЭксплуатации.Ссылка = вт_ТаблицаНаработок.ОбъектЭксплуатации)
	|ИТОГИ ПО
	|	ОбъектЭксплуатации";

	Запрос.УстановитьПараметр("ТаблицаНаработок", ТаблицаНаработок);
	РезультатЗапроса = Запрос.Выполнить();
	НаработкаНаДату = ТекущаяДатаСеанса();
	ВыборкаОбъектЭксплуатации = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаОбъектЭксплуатации.Следующий() Цикл
		СпрОЭ = ВыборкаОбъектЭксплуатации.ОбъектЭксплуатации.ПолучитьОбъект();
		Наработки = СпрОЭ.Наработки.Выгрузить();
		Наработки.Очистить();
		
		ВыборкаНаработка = ВыборкаОбъектЭксплуатации.Выбрать();
		
		Пока ВыборкаНаработка.Следующий() Цикл
			Если Не ЗначениеЗаполнено(ВыборкаНаработка.Наработка) Тогда
				Продолжить;
			КонецЕсли;
			НоваяСтрока = Наработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаНаработка, "Наработка,Значение");
			НоваяСтрока.НаработкаНаДату = НаработкаНаДату;
		КонецЦикла;
		СпрОЭ.Наработки.Загрузить(Наработки);
		СпрОЭ.ОбменДанными.Загрузка = Истина;
		СпрОЭ.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьНаработкуКлассОбъекта(ТаблицаНаработок)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗНаработка.Класс КАК Класс,
	|	ТЗНаработка.Наработка КАК Наработка
	|ПОМЕСТИТЬ вт_ТаблицаНаработок
	|ИЗ
	|	&ТаблицаНаработок КАК ТЗНаработка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлассыОбъектовЭксплуатации.Ссылка КАК Класс,
	|	ЕСТЬNULL(вт_ТаблицаНаработок.Наработка, ЗНАЧЕНИЕ(Справочник.ПоказателиНаработки.ПустаяСсылка)) КАК ПоказательНаработки
	|ИЗ
	|	Справочник.КлассыОбъектовЭксплуатации КАК КлассыОбъектовЭксплуатации
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ТаблицаНаработок КАК вт_ТаблицаНаработок
	|		ПО (КлассыОбъектовЭксплуатации.Ссылка = вт_ТаблицаНаработок.Класс)
	|ИТОГИ ПО
	|	Класс";

	Запрос.УстановитьПараметр("ТаблицаНаработок", ТаблицаНаработок);
	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаКлассОбъекта = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаКлассОбъекта.Следующий() Цикл
		
		Класс = ВыборкаКлассОбъекта.Класс.ПолучитьОбъект();
		ПоказателиНаработки = Класс.ПоказателиНаработки.Выгрузить();
		
		ПоказателиНаработки.Очистить();
		
		ВыборкаНаработка = ВыборкаКлассОбъекта.Выбрать();
		
		Пока ВыборкаНаработка.Следующий() Цикл
			Если Не ЗначениеЗаполнено(ВыборкаНаработка.ПоказательНаработки) Тогда
				Продолжить;
			КонецЕсли;
			НоваяСтрока = ПоказателиНаработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаНаработка, "ПоказательНаработки");
		КонецЦикла;
		
		Класс.ПоказателиНаработки.Загрузить(ПоказателиНаработки);
		Класс.ОбменДанными.Загрузка = Истина;
		Класс.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьВидыПроверокКласса(ТаблицаВидыПроверок)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаВидыПроверок.Класс КАК Класс,
	|	ТаблицаВидыПроверок.ВидПроверокОборудования КАК ВидПроверокОборудования
	|ПОМЕСТИТЬ вт_ТаблицаВидыПроверок
	|ИЗ
	|	&ТаблицаВидыПроверок КАК ТаблицаВидыПроверок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлассыОбъектовЭксплуатации.Ссылка КАК Класс,
	|	ЕСТЬNULL(вт_ТаблицаВидыПроверок.ВидПроверокОборудования, ЗНАЧЕНИЕ(Справочник.мп_ВидыПроверокОборудования.ПустаяСсылка)) КАК ВидПроверокОборудования
	|ИЗ
	|	Справочник.КлассыОбъектовЭксплуатации КАК КлассыОбъектовЭксплуатации
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ТаблицаВидыПроверок КАК вт_ТаблицаВидыПроверок
	|		ПО (КлассыОбъектовЭксплуатации.Ссылка = вт_ТаблицаВидыПроверок.Класс)
	|ИТОГИ ПО
	|	Класс";

	Запрос.УстановитьПараметр("ТаблицаВидыПроверок", ТаблицаВидыПроверок);
	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаКлассОбъекта = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаКлассОбъекта.Следующий() Цикл
		
		Класс = ВыборкаКлассОбъекта.Класс.ПолучитьОбъект();
		мп_ВидыПроверок = Класс.мп_ВидыПроверок.Выгрузить();
		
		мп_ВидыПроверок.Очистить();
		
		ВыборкаВидПроверки = ВыборкаКлассОбъекта.Выбрать();
		
		Пока ВыборкаВидПроверки.Следующий() Цикл
			Если Не ЗначениеЗаполнено(ВыборкаВидПроверки.ВидПроверокОборудования) Тогда
				Продолжить;
			КонецЕсли;
			НоваяСтрока = мп_ВидыПроверок.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаВидПроверки, "ВидПроверокОборудования");
		КонецЦикла;
		
		Класс.мп_ВидыПроверок.Загрузить(мп_ВидыПроверок);
		Класс.ОбменДанными.Загрузка = Истина;
		Класс.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

Функция  КоллекцияXDTO(Элемент)
	Если ТипЗнч(Элемент)=Тип("ОбъектXDTO") Тогда
	МассивXDTO=Новый Массив;
	МассивXDTO.Добавить(Элемент);
		Возврат МассивXDTO;
	КонецЕсли;
	Возврат Элемент;
КонецФункции

Процедура ПрочитатьПакетСервер(СтруктураДанных, ФункцияHTTP) Экспорт
	
	Если СтруктураДанных.ПакетСервер = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТаблицаНаработок = Новый ТаблицаЗначений;
	ТаблицаНаработок.Колонки.Добавить("ОбъектЭксплуатации",
		Новый ОписаниеТипов("СправочникСсылка.ОбъектыЭксплуатации"));
	ТаблицаНаработок.Колонки.Добавить("Наработка", Новый ОписаниеТипов("СправочникСсылка.ПоказателиНаработки"));
	ТаблицаНаработок.Колонки.Добавить("Значение", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	
	ТаблицаНаработокКлассОбъекта = Новый ТаблицаЗначений;
	ТаблицаНаработокКлассОбъекта.Колонки.Добавить("Класс",
		Новый ОписаниеТипов("СправочникСсылка.КлассыОбъектовЭксплуатации"));
	ТаблицаНаработокКлассОбъекта.Колонки.Добавить("Наработка",
		Новый ОписаниеТипов("СправочникСсылка.ПоказателиНаработки"));
	
	ТаблицаВидыПроверокКласса = Новый ТаблицаЗначений;
	ТаблицаВидыПроверокКласса.Колонки.Добавить("Класс",
		Новый ОписаниеТипов("СправочникСсылка.КлассыОбъектовЭксплуатации"));
	ТаблицаВидыПроверокКласса.Колонки.Добавить(
		"ВидПроверокОборудования", Новый ОписаниеТипов("СправочникСсылка.мп_ВидыПроверокОборудования"));
	
	ТаблицаНастроекВидыНоменклатуры = Новый ТаблицаЗначений;
	ТаблицаНастроекВидыНоменклатуры.Колонки.Добавить(
		"ВидНоменклатуры", Новый ОписаниеТипов("СправочникСсылка.ВидыНоменклатуры"));
	ТаблицаНастроекВидыНоменклатуры.Колонки.Добавить(
		"КодНастройки", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	ТаблицаНастроекВидыНоменклатуры.Колонки.Добавить(
		"УИДНастройки", ОбщегоНазначения.ОписаниеТипаСтрока(36));
	ТаблицаНастроекВидыНоменклатуры.Колонки.Добавить(
		"ВерсияДанныхЕРП", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	
	ОстаткиПоНоменклатуре  = Неопределено;
	
	ТекущийУзел = ПланыОбмена.мп_ОбменМобильноеПриложениеТОИР.ЭтотУзел();
	
	ПакетСервер = СтруктураДанных.ПакетСервер;
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ПакетСервер);
	
	Если ФункцияHTTP = "updatecatalogs" Тогда
		ОстаткиПоНоменклатуре = РегистрыСведений.ОстаткиПоНоменклатуре.СоздатьНаборЗаписей();
		ОстаткиПоНоменклатуре.Записать(Истина);

		ТоварыДругогоКачества = РегистрыСведений.ТоварыДругогоКачества.СоздатьНаборЗаписей();
		ТоварыДругогоКачества.Записать(Истина);
		Фабрика=Новый ФабрикаXDTO;
		ОбXDTO=Фабрика.ПрочитатьXML(ЧтениеXML);

		СвойстваОбъекта = ОбXDTO.Body.Свойства();

		Если Не СвойстваОбъекта.Получить("CatalogObject_ВидыНоменклатуры") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_ВидыНоменклатуры) Цикл
				ЗаписатьВидыНоменклатуры(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_СерииНоменклатуры") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_СерииНоменклатуры) Цикл
				ЗаписатьСерииНоменклатуры(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_УпаковкиЕдиницыИзмерения") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_УпаковкиЕдиницыИзмерения) Цикл
				ЗаписатьЕдиницыИзмерения(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_Номенклатура") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_Номенклатура) Цикл
				ЗаписатьНоменклатуру(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_ХарактеристикиНоменклатуры") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_ХарактеристикиНоменклатуры) Цикл
				ЗаписатьХарактеристикиНоменклатуры(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_Назначения") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_Назначения) Цикл
				ЗаписатьНазначения(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("Constants_ERP") = Неопределено Тогда
			СвойстваКонстант = ОбXDTO.Body.Constants_ERP.Свойства();
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.Constants_ERP) Цикл
				ИмяКонстанты = "ВидыНоменклатурыИсклИзАнализаПоИндНомерамВРН";
				Если Не СвойстваКонстант.Получить(ИмяКонстанты) = Неопределено Тогда
					ЗначениеКонстанты = ?(Объект.Получить(ИмяКонстанты) = "true", Истина, Ложь);
					Константы.ВидыНоменклатурыИсклИзАнализаПоИндНомерамВРН.Установить(ЗначениеКонстанты);
					
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("InformationRegisters_ОстаткиПоНоменклатуре") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.InformationRegisters_ОстаткиПоНоменклатуре) Цикл
				ЗаписатьОстаткиПоНоменклатуре(Объект, СтруктураДанных, ОстаткиПоНоменклатуре);
			КонецЦикла;
		КонецЕсли;

		// ТоварыДругогоКачества
		Если Не СвойстваОбъекта.Получить("InformationRegisters_ТоварыДругогоКачества") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.InformationRegisters_ТоварыДругогоКачества) Цикл
				ЗаписатьТоварыДругогоКачества(Объект, СтруктураДанных, ТоварыДругогоКачества);
			КонецЦикла;
		КонецЕсли;

		Если Не ОстаткиПоНоменклатуре = Неопределено Тогда
			ОстаткиПоНоменклатуре.Записать(Истина);
		КонецЕсли;

		Если Не ТоварыДругогоКачества = Неопределено Тогда
			ТоварыДругогоКачества.Записать(Истина);
		КонецЕсли;
		

		Возврат;
		
	ИначеЕсли  ФункцияHTTP = "updateinformationregisters" Тогда
		Период = ТекущаяДатаСеанса();
		Фабрика=Новый ФабрикаXDTO;
		ОбXDTO=Фабрика.ПрочитатьXML(ЧтениеXML);
		СвойстваОбъекта = ОбXDTO.Body.Свойства();
		Если Не СвойстваОбъекта.Получить("CatalogObject_ОбъектыЭксплуатации") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_ОбъектыЭксплуатации) Цикл
				ЗаписатьОбъектыЭксплуатации(Объект, СтруктураДанных);
			КонецЦикла
			
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_УзлыОбъектовЭксплуатации") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_УзлыОбъектовЭксплуатации) Цикл
				ЗаписатьУзелОбъектовЭксплуатации(Объект, СтруктураДанных);
			КонецЦикла
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_Номенклатура") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_Номенклатура) Цикл
				ЗаписатьНоменклатуру(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_ХарактеристикиНоменклатуры") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_ХарактеристикиНоменклатуры) Цикл
				ЗаписатьХарактеристикиНоменклатуры(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;
		
		Если Не СвойстваОбъекта.Получить("CatalogObject_СерииНоменклатуры") = Неопределено Тогда
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.CatalogObject_СерииНоменклатуры) Цикл
				ЗаписатьСерииНоменклатуры(Объект, СтруктураДанных);
			КонецЦикла;
		КонецЕсли;

		Если Не СвойстваОбъекта.Получить("InformationRegisters_Мечел_ТМЦВЭксплуатацииСписанныеНаРасходы") = Неопределено Тогда
			НаборТМЦ = РегистрыСведений.Мечел_ТМЦВЭксплуатацииСписанныеНаРасходы.СоздатьНаборЗаписей();
			НаборТМЦ.Записать(Истина);
			Для Каждого Объект Из КоллекцияXDTO(ОбXDTO.Body.InformationRegisters_Мечел_ТМЦВЭксплуатацииСписанныеНаРасходы) Цикл
				ЗаписатьНаборТМЦ(Объект, СтруктураДанных, НаборТМЦ, Период);
			КонецЦикла;
			НаборТМЦ.Записать(Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	ОбновлялиРегистрацияДефекта = Ложь;
	Попытка
		
		ЧтениеСообщение = ПланыОбмена.СоздатьЧтениеСообщения();
		ЧтениеСообщение.НачатьЧтение(ЧтениеXML);
		Пока 
			ВозможностьЧтенияXML(ЧтениеXML)
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.Мечел_ДефектыОборудования"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.Мечел_ТехнологическиеМеста"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.ПоказателиНаработки"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.КлассыОбъектовЭксплуатации"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.ОбъектыЭксплуатации"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.НаработкиОбъектовЭксплуатации"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.УзлыОбъектовЭксплуатации"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.Склады"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.ВидыДефектов"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.Мечел_ПричиныСостоянияОборудования"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.Мечел_ВидыСостоянияОборудования"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.Мечел_ПричиныОтменыРемонтов"

			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.ТехнологическиеОперации"

			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.Организации"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.ВидыРемонтов"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.ФизическиеЛица"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "DocumentObject.НаработкаОбъектовЭксплуатации"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "DocumentObject.мп_РегистрацияПроверокОборудования"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "DocumentObject.РегистрацияДефекта"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "DocumentObject.мп_ЗаданиеНаРемонт"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "DocumentObject.мп_НарядНаРемонт"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.НаработкиКлассов"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.мп_ВидыПроверокКлассов"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.мп_ВидыПроверокОборудования"
			
			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.ЗаписатьОбщиеВидыРемонтов"

			ИЛИ ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
			И ЧтениеXML.Имя = "CatalogObject.СтруктураПредприятия" Цикл
			
			Если ЧтениеXML.Имя = "CatalogObject.СтруктураПредприятия" Тогда
				ЗаписатьСтруктураПредприятия(ЧтениеXML, СтруктураДанных);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Склады" Тогда
				ЗаписатьСкладСИерархией(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ВидыДефектов" Тогда
				ЗаписатьВидыДефектов(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Мечел_ПричиныСостоянияОборудования" Тогда
				ЗаписатьПричиныСостоянияОборудования(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Мечел_ВидыСостоянияОборудования" Тогда
				ЗаписатьВидыСостоянияОборудования(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Мечел_ПричиныОтменыРемонтов" Тогда
				ЗаписатьПричиныОтменыРемонтов(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ТехнологическиеОперации" Тогда
				ЗаписатьТехнологическиеОперации(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Мечел_ДефектыОборудования" Тогда
				ЗаписатьДефектыОборудования(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ПоказателиНаработки" Тогда
				ЗаписатьПоказателиНаработки(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.КлассыОбъектовЭксплуатации" Тогда
				ЗаписатьКлассыОбъектовЭксплуатации(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.НаработкиКлассов" Тогда
				ЗаписатьНаработкуКлассов(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель, ТаблицаНаработокКлассОбъекта);

			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.мп_ВидыПроверокКлассов" Тогда
				ЗаписатьВидыПроверокКлассов(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель, ТаблицаВидыПроверокКласса);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.мп_ВидыПроверокОборудования" Тогда
				ЗаписатьВидыПроверокОборудования(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ОбщиеВидыРемонтов" Тогда
				ЗаписатьОбщиеВидыРемонтов(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ВидыРемонтов" Тогда
				ЗаписатьВидыРемонтов(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ОбъектыЭксплуатации" Тогда
				ЗаписатьОбъектыЭксплуатации(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.НаработкиОбъектовЭксплуатации" Тогда
				ЗаписатьНаработкуОбъектовЭксплуатации(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель, ТаблицаНаработок);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.УзлыОбъектовЭксплуатации" Тогда
				ЗаписатьУзелОбъектовЭксплуатации(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
			
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Мечел_ТехнологическиеМеста" Тогда
				ЗаписатьТехнологическиеМеста(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);

			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Организации" Тогда
				ЗаписатьОрганизацию(ЧтениеXML, СтруктураДанных);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.Пользователи" Тогда
				ЗаписатьПользователей(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ФизическиеЛица" Тогда
				ЗаписатьФизическихЛиц(ЧтениеXML, СтруктураДанных);

			ИначеЕсли ЧтениеXML.Имя = "DocumentObject.НаработкаОбъектовЭксплуатации" Тогда
				Если ФункцияHTTP = "synchronization" Тогда
					ОбновитьНаработкуОбъектаЭксплуатации(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				КонецЕсли;
				
			ИначеЕсли ЧтениеXML.Имя = "DocumentObject.мп_РегистрацияПроверокОборудования" Тогда
				Если ФункцияHTTP = "synchronization" Тогда
					ОбновитьРегистрациюПроверокОборудования(ЧтениеXML, СтруктураДанных, ЧтениеСообщение.Отправитель);
				КонецЕсли;
			ИначеЕсли ЧтениеXML.Имя = "CatalogObject.ВидыНоменклатуры" Тогда
				Если ФункцияHTTP = "dataformobile" Тогда
					ЗаписатьВидыНоменклатуры(ЧтениеXML, СтруктураДанных, ТаблицаНастроекВидыНоменклатуры);
				КонецЕсли;
			ИначеЕсли ЧтениеXML.Имя = "DocumentObject.РегистрацияДефекта" Тогда
				Если ФункцияHTTP = "dataformobile" Тогда
					ОбновитьРегистрациюДефекта(ЧтениеXML, СтруктураДанных);
					ОбновлялиРегистрацияДефекта = Истина;
				КонецЕсли;
			ИначеЕсли ЧтениеXML.Имя = "DocumentObject.мп_ЗаданиеНаРемонт" Тогда
				Если ФункцияHTTP = "dataformobile" Тогда
					ЗаписатьДокументЗаданиеНаРемонт(ЧтениеXML, СтруктураДанных);
				КонецЕсли;
			ИначеЕсли ЧтениеXML.Имя = "DocumentObject.мп_НарядНаРемонт" Тогда
				Если ФункцияHTTP = "dataformobile" Тогда
					ЗаписатьДокументНарядНаРемонт(ЧтениеXML, СтруктураДанных);
				КонецЕсли;
			Иначе
				Данные = ПрочитатьXML(ЧтениеXML);
				Если НЕ Данные = Неопределено Тогда
					Данные.ОбменДанными.Загрузка = Истина;
					Данные.ОбменДанными.Отправитель = ЧтениеСообщение.Отправитель;
					Данные.Записать();
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если ТаблицаНастроекВидыНоменклатуры.Количество() > 0 Тогда
			ЗаписатьНастройкиВидовНаоменклатуры(ТаблицаНастроекВидыНоменклатуры);
		КонецЕсли;
		Если ТаблицаНаработок.Количество() > 0 Тогда
			ЗаписатьНаработкуОЭ(ТаблицаНаработок);
		КонецЕсли;
		
		Если ТаблицаНаработокКлассОбъекта.Количество() > 0 Тогда
			ЗаписатьНаработкуКлассОбъекта(ТаблицаНаработокКлассОбъекта);
		КонецЕсли;
		
		Если ТаблицаВидыПроверокКласса.Количество() > 0 Тогда
			ЗаписатьВидыПроверокКласса(ТаблицаВидыПроверокКласса);
		КонецЕсли;

		ПланыОбмена.УдалитьРегистрациюИзменений(ЧтениеСообщение.Отправитель, ЧтениеСообщение.НомерПринятого);

		ЧтениеСообщение.ЗакончитьЧтение();
		
		Если ОбновлялиРегистрацияДефекта Тогда
			ПараметрыПодключения = HTTPExchange.ПолучитьПараметрыСоединения();
			СоединениеHTTP = HTTPExchange.ПолучитьСоединениеHTTP(СтруктураДанных, ПараметрыПодключения);
			РегистрацияДефекта = Документы.РегистрацияДефекта.ВыбратьИзменения();
			
				ОтправитьДанныеНаСерверОбработкаРезультатовПачкой(
					СтруктураДанных, СоединениеHTTP, ПараметрыПодключения, Истина, РегистрацияДефекта, Истина);
		КонецЕсли;
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			"ОбменСервер.ПрочитатьПакетСервер | Ошибка чтения пакета с сервера", СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаписатьОрганизацию(ЧтениеXML, СтруктураДанных)

	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НоваяСсылка = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаСуществует Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.Организации.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
		
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);

	Попытка
		НовыйЭлемент.Записать();
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.Организации | Ошибка записи элемента Организации %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;

КонецПроцедуры

Процедура ЗаписатьПользователей(ЧтениеXML, СтруктураДанных, Отправитель)

	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НоваяСсылка = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаСуществует Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.Пользователи.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
		
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);
	РолиЕРП = СтрРазделить(ОбъектXDTO.Роли, ",");
	
	РолиПользователя = НовыйЭлемент.Роли.Выгрузить();
	РолиПользователя.Очистить();
	Для Каждого ТекРоль Из РолиЕРП Цикл
		НоваяРоль = РолиПользователя.Добавить();
		НоваяРоль.Роль = ТекРоль;
	КонецЦикла;
	НовыйЭлемент.Роли.Загрузить(РолиПользователя);
	НовыйЭлемент.ИдентификаторПользователяИБ = Новый УникальныйИдентификатор(ОбъектXDTO.ИдентификаторПользователяИБ);
	НовыйЭлемент.Недействителен = ?(ОбъектXDTO.Недействителен = "true", Истина, Ложь);
	НовыйЭлемент.Служебный = ?(ОбъектXDTO.Служебный = "true", Истина, Ложь);
	НовыйЭлемент.DeletionMark = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	
	Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Организация));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Организация);
	
	Если СсылкаСуществует Тогда
		НовыйЭлемент.Организация = Организация;
	КонецЕсли;
	
	Подразделение = Справочники.СтруктураПредприятия.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Подразделение));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Подразделение);
	
	Если СсылкаСуществует Тогда
		НовыйЭлемент.Подразделение = Подразделение;
	КонецЕсли;
	
	Попытка
		НовыйЭлемент.Записать();
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.Организации | Ошибка записи элемента Организации %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;
КонецПроцедуры

