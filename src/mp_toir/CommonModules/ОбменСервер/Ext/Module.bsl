КонецПроцедуры

#КонецОбласти

#Область Документы

// ОбновитьРегистрациюПроверокОборудования
//
// Параметры:
//  ЧтениеXML		 - 	 - 
//  СтруктураДанных	 - 	 - 
//  Отправитель		 - 	 - 
//
Процедура ОбновитьРегистрациюПроверокОборудования(ЧтениеXML, СтруктураДанных, Отправитель)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НоваяСсылка = Документы.мп_РегистрацияПроверокОборудования.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	
	Если Не СсылкаСуществует Тогда
		Возврат;
	КонецЕсли;
	
	СтатусыОбмена = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.мп_СтатусыОбмена Цикл 
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СтатусыОбмена.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	СтатусыОбмена.Вставить("ОбъектXDTO", Перечисления.мп_СтатусыОбмена.ПустаяСсылка());
	
	НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	НовыйЭлемент.СтатусОбмена = СтатусыОбмена[Строка(ОбъектXDTO.СтатусОбмена)];
	
	Попытка
		
		НовыйЭлемент.Записать();
		
	Исключение
	
		HTTPCore.ЗаписатьМобильнуюОшибку(
		СтрШаблон(
		"ОбменСервер.ОбновитьРегистрациюПроверокОборудования | Ошибка записи элемента мп_РегистрацияПроверокОборудования %1",
			ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
	
	КонецПопытки;
	
КонецПроцедуры

Функция СоздатьДокументРегистрацияДефекта(НоваяСсылка, ОбъектXDTO, ОтветственныйЗаУстранение)

	СсылкаНаДокумент = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаНаДокумент Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Документы.РегистрацияДефекта.СоздатьДокумент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;

	НовыйЭлемент.ВерсияДанныхЕРП = ОбъектXDTO.ВерсияДанныхЕРП;
	НовыйЭлемент.Дата = СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.Дата);
	НовыйЭлемент.НомерКИС = ОбъектXDTO.Номер;

	Подразделение = Справочники.СтруктураПредприятия.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Подразделение));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Подразделение);
	Если СсылкаСуществует Тогда
		НовыйЭлемент.Подразделение = Подразделение;
	КонецЕсли;

	 ОбъектЭксплуатации = Справочники.ОбъектыЭксплуатации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.ОбъектЭксплуатации));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ОбъектЭксплуатации);
	Если СсылкаСуществует Тогда
		НовыйЭлемент.ОбъектЭксплуатации = ОбъектЭксплуатации;
	КонецЕсли;
	
	Ответственный = Справочники.Пользователи.ПолучитьСсылку(
	Новый УникальныйИдентификатор(ОбъектXDTO.Ответственный));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Ответственный);
	Если Не СсылкаСуществует Тогда
		Ответственный = Справочники.Пользователи.ПустаяСсылка();
	КонецЕсли;

	Если РольДоступна("мп_БригадирТОиР") Тогда
		Если СсылкаНаДокумент И ОтветственныйЗаУстранение = Справочники.Пользователи.ПустаяСсылка() Тогда
			НовыйЭлемент.Ответственный = Ответственный;
		КонецЕсли;
	Иначе
		НовыйЭлемент.Ответственный = ОтветственныйЗаУстранение;
	КонецЕсли;

	НовыйЭлемент.ОтветственныйЗаУстранение = ОтветственныйЗаУстранение;

	НовыйЭлемент.КраткоеОписаниеДефекта =
		?(Строка(ОбъектXDTO.КраткоеОписаниеДефекта) = "ОбъектXDTO", "", ОбъектXDTO.КраткоеОписаниеДефекта);
	
	НовыйЭлемент.СпособУстранения = ?(ОбъектXDTO.СпособУстранения = "true", Истина, Ложь);
	
	Источник = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.мп_ИсточникиДокументов Цикл 
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		Источник.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	Источник.Вставить("ОбъектXDTO", Перечисления.мп_ИсточникиДокументов.ПустаяСсылка());
	НовыйЭлемент.Источник = Источник[ОбъектXDTO.Источник];

	СтатусыДефектов = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.СтатусыДефектов Цикл
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СтатусыДефектов.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	СтатусыДефектов.Вставить("ОбъектXDTO", Перечисления.СтатусыДефектов.ПустаяСсылка());
	НовыйЭлемент.Статус = СтатусыДефектов[ОбъектXDTO.Статус];
	
	Критичность = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.Мечел_КритичностьДефекта Цикл 
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		Критичность.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	Критичность.Вставить("ОбъектXDTO", Перечисления.мп_СтатусыОбмена.ПустаяСсылка());
	НовыйЭлемент.Критичность = Критичность[Строка(ОбъектXDTO.Критичность)];
	
	НовыйЭлемент.Комментарий = ?(Строка(ОбъектXDTO.Комментарий) = "ОбъектXDTO", "", ОбъектXDTO.Комментарий);

	Организация = Справочники.Организации.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.Организация));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Организация);
	Если СсылкаСуществует Тогда
		НовыйЭлемент.Организация = Организация;
	КонецЕсли;

	ВидДефекта = Справочники.ВидыДефектов.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.ВидДефекта));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ВидДефекта);
	Если СсылкаСуществует Тогда
		НовыйЭлемент.ВидДефекта = ВидДефекта;
	КонецЕсли;

	ДвоичныеДанные = Base64Значение(ОбъектXDTO.ДефектныеУзлы);
	РезультатСтрBase64 = ПолучитьСтрокуИзДвоичныхДанных(ДвоичныеДанные, "UTF-8");
	РезультатХранилище = XMLЗначение(Тип("ХранилищеЗначения"), РезультатСтрBase64);
	ТЗРезультат = РезультатХранилище.Получить();

	Если ТипЗнч(ТЗРезультат) = Тип("ТаблицаЗначений") Тогда
	
		Дефекты = НовыйЭлемент.Дефекты.Выгрузить();
		Дефекты.Очистить();
		Для Каждого ТекСтрока Из ТЗРезультат Цикл
			
			НоваяСтрока = Дефекты.Добавить();
			ЗаполнитьЗначенияСвойств(
				НоваяСтрока, ТекСтрока, "ДефектУстранен,ОписаниеУстранения,ИдентификаторСтроки,ДатаУстранения");
			
			Узел = Справочники.УзлыОбъектовЭксплуатации.ПолучитьСсылку(
				Новый УникальныйИдентификатор(ТекСтрока.Узел));
			СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Узел);
			Если СсылкаСуществует Тогда
				НоваяСтрока.Узел = Узел;
			КонецЕсли;
			
			Дефект = Справочники.Мечел_ДефектыОборудования.ПолучитьСсылку(
				Новый УникальныйИдентификатор(ТекСтрока.Дефект));
			СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Дефект);
			Если СсылкаСуществует Тогда
				НоваяСтрока.Дефект = Дефект;
				НоваяСтрока.СпособУстранения = Дефект.СпособУстранения;
			КонецЕсли;
			
		КонецЦикла;
		НовыйЭлемент.Дефекты.Загрузить(Дефекты);
	КонецЕсли;

	Возврат НовыйЭлемент;
	
КонецФункции

Процедура ЗаписатьДокументНарядНаРемонт(ЧтениеXML, СтруктураДанных)

	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	НоваяСсылка = Документы.мп_НарядНаРемонт.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаНаДокументСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);

	ВерсияДанныхЕРП = ?(Строка(ОбъектXDTO.ВерсияДанныхЕРП) = "ОбъектXDTO", "", ОбъектXDTO.ВерсияДанныхЕРП);
	
	Если СсылкаНаДокументСуществует Тогда
		Если ВерсияДанныхЕРП = НоваяСсылка.ВерсияДанныхЕРП Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	РеквизитыДокумента = Новый Структура;
	
	РеквизитыДокумента.Вставить("ВерсияДанныхЕРП", ВерсияДанныхЕРП);
	
	Дата = СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.Дата);
	РеквизитыДокумента.Вставить("Дата", Дата);
	
	НомерКИС = ОбъектXDTO.Номер;
	РеквизитыДокумента.Вставить("НомерКИС", НомерКИС);
	
	ПометкаУдаления = ?(ОбъектXDTO.ПометкаУдаления = "false", Ложь, Истина);
	РеквизитыДокумента.Вставить("ПометкаУдаления", ПометкаУдаления);
	
	Проведен = ?(ОбъектXDTO.Проведен = "false", Ложь, Истина);
	РеквизитыДокумента.Вставить("Проведен", Проведен);

	СтатусыНаряд = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.СтатусыНарядаНаРемонт Цикл 
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СтатусыНаряд.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	СтатусыНаряд.Вставить("ОбъектXDTO", Перечисления.СтатусыНарядаНаРемонт.ПустаяСсылка());
	Статус = СтатусыНаряд[Строка(ОбъектXDTO.Статус)];
	РеквизитыДокумента.Вставить("Статус", Статус);
	
	Подразделение = РеквизитСправочникаПоУИД("СтруктураПредприятия", ОбъектXDTO.Подразделение);
	РеквизитыДокумента.Вставить("Подразделение", Подразделение);
	
	Если СсылкаНаДокументСуществует Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Документы.мп_НарядНаРемонт.СоздатьДокумент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, РеквизитыДокумента);
	
	ТЗРезультат = ТаблицаЗначенийИзДвоичныхДанных(ОбъектXDTO, "Работы");
	Если ТипЗнч(ТЗРезультат) = Тип("ТаблицаЗначений") Тогда
		Работы = НовыйЭлемент.Работы.Выгрузить();
		Работы.Очистить();
		Для Каждого ТекСтрока Из ТЗРезультат Цикл
			ИмяДокумента = ТекСтрока.ВидДокумента;
			ЗначениеРеквизита = ТекСтрока.Работа;
			Работа = РеквизитДокументаПоУИД(ИмяДокумента, ЗначениеРеквизита);
			ИдентификаторСтроки = ТекСтрока.ИдентификаторСтроки;
			
			НоваяСтрока = Работы.Добавить();
			НоваяСтрока.Работа = Работа;
			НоваяСтрока.ИдентификаторСтроки = ИдентификаторСтроки;
			
		КонецЦикла;
		НовыйЭлемент.Работы.Загрузить(Работы);
	КонецЕсли;
	
	ТЗРезультат = ТаблицаЗначенийИзДвоичныхДанных(ОбъектXDTO, "Исполнители");
	Если ТипЗнч(ТЗРезультат) = Тип("ТаблицаЗначений") Тогда
		Исполнители = НовыйЭлемент.Исполнители.Выгрузить();
		Исполнители.Очистить();
		Для Каждого ТекСтрока Из ТЗРезультат Цикл
			ИмяСправочника = "Пользователи";
			ЗначениеРеквизита = ТекСтрока.Ответственный;
			Ответственный = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			ИдентификаторСтрокиРаботы = ТекСтрока.ИдентификаторСтрокиРаботы;
			
			НоваяСтрока = Исполнители.Добавить();
			НоваяСтрока.Ответственный = Ответственный;
			НоваяСтрока.ИдентификаторСтрокиРаботы = ИдентификаторСтрокиРаботы;
			
		КонецЦикла;
		НовыйЭлемент.Исполнители.Загрузить(Исполнители);
	КонецЕсли;
	НовыйЭлемент.СтатусОбмена = Перечисления.мп_СтатусыОбмена.ЗагруженИзКИС;
	НовыйЭлемент.Записать(РежимЗаписиДокумента.Запись);

КонецПроцедуры

Процедура ЗаписатьДокументЗаданиеНаРемонт(ЧтениеXML, СтруктураДанных)
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);

	НоваяСсылка = Документы.мп_ЗаданиеНаРемонт.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаНаДокументСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);

	ВерсияДанныхЕРП = ?(Строка(ОбъектXDTO.ВерсияДанныхЕРП) = "ОбъектXDTO", "", ОбъектXDTO.ВерсияДанныхЕРП);
	
	Если СсылкаНаДокументСуществует Тогда
		Если ВерсияДанныхЕРП = НоваяСсылка.ВерсияДанныхЕРП Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	РеквизитыДокумента = Новый Структура;

	ИстинаСтрокой = "true";
	ЗаказНаРемонтУИД = ?(ОбъектXDTO.ЗаказНаРемонтУИД = "ОбъектXDTO", "", ОбъектXDTO.ЗаказНаРемонтУИД);
	ЗаказНаРемонтВерсияДанныхЕРП =
		?(Строка(ОбъектXDTO.ЗаказНаРемонтВерсияДанныхЕРП) = "ОбъектXDTO", "", ОбъектXDTO.ЗаказНаРемонтВерсияДанныхЕРП);
	ЗаказНаРемонтДата = СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.ЗаказНаРемонтДата);
	ЗаказНаРемонтНомер =
		?(Строка(ОбъектXDTO.ЗаказНаРемонтНомер) = "ОбъектXDTO", "", ОбъектXDTO.ЗаказНаРемонтНомер);
	ЗаказНаРемонтПредставление =
		?(Строка(ОбъектXDTO.ЗаказНаРемонтПредставление) = "ОбъектXDTO", "", ОбъектXDTO.ЗаказНаРемонтПредставление);
	ЗаказНаРемонтПроведен =
		?(ОбъектXDTO.ЗаказНаРемонтПроведен = ИстинаСтрокой, Истина, Ложь);
		
	ЗаказНаРемонтПометкаУдаления =
		?(ОбъектXDTO.ЗаказНаРемонтПометкаУдаления = ИстинаСтрокой, Истина, Ложь);

	РеквизитыЗаказНаРемонт = Новый Структура;
	РеквизитыЗаказНаРемонт.Вставить("ЗаказНаРемонтУИД", ЗаказНаРемонтУИД);
	РеквизитыЗаказНаРемонт.Вставить("ЗаказНаРемонтВерсияДанныхЕРП", ЗаказНаРемонтВерсияДанныхЕРП);
	РеквизитыЗаказНаРемонт.Вставить("ЗаказНаРемонтДата", ЗаказНаРемонтДата);
	РеквизитыЗаказНаРемонт.Вставить("ЗаказНаРемонтНомер", ЗаказНаРемонтНомер);
	РеквизитыЗаказНаРемонт.Вставить("ЗаказНаРемонтПредставление", ЗаказНаРемонтПредставление);
	РеквизитыЗаказНаРемонт.Вставить("ЗаказНаРемонтПроведен", ЗаказНаРемонтПроведен);
	РеквизитыЗаказНаРемонт.Вставить("ЗаказНаРемонтПометкаУдаления", ЗаказНаРемонтПометкаУдаления);

	ЗаказНаРемонт =
		Справочники.ЗаказНаРемонт.ПолучитьЗаказНаРемонт(РеквизитыЗаказНаРемонт);
	РеквизитыДокумента.Вставить("ЗаказНаРемонт", ЗаказНаРемонт);
	
	ОбъектЭксплуатации = РеквизитСправочникаПоУИД("ОбъектыЭксплуатации", ОбъектXDTO.ОбъектЭксплуатации);
	РеквизитыДокумента.Вставить("ОбъектЭксплуатации", ОбъектЭксплуатации);
	
	Узел = РеквизитСправочникаПоУИД("УзлыОбъектовЭксплуатации", ОбъектXDTO.Узел);
	РеквизитыДокумента.Вставить("Узел", Узел);

	НаименованиеРабот = РеквизитСправочникаПоУИД("ТехнологическиеОперации", ОбъектXDTO.НаименованиеРабот);
	РеквизитыДокумента.Вставить("НаименованиеРабот", НаименованиеРабот);

	ПоказательИзмерения = РеквизитСправочникаПоУИД("ПоказателиНаработки", ОбъектXDTO.ПоказательИзмерения);
	РеквизитыДокумента.Вставить("ПоказательИзмерения", ПоказательИзмерения);

	ВидПроверки = РеквизитСправочникаПоУИД("мп_ВидыПроверокОборудования", ОбъектXDTO.ВидПроверки);
	РеквизитыДокумента.Вставить("ВидПроверки", ВидПроверки);

	ОбщийВидРемонта = РеквизитСправочникаПоУИД("ОбщиеВидыРемонтов", ОбъектXDTO.ОбщийВидРемонта);
	РеквизитыДокумента.Вставить("ОбщийВидРемонта", ОбщийВидРемонта);

	Исполнитель = РеквизитСправочникаПоУИД("СтруктураПредприятия", ОбъектXDTO.Исполнитель);
	РеквизитыДокумента.Вставить("Исполнитель", Исполнитель);

	ВидРемонта = РеквизитСправочникаПоУИД("ВидыРемонтов", ОбъектXDTO.ВидРемонта);
	РеквизитыДокумента.Вставить("ВидРемонта", ВидРемонта);

	РеквизитыДокумента.Вставить("ВерсияДанныхЕРП", ВерсияДанныхЕРП);
	
	ПометкаУдаления = ?(ОбъектXDTO.ПометкаУдаления = "true", Истина, Ложь);
	РеквизитыДокумента.Вставить("ПометкаУдаления", ПометкаУдаления);
	
	НомерКИС = ?(Строка(ОбъектXDTO.НомерКИС) = "ОбъектXDTO", "", ОбъектXDTO.НомерКИС);
	РеквизитыДокумента.Вставить("НомерКИС", НомерКИС);
	
	Дата = СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.Дата);
	РеквизитыДокумента.Вставить("Дата", Дата);
	
	Проведен = ?(ОбъектXDTO.Проведен = "true", Истина, Ложь);
	РеквизитыДокумента.Вставить("Проведен", Проведен);
	
	РеквизитыДокумента.Вставить("СтатусОбмена", Перечисления.мп_СтатусыОбмена.ЗагруженИзКИС);
	
	ИдентификаторСтроки = ?(Строка(ОбъектXDTO.ИдентификаторСтроки) = "ОбъектXDTO", "", ОбъектXDTO.ИдентификаторСтроки);
	РеквизитыДокумента.Вставить("ИдентификаторСтроки", ИдентификаторСтроки);
	
	ДатаНачала = СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.ДатаНачала);
	РеквизитыДокумента.Вставить("ДатаНачала", ДатаНачала);
	
	ДатаЗавершения = СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.ДатаЗавершения);
	РеквизитыДокумента.Вставить("ДатаЗавершения", ДатаЗавершения);
	
	ВыполнениеОперации = ?(Строка(ОбъектXDTO.ВыполнениеОперации) = "ОбъектXDTO", "", ОбъектXDTO.ВыполнениеОперации);
	Если Не ПустаяСтрока(ВыполнениеОперации) Тогда
		ВыполнениеОперации = """" + ВыполнениеОперации  + """";
	КонецЕсли;
	РеквизитыДокумента.Вставить("ВыполнениеОперации", ВыполнениеОперации);
	ТипЧисло = Тип("Число");
	ЗначениеПоказателяИзмерения = СериализаторXDTO.XMLЗначение(ТипЧисло, ОбъектXDTO.ЗначениеПоказателяИзмерения);
	РеквизитыДокумента.Вставить("ЗначениеПоказателяИзмерения", ЗначениеПоказателяИзмерения);
	
	РезультатПроверки = ?(ОбъектXDTO.РезультатПроверки = "true", Истина, Ложь);
	РеквизитыДокумента.Вставить("РезультатПроверки", РезультатПроверки);
	
	ДатаИзмеренияПроверкиВыполнения
		= СериализаторXDTO.XMLЗначение(Тип("Дата"), ОбъектXDTO.ДатаИзмеренияПроверкиВыполнения);
	РеквизитыДокумента.Вставить("ДатаИзмеренияПроверкиВыполнения", ДатаИзмеренияПроверкиВыполнения);
	
	ФотоотчетОбязателен = ?(ОбъектXDTO.ФотоотчетОбязателен = "true", Истина, Ложь);
	РеквизитыДокумента.Вставить("ФотоотчетОбязателен", ФотоотчетОбязателен);
	
	Продолжительность = ?(Строка(ОбъектXDTO.Продолжительность) = "ОбъектXDTO", "", ОбъектXDTO.Продолжительность);
	РеквизитыДокумента.Вставить("Продолжительность", Продолжительность);
	
	Трудоемкость = СериализаторXDTO.XMLЗначение(ТипЧисло, ОбъектXDTO.Трудоемкость);
	РеквизитыДокумента.Вставить("Трудоемкость", Трудоемкость);
	
	ТабличнаяЧасть = СериализаторXDTO.XMLЗначение(ТипЧисло, ОбъектXDTO.ТабличнаяЧасть);
	РеквизитыДокумента.Вставить("ТабличнаяЧасть", ТабличнаяЧасть);
	
	КоличествоЧеловек = СериализаторXDTO.XMLЗначение(ТипЧисло, ОбъектXDTO.КоличествоЧеловек);
	РеквизитыДокумента.Вставить("КоличествоЧеловек", КоличествоЧеловек);
	
	Комментарий = ?(Строка(ОбъектXDTO.Комментарий) = "ОбъектXDTO", "", ОбъектXDTO.Комментарий);
	РеквизитыДокумента.Вставить("Комментарий", Комментарий);
	
	ТехРешение = ?(Строка(ОбъектXDTO.ТехРешение) = "ОбъектXDTO", "", ОбъектXDTO.ТехРешение);
	РеквизитыДокумента.Вставить("ТехРешение", ТехРешение);

	Если СсылкаНаДокументСуществует Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Документы.мп_ЗаданиеНаРемонт.СоздатьДокумент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, РеквизитыДокумента);
	
	ТЗРезультат = ТаблицаЗначенийИзДвоичныхДанных(ОбъектXDTO, "МатериалыКОприходованию");
	Если ТипЗнч(ТЗРезультат) = Тип("ТаблицаЗначений") Тогда
		МатериалыКОприходованию = НовыйЭлемент.МатериалыКОприходованию.Выгрузить();
		МатериалыКОприходованию.Очистить();
		Для Каждого ТекСтрока Из ТЗРезультат Цикл
			ИмяСправочника = "Номенклатура";
			ЗначениеРеквизита = ТекСтрока.Номенклатура;
			Номенклатура = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ЗначениеРеквизита = ТекСтрока.НоменклатураВозврат;
			НоменклатураВозврат = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ИмяСправочника = "ХарактеристикиНоменклатуры";
			ЗначениеРеквизита = ТекСтрока.Характеристика;
			Характеристика = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ЗначениеРеквизита = ТекСтрока.ХарактеристикаВозврат;
			ХарактеристикаВозврат = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ИмяСправочника = "СерииНоменклатуры";
			ЗначениеРеквизита = ТекСтрока.Серия;
			Серия = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ИмяСправочника = "Склады";
			ЗначениеРеквизита = ТекСтрока.Склад;
			Склад = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);

			НоваяСтрока = МатериалыКОприходованию.Добавить();
			НоваяСтрока.Номенклатура = Номенклатура;
			НоваяСтрока.НоменклатураВозврат = НоменклатураВозврат;
			НоваяСтрока.Характеристика = Характеристика;
			НоваяСтрока.ХарактеристикаВозврат = ХарактеристикаВозврат;
			НоваяСтрока.Серия = Серия;
			НоваяСтрока.Склад = Склад;
			НоваяСтрока.СтатусУказанияСерий = ТекСтрока.СтатусУказанияСерий;
			НоваяСтрока.Количество = ТекСтрока.Количество;
			
		КонецЦикла;
		НовыйЭлемент.МатериалыКОприходованию.Загрузить(МатериалыКОприходованию);
		
	КонецЕсли;
	
	ТЗРезультат = ТаблицаЗначенийИзДвоичныхДанных(ОбъектXDTO, "МатериалыКСписанию");
	Если ТипЗнч(ТЗРезультат) = Тип("ТаблицаЗначений") Тогда
		МатериалыКСписанию = НовыйЭлемент.МатериалыКСписанию.Выгрузить();
		МатериалыКСписанию.Очистить();
		Для Каждого ТекСтрока Из ТЗРезультат Цикл
			ИмяСправочника = "Номенклатура";
			ЗначениеРеквизита = ТекСтрока.Номенклатура;
			Номенклатура = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ЗначениеРеквизита = ТекСтрока.ЗаменаНоменклатура;
			ЗаменаНоменклатура = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ИмяСправочника = "ХарактеристикиНоменклатуры";
			ЗначениеРеквизита = ТекСтрока.Характеристика;
			Характеристика = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ЗначениеРеквизита = ТекСтрока.ЗаменаХарактеристика;
			ЗаменаХарактеристика = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ИмяСправочника = "СерииНоменклатуры";
			ЗначениеРеквизита = ТекСтрока.Серия;
			Серия = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ЗначениеРеквизита = ТекСтрока.ЗаменаСерия;
			ЗаменаСерия = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			ИмяСправочника = "Склады";
			ЗначениеРеквизита = ТекСтрока.Склад;
			Склад = РеквизитСправочникаПоУИД(ИмяСправочника, ЗначениеРеквизита);
			
			План = ТекСтрока.План;
			Факт = План;

			НоваяСтрока = МатериалыКСписанию.Добавить();
			НоваяСтрока.Номенклатура = Номенклатура;
			НоваяСтрока.Характеристика = Характеристика;
			НоваяСтрока.Серия = Серия;
			НоваяСтрока.Склад = Склад;
			НоваяСтрока.План = План;
			НоваяСтрока.Факт = Факт;
			НоваяСтрока.СтатусУказанияСерий = ТекСтрока.СтатусУказанияСерий;
			НоваяСтрока.ЗаменаНоменклатура = ЗаменаНоменклатура;
			НоваяСтрока.ЗаменаХарактеристика = ЗаменаХарактеристика;
			НоваяСтрока.ЗаменаСерия = ЗаменаСерия;
		КонецЦикла;
		НовыйЭлемент.МатериалыКСписанию.Загрузить(МатериалыКСписанию);
	КонецЕсли;
	НовыйЭлемент.Записать(РежимЗаписиДокумента.Запись);

КонецПроцедуры

Процедура ОбновитьРегистрациюДефекта(ЧтениеXML, СтруктураДанных)

	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);

	НоваяСсылка = Документы.РегистрацияДефекта.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаНаДокументСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	ОтветОтЕРП = ?(ОбъектXDTO.ОтветОтЕРП = "true", Истина, Ложь);
 	Если Не ОтветОтЕРП Тогда

		ВерсияДанныхЕРП = ?(ОбъектXDTO.ВерсияДанныхЕРП = "ОбъектXDTO", "", ОбъектXDTO.ВерсияДанныхЕРП);
		СовпадаетВерсияДанных = (НоваяСсылка.ВерсияДанныхЕРП = ВерсияДанныхЕРП);
		Если СсылкаНаДокументСуществует И СовпадаетВерсияДанных Тогда
			Возврат;
		КонецЕсли;

		РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();

		ОтветственныйЗаУстранение = Справочники.Пользователи.ПолучитьСсылку(
		Новый УникальныйИдентификатор(ОбъектXDTO.ОтветственныйЗаУстранение));
		СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(ОтветственныйЗаУстранение);
		Если Не СсылкаСуществует Тогда
			ОтветственныйЗаУстранение = Справочники.Пользователи.ПустаяСсылка();
		КонецЕсли;
		ИмяРолиБригадира = "мп_БригадирТОиР";
		Если РольДоступна(ИмяРолиБригадира) И Не СсылкаНаДокументСуществует Тогда
			ЗагружаемДокумент = Истина;
		ИначеЕсли РольДоступна(ИмяРолиБригадира) И Не СовпадаетВерсияДанных Тогда
			ЗагружаемДокумент = Истина;
		ИначеЕсли СсылкаСуществует И ОтветственныйЗаУстранение = РеквизитыКонстант["ТекущийПользователь"] Тогда
			ЗагружаемДокумент = Истина;
		Иначе
			ЗагружаемДокумент = Ложь;
		КонецЕсли;

		Если ЗагружаемДокумент Тогда
			НовыйЭлемент = СоздатьДокументРегистрацияДефекта(НоваяСсылка, ОбъектXDTO, ОтветственныйЗаУстранение);
		Иначе
			Возврат;
		КонецЕсли;
	Иначе
		СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
		Если СсылкаСуществует Тогда
			НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	СтатусыОбмена = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.мп_СтатусыОбмена Цикл 
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СтатусыОбмена.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	СтатусыОбмена.Вставить("ОбъектXDTO", Перечисления.мп_СтатусыОбмена.ПустаяСсылка());
	
	Если ОтветОтЕРП Тогда
		НовыйЭлемент.СтатусОбмена = СтатусыОбмена[Строка(ОбъектXDTO.СтатусОбмена)];
	ИначеЕсли СтатусыОбмена[Строка(ОбъектXDTO.СтатусОбмена)] = Перечисления.мп_СтатусыОбмена.КВыгрузкеВМП Тогда
		НовыйЭлемент.СтатусОбмена = Перечисления.мп_СтатусыОбмена.ЗагруженИзКИС;
		Если РольДоступна("мп_БригадирТОиР") Тогда
			НовыйЭлемент.ДополнительныеСвойства.Вставить("ЗагруженИзКИС", Истина);
		КонецЕсли;
	Иначе
		НовыйЭлемент.СтатусОбмена = СтатусыОбмена[Строка(ОбъектXDTO.СтатусОбмена)];
	КонецЕсли;

	Попытка
		Если Не НовыйЭлемент.ПометкаУдаления Тогда
			НовыйЭлемент.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			НовыйЭлемент.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
		
	Исключение
		ТекстОшибки = СтрШаблон(
			"ОбменСервер.РегистрацияДефекта | Ошибка записи элемента РегистрацияДефекта %1", "");
		HTTPCore.ЗаписатьМобильнуюОшибку(ТекстОшибки, СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;

КонецПроцедуры

Процедура ОбновитьНаработкуОбъектаЭксплуатации(ЧтениеXML, СтруктураДанных, Отправитель)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НоваяСсылка = Документы.НаработкаОбъектовЭксплуатации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	
	Если Не СсылкаСуществует Тогда
		Возврат;
	КонецЕсли;
	
	СтатусыОбмена = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.мп_СтатусыОбмена Цикл 
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СтатусыОбмена.Вставить(ИдентификаторЗначения, ТекЗначПер);
	КонецЦикла;
	СтатусыОбмена.Вставить("ОбъектXDTO", Перечисления.мп_СтатусыОбмена.ПустаяСсылка());
	
	НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	НовыйЭлемент.мп_СтатусОбмена = СтатусыОбмена[Строка(ОбъектXDTO.мп_СтатусОбмена)];
	
	Попытка
		
		НовыйЭлемент.Записать();
		
	Исключение
		ТекстОшибки = СтрШаблон(
			"ОбменСервер.НаработкаОбъектовЭксплуатации | Ошибка записи элемента НаработкаОбъектовЭксплуатации %1",
			ОбъектXDTO.Description);
			
		HTTPCore.ЗаписатьМобильнуюОшибку(ТекстОшибки, СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

Процедура ЗаписатьПакетКлиентПачкой(СтруктураДанных, ОбъектыОбмена = Неопределено, ОтветДляКИС = Ложь)

	Попытка
		УзелОбмена = ОбщегоНазначенияПовтИсп.ПолучитьУзелЦентральнойБазы();
		Если УзелОбмена.Пустая() Тогда
			ВызватьИсключение "Узел обмена ЦБ не найден. Произведите регистрацию устройства.";

		КонецЕсли;

		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.УстановитьСтроку();

		ЗаписьСообщения = ПланыОбмена.СоздатьЗаписьСообщения();
		ЗаписьСообщения.НачатьЗапись(ЗаписьXML, УзелОбмена);

		Если ОтветДляКИС Тогда
			ЗаписьXML.ЗаписатьАтрибут("MessageType", "Response");
		КонецЕсли;
		
		ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(
			УзелОбмена, ЗаписьСообщения.НомерСообщения, ОбъектыОбмена);
			
		Пока ВыборкаИзменений.Следующий() Цикл
			ОбъектОбменаУзел = ВыборкаИзменений.Получить();
			ЗаписатьXML(ЗаписьXML, ОбъектОбменаУзел);
		КонецЦикла;
		
		ЗаписьСообщения.ЗакончитьЗапись();
		
		СтруктураДанных.ПакетКлиент = ЗаписьXML.Закрыть();
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			"ОбменСервер.ЗаписатьПакетКлиент | Ошибка формирования пакета данных на клиенте", СтруктураДанных, ,
			ОписаниеОшибки());
		
	КонецПопытки;
	
КонецПроцедуры

Функция ОчиститьПакетОтСоставногоРеквизита(ПакетКлиент, ВидДокумента, СоставнойРеквизит)
	
	Чтение = Новый ЧтениеXML;
	Чтение.УстановитьСтроку(ПакетКлиент);
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();
	
	ВНужномДокументе = Ложь;
	
	Пока Чтение.Прочитать() Цикл
		
		Если Чтение.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			
			Если Чтение.Имя = ВидДокумента Тогда
				ВНужномДокументе = Истина;
				Запись.ЗаписатьТекущий(Чтение);
				Продолжить;
			КонецЕсли;
			
			Если ВНужномДокументе И Чтение.Имя = СоставнойРеквизит Тогда
				Чтение.Пропустить();
				Продолжить;
			КонецЕсли;
			
		ИначеЕсли Чтение.ТипУзла = ТипУзлаXML.КонецЭлемента И Чтение.Имя = ВидДокумента Тогда
			ВНужномДокументе = Ложь;
		КонецЕсли;
		
		Запись.ЗаписатьТекущий(Чтение);
		
	КонецЦикла;
	
	Возврат Запись.Закрыть();
	
КонецФункции

Процедура ЗаписатьПакетКлиент(СтруктураДанных, ОбъектОбмена = Неопределено)
	
	Попытка
		УзелОбмена = ОбщегоНазначенияПовтИсп.ПолучитьУзелЦентральнойБазы();
		Если УзелОбмена.Пустая() Тогда
			ВызватьИсключение "Узел обмена ЦБ не найден. Произведите регистрацию устройства.";
			
		КонецЕсли;
		
		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.УстановитьСтроку();
		
		ЗаписьСообщения = ПланыОбмена.СоздатьЗаписьСообщения();
		ЗаписьСообщения.НачатьЗапись(ЗаписьXML, УзелОбмена);
		
		ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(
			УзелОбмена, ЗаписьСообщения.НомерСообщения, ОбъектОбмена);
			
		Пока ВыборкаИзменений.Следующий() Цикл
			ОбъектОбменаУзел = ВыборкаИзменений.Получить();
			ЗаписатьXML(ЗаписьXML, ОбъектОбменаУзел);
		КонецЦикла;
		
		ЗаписьСообщения.ЗакончитьЗапись();
		ПакетКлиент = ЗаписьXML.Закрыть();
		ПакетКлиент = ОчиститьПакетОтСоставногоРеквизита(ПакетКлиент, "DocumentObject.мп_НарядНаРемонт", "Работа");
		СтруктураДанных.ПакетКлиент = ПакетКлиент;
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			"ОбменСервер.ЗаписатьПакетКлиент | Ошибка формирования пакета данных на клиенте", СтруктураДанных, ,
			ОписаниеОшибки());
		
	КонецПопытки;
	
КонецПроцедуры

