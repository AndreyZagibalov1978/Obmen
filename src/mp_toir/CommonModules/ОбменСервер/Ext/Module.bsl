КонецПроцедуры

Процедура ЗаписатьСтруктураПредприятия(ЧтениеXML, СтруктураДанных)

	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НоваяСсылка = Справочники.СтруктураПредприятия.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаСуществует Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		НовыйЭлемент = Справочники.СтруктураПредприятия.СоздатьЭлемент();
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
		
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO);
	
	Родитель = Справочники.СтруктураПредприятия.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Parent));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Родитель);
	Если Не СсылкаСуществует Тогда
		Родитель = Справочники.СтруктураПредприятия.ПустаяСсылка();
	КонецЕсли;
	
	НовыйЭлемент.Родитель = Родитель;
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	
	Попытка
		НовыйЭлемент.Записать();
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.СтруктураПредприятия | Ошибка записи элемента подразделения %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;
	

КонецПроцедуры

Процедура ЗаписатьДефектыОборудования(ЧтениеXML, СтруктураДанных, Отправитель)
	
	СпособыУстранения = Новый Соответствие;
	Для Каждого ТекЗначПер Из Перечисления.Мечел_СпособыУстраненияДефектов Цикл 
	
		ИдентификаторЗначения = XMLСтрока(ТекЗначПер);
		СпособыУстранения.Вставить(ИдентификаторЗначения, ТекЗначПер);
		
	КонецЦикла;

	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НоваяСсылка = Справочники.Мечел_ДефектыОборудования.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ref));
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(НоваяСсылка);
	Если СсылкаСуществует Тогда
		НовыйЭлемент = НоваяСсылка.ПолучитьОбъект(); 
	Иначе
		Если ОбъектXDTO.IsFolder = "true" Тогда
			НовыйЭлемент = Справочники.Мечел_ДефектыОборудования.СоздатьГруппу();
		Иначе
			НовыйЭлемент = Справочники.Мечел_ДефектыОборудования.СоздатьЭлемент();
		КонецЕсли;
		НовыйЭлемент.УстановитьСсылкуНового(НоваяСсылка);
	КонецЕсли;
	
	Родитель = Справочники.Мечел_ДефектыОборудования.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Parent));
	
	СсылкаСуществует = ОбщегоНазначения.СсылкаСуществует(Родитель);
	Если Не СсылкаСуществует Тогда
		Родитель = Справочники.Мечел_ДефектыОборудования.ПустаяСсылка();
	КонецЕсли;
	
	НовыйЭлемент.ОбменДанными.Загрузка = Истина;
	
	ЗаполнитьЗначенияСвойств(НовыйЭлемент, ОбъектXDTO, "Code,Description");
	НовыйЭлемент.ПометкаУдаления = ?(ОбъектXDTO.DeletionMark = "true", Истина, Ложь);
	Если ОбъектXDTO.IsFolder = "false" Тогда
		Если Не ПустаяСтрока(ОбъектXDTO.СпособУстранения) Тогда
			НовыйЭлемент.СпособУстранения = СпособыУстранения[ОбъектXDTO.СпособУстранения];
		КонецЕсли;
		НовыйЭлемент.Мечел_Флаг_Неустранимый = ?(ОбъектXDTO.Мечел_Флаг_Неустранимый = "true", Истина, Ложь);
		НовыйЭлемент.мп_ФотоОбязательно = ?(ОбъектXDTO.мп_ФотоОбязательно = "true", Истина, Ложь);
	КонецЕсли;
	НовыйЭлемент.Родитель = Родитель;
	Попытка
		НовыйЭлемент.Записать();
		
	Исключение
		HTTPCore.ЗаписатьМобильнуюОшибку(
			СтрШаблон(
				"ОбменСервер.СтруктураПредприятия | Ошибка записи элемента подразделения %1",
				ОбъектXDTO.Description), СтруктураДанных, , ОписаниеОшибки());
		
	КонецПопытки;
КонецПроцедуры

