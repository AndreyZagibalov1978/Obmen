			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	мп_ЗаданиеНаРемонт.Номер КАК Номер,
	мп_ЗаданиеНаРемонт.Ссылка КАК Ссылка,
	мп_ЗаданиеНаРемонт.Подразделение КАК Подразделение,
	мп_ЗаданиеНаРемонт.ДатаИзмеренияПроверкиВыполнения КАК ДатаИзмеренияПроверкиВыполнения,
	мп_ЗаданиеНаРемонт.Ответственный КАК Ответственный,
	мп_ЗаданиеНаРемонт.ОбъектЭксплуатации КАК ОбъектЭксплуатации,
	мп_ЗаданиеНаРемонт.ВыполнениеОперации КАК ВыполнениеОперации,
	мп_ЗаданиеНаРемонт.СтатусОбмена КАК СтатусОбмена,
	мп_ЗаданиеНаРемонт.Дата КАК Дата
ИЗ
	Документ.мп_ЗаданиеНаРемонт КАК мп_ЗаданиеНаРемонт
ГДЕ
	ВЫБОР
			КОГДА &amp;ПлановаяДата = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ИСТИНА
			КОГДА НАЧАЛОПЕРИОДА(мп_ЗаданиеНаРемонт.ДатаНачала, ДЕНЬ) &lt;= НАЧАЛОПЕРИОДА(&amp;ПлановаяДата, ДЕНЬ)
					И НАЧАЛОПЕРИОДА(мп_ЗаданиеНаРемонт.ДатаЗавершения, ДЕНЬ) &gt;= НАЧАЛОПЕРИОДА(&amp;ПлановаяДата, ДЕНЬ)
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;Подразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ мп_ЗаданиеНаРемонт.Подразделение = &amp;Подразделение
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;Ответственный = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ мп_ЗаданиеНаРемонт.Ответственный = &amp;Ответственный
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ОбъектЭксплуатации = ЗНАЧЕНИЕ(Справочник.ОбъектыЭксплуатации.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ мп_ЗаданиеНаРемонт.ОбъектЭксплуатации = &amp;ОбъектЭксплуатации
		КОНЕЦ
	И НЕ мп_ЗаданиеНаРемонт.Ссылка В (&amp;ИсключаемыеДокументы)
	И НЕ мп_ЗаданиеНаРемонт.ПометкаУдаления</QueryText>
