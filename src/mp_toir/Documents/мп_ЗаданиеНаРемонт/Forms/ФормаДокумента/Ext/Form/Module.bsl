&НаКлиенте
Процедура ДобавитьМатериалКСписанию(Команда)
	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	Строка = Объект.МатериалыКСписанию.Добавить();
	Строка.ЭтоНоваяСтрока = Истина;
	Строка.АвтоматическиДобавленнаяСтрока = Ложь;
	Строка.ИдентификаторСтроки = Новый УникальныйИдентификатор();
	ОткрытьФормуРедактированияСписания(Строка);

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьМатериалКСписанию(Команда)

	Строка = Элементы.МатериалыКСписанию.ТекущиеДанные;
	Строка.ЭтоНоваяСтрока = Ложь;
	ОткрытьФормуРедактированияСписания(Строка);

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРедактированияСписания(Строка)
	
	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("Номенклатура", Строка.Номенклатура);
	ДанныеСтроки.Вставить("Характеристика", Строка.Характеристика);
	ДанныеСтроки.Вставить("Серия", Строка.Серия);
	ДанныеСтроки.Вставить("Склад", Строка.Склад);
	ДанныеСтроки.Вставить("План", Строка.План);
	ДанныеСтроки.Вставить("Факт", Строка.Факт);
	ДанныеСтроки.Вставить("СтатусУказанияСерий", Строка.СтатусУказанияСерий);
	ДанныеСтроки.Вставить("АвтоматическиДобавленнаяСтрока", Строка.АвтоматическиДобавленнаяСтрока);
	ДанныеСтроки.Вставить("НомерСтроки", Строка.ПолучитьИдентификатор());
	ДанныеСтроки.Вставить("ИдентификаторСтроки", Строка.ИдентификаторСтроки);
	ДанныеСтроки.Вставить("ЗаменаНоменклатура", Строка.ЗаменаНоменклатура);
	ДанныеСтроки.Вставить("ЗаменаХарактеристика", Строка.ЗаменаХарактеристика);
	ДанныеСтроки.Вставить("ЗаменаСерия", Строка.ЗаменаСерия);
	ЭтоКИС= (Объект.Источник = ПредопределенноеЗначение("Перечисление.мп_ИсточникиДокументов.КИС"));
	ДанныеСтроки.Вставить("ТолькоПросмотр", ЭтоКИС);
	ДанныеСтроки.Вставить("СтатусОбмена", Объект.СтатусОбмена);
	ДанныеСтроки.Вставить("Источник", Объект.Источник);
	ДанныеСтроки.Вставить("ОбъектЭксплуатации", Объект.ОбъектЭксплуатации);
	ДанныеСтроки.Вставить("ВыбранныйУзел", Объект.Узел);
	ДанныеСтроки.Вставить("МатериалыКОприходованию", Объект.МатериалыКОприходованию);
	ДанныеСтроки.Вставить("МатериалыКСписанию", Объект.МатериалыКСписанию);

	ОткрытьФорму("Документ.мп_ЗаданиеНаРемонт.Форма.ФормаСтрокиСписания",
		ДанныеСтроки, ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтрокуСписания(Команда)

	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;

	ИндексСтроки = Элементы.МатериалыКСписанию.ТекущиеДанные.НомерСтроки - 1;
	Объект.МатериалыКСписанию.Удалить(ИндексСтроки);
	Модифицированность = Истина;

КонецПроцедуры

