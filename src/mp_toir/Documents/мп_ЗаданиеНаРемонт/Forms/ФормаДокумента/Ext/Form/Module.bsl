&НаКлиенте
Процедура ДоступностьРеквизитовНаКлиенте()
	ЗапретРедактирования = Ложь;
	ПраваДоступа = ОбщегоНазначенияВызовСервера.ДоступныеПрава();
	ОтветственныйИсполнитель = ОтветственныйИсполнитель();
	Если ПраваДоступа.АдминТОиР Или ПраваДоступа.БригадирТОиР Тогда
		Если Объект.Исполнители.Количество() > 0 И Не ОтветственныйИсполнитель Тогда
			СтрСообщение = "Заданию на ремонт уже назначены исполнители. "
				+	"После внесения изменений установите Статус обмена = К выгрузке в КИС. "
				+	"Тем не менее, внесение изменений может привести к рассинхронизации информации";
			ПоказатьПредупреждение(, СтрСообщение, 45);
		КонецЕсли;
	ИначеЕсли ПраваДоступа.МеханикТОиР Тогда
		Если Не ОтветственныйИсполнитель Тогда
			ЗапретРедактирования = Истина;
		КонецЕсли;
	Иначе
		ЗапретРедактирования = Истина;
	КонецЕсли;
	ДоступностьРеквизитов(ЗапретРедактирования);
КонецПроцедуры

&НаСервере
Функция ОтветственныйИсполнитель()
	ТЗИсполнители = Объект.Исполнители.Выгрузить();
	СтрокаИсполнитель = ТЗИсполнители.Найти(ЭтотОбъект.ТекущийПользователь, "Ответственный");
	Возврат (НЕ СтрокаИсполнитель = Неопределено);
КонецФункции

&НаКлиенте
Процедура ИнициализироватьКартинкуНаФорме(ДанныеКартинки, РасширениеФайла)

	Если ДанныеКартинки <> Неопределено Тогда

		ИдентификаторСтроки = Новый УникальныйИдентификатор;
		АдресФото = ПоместитьВоВременноеХранилище(ДанныеКартинки, ИдентификаторСтроки);
		ТекущаяДата = ОбщегоНазначенияВызовСервера.ТекущаяДатаСервера();
		ТекущаяДатаСтрока = Формат( ТекущаяДата, "ДФ='yyyy_MM_dd'") + " время " + Формат( ТекущаяДата, "ДФ='HH_mm_ss'");
		НоваяСтрока = ЭтотОбъект.ТаблицаФотографии.Добавить();
		НоваяСтрока.Фото = ПоместитьКартинку_ФотоФайлДвоичный(ДанныеКартинки);
		НоваяСтрока.ФотоПредставление = АдресФото;
		НоваяСтрока.РасширениеФайла = РасширениеФайла;
		НоваяСтрока.ИдентификаторСтроки = ИдентификаторСтроки;
		НоваяСтрока.ИмяФайла = "мп_" + ТекущаяДатаСтрока + "." + РасширениеФайла;
		ДобавитьВТаблицу();
	КонецЕсли;

КонецПроцедуры

