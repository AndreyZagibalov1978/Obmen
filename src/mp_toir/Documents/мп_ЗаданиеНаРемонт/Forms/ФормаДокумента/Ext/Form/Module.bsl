&НаКлиенте
Процедура ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы)
	ИмяСтраницы = ИменаСтраниц[ТекущийИндексСтраницы];
	Страница = Элементы.Найти(ИмяСтраницы);
	Если Страница = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Элементы.ПредставлениеСтраницы.Заголовок = Страница.Заголовок;
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Страница;
	Элементы.ГруппаКнопкиСтраниц.Заголовок = "Всего " + Строка(ЭтотОбъект.КоличествоСтраниц) + " этапов";
КонецПроцедуры

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	ТекущийИндексСтраницы = ИменаСтраниц.Найти(ТекущаяСтраница.Имя);
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
КонецПроцедуры

&НаСервереБезКонтекста
Функция РедактированиеФормы(Знач Подразделение, ЗначОтветственный, Знач СтатусОбмена, Знач Источник, Знач Проведен);
	Если РольДоступна("ПолныеПрава") Или РольДоступна("мп_АдминистрированиеТОиР") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если Источник = Перечисления.мп_ИсточникиДокументов.КИС Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура ДоступностьРеквизитов(Знач ЗакрытьДоступ = Ложь)

	ИсточникКИС = (Объект.Источник = Перечисления.мп_ИсточникиДокументов.КИС);
	АдминТОиР = РольДоступна("мп_АдминистрированиеТОиР");
	БригадирТОиР = РольДоступна("мп_БригадирТОиР");
	МеханикТОиР = РольДоступна("мп_ДобавлениеИзменениеДокументовТОиР");
	
	Мечел_ИзмерениеОбязательно = Ложь;
	Если ЗначениеЗаполнено(Объект.НаименованиеРабот) Тогда
		Мечел_ИзмерениеОбязательно = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			Объект.НаименованиеРабот, "Мечел_ИзмерениеОбязательно");
	КонецЕсли;

	РазрешеноИзменять =Новый Массив;
	ЗапрещеноИзменять = Новый Массив;
	
	РазрешеноИзменять.Добавить("ГруппаКнопкиСтраниц");
	РазрешеноИзменять.Добавить("Страница1");
	РазрешеноИзменять.Добавить("Страница2");
	РазрешеноИзменять.Добавить("ГруппаСтраницы");
	РазрешеноИзменять.Добавить("ГруппаШапка");
	РазрешеноИзменять.Добавить("ГруппаНомер");
	РазрешеноИзменять.Добавить("ГруппаОсновная");
	РазрешеноИзменять.Добавить("ГруппаОсновная2");
	РазрешеноИзменять.Добавить("ГруппаФото");
	РазрешеноИзменять.Добавить("ГруппаИсполнители");
	РазрешеноИзменять.Добавить("ГруппаДополнительно");
	РазрешеноИзменять.Добавить("ГруппаСписание");
	РазрешеноИзменять.Добавить("МатериалыКСписанию");
	РазрешеноИзменять.Добавить("МатериалыКСписаниюКонтекстноеМеню");
	РазрешеноИзменять.Добавить("МатериалыКСписаниюКонтекстноеМенюИзменитьМатериалКСписанию");
	
	РазрешеноИзменять.Добавить("ГруппаОприходование");
	РазрешеноИзменять.Добавить("МатериалыКОприходованию");
	РазрешеноИзменять.Добавить("МатериалыКОприходованиюКонтекстноеМеню");
	РазрешеноИзменять.Добавить("МатериалыКОприходованиюКонтекстноеМенюИзменитьМатериалыКОприходованию");
	РазрешеноИзменять.Добавить("СтатусОбмена");
	
	Если Не ЗакрытьДоступ Тогда
		ЕстьВыполнение
			= Документы.мп_ЗаданиеНаРемонт.СостояниеВыполнениеОперации(Объект.ВыполнениеОперации);
		ЗакрытьДоступ = (Объект.Проведен И ЕстьВыполнение);
	КонецЕсли;
	
	Если Мечел_ИзмерениеОбязательно И Не ИсточникКИС И Не ЗакрытьДоступ Тогда
		РазрешеноИзменять.Добавить("ПоказательИзмерения");
		РазрешеноИзменять.Добавить("ВидПроверки");
	Иначе
		ЗапрещеноИзменять.Добавить("ПоказательИзмерения");
		ЗапрещеноИзменять.Добавить("ВидПроверки");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ВидПроверки) И Не ИсточникКИС И Не ЗакрытьДоступ Тогда
		РазрешеноИзменять.Добавить("РезультатПроверки");
	Иначе
		ЗапрещеноИзменять.Добавить("РезультатПроверки");
	КонецЕсли;

	СписокСтатусовОбмена = Новый Массив;
	СписокСтатусовОбмена.Добавить(Перечисления.мп_СтатусыОбмена.Создан);
	СписокСтатусовОбмена.Добавить(Перечисления.мп_СтатусыОбмена.ЗагруженИзКИС);

	Если АдминТОиР Или (БригадирТОиР И СписокСтатусовОбмена.Найти(Объект.СтатусОбмена) <> Неопределено) И Не ЗакрытьДоступ Тогда
		РазрешеноИзменять.Добавить("ИсполнителиДобавитьИсполнителя");
		РазрешеноИзменять.Добавить("ИсполнителиКонтекстноеМенюИзменитьСтрокуИсполнителя");
		РазрешеноИзменять.Добавить("ИсполнителиКонтекстноеМенюУдалитьСтрокуИсполнителя");
	Иначе
		ЗапрещеноИзменять.Добавить("ИсполнителиДобавитьИсполнителя");
		ЗапрещеноИзменять.Добавить("ИсполнителиКонтекстноеМенюИзменитьСтрокуИсполнителя");
		ЗапрещеноИзменять.Добавить("ИсполнителиКонтекстноеМенюУдалитьСтрокуИсполнителя");
	КонецЕсли;
	Если Не ИсточникКИС И Не ЗакрытьДоступ Тогда
		РазрешеноИзменять.Добавить("Дата");
	КонецЕсли;
	
	ЗапрещеноИзменять.Добавить("Источник");
	
	Если ИсточникКИС Или ЗакрытьДоступ Тогда
		ЗапрещеноИзменять.Добавить("МатериалыКСписаниюКонтекстноеМенюУдалитьСтрокуСписания");
		ЗапрещеноИзменять.Добавить("МатериалыКОприходованиюКонтекстноеМенюУдалитьСтрокуОприходования");
		ЗапрещеноИзменять = 
			ОбщегоНазначения.ЗапрещаемыеЭлементы(Элементы, РазрешеноИзменять, ЗапрещеноИзменять);
	КонецЕсли;

	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, РазрешеноИзменять, "Доступность", Истина);

	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, ЗапрещеноИзменять, "Доступность", Ложь) ;

КонецПроцедуры

&НаСервере
Процедура ВыполнениеОперацииПриИзмененииСервер(Знач ВыбранноеЗначение)
	
	Мечел_ИзмерениеОбязательно = Ложь;
	мп_ПроверкаОбязательна = Ложь;
	Если ЗначениеЗаполнено(Объект.НаименованиеРабот) Тогда
		РеквизитыРабот = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			Объект.НаименованиеРабот, "Мечел_ИзмерениеОбязательно, мп_ПроверкаОбязательна");
		Мечел_ИзмерениеОбязательно = РеквизитыРабот.Мечел_ИзмерениеОбязательно;
		мп_ПроверкаОбязательна = РеквизитыРабот.мп_ПроверкаОбязательна;
	КонецЕсли;
	ПустаяДатаИзмерения = (Объект.ДатаИзмеренияПроверкиВыполнения = Дата(1, 1, 1));
	Если ВыбранноеЗначение = """Да""" Тогда
		Если Объект.Источник = Перечисления.мп_ИсточникиДокументов.МечелТОиР Тогда
			Если Мечел_ИзмерениеОбязательно 
			И ЗначениеЗаполнено(Объект.ПоказательИзмерения)
			И Объект.ЗначениеПоказателяИзмерения <> 0
			И ПустаяДатаИзмерения Тогда
				
				Объект.ДатаИзмеренияПроверкиВыполнения = ТекущаяДатаСеанса();
				
			ИначеЕсли мп_ПроверкаОбязательна  
			И ЗначениеЗаполнено(Объект.ВидПроверки)
			И ПустаяДатаИзмерения Тогда
				
				Объект.ДатаИзмеренияПроверкиВыполнения = ТекущаяДатаСеанса();
				
			ИначеЕсли Не Мечел_ИзмерениеОбязательно
			И Не мп_ПроверкаОбязательна
			И ПустаяДатаИзмерения Тогда

				Объект.ДатаИзмеренияПроверкиВыполнения = ТекущаяДатаСеанса();

			КонецЕсли;
		Иначе
			Если ПустаяДатаИзмерения Тогда
				Объект.ДатаИзмеренияПроверкиВыполнения = ТекущаяДатаСеанса();
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ВыбранноеЗначение = "" Или ВыбранноеЗначение = """Нет""" Тогда
		Объект.ДатаИзмеренияПроверкиВыполнения = ПустаяДатаИзмерения;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗначениеПоказателяИзмеренияПриИзмененииНаСервере()
	ПустаяДатаИзмерения = (Объект.ДатаИзмеренияПроверкиВыполнения = Дата(1, 1, 1));
	Если ЗначениеЗаполнено(Объект.ВыполнениеОперации) 
		И Объект.ЗначениеПоказателяИзмерения <> 0 И ПустаяДатаИзмерения Тогда
		
		Объект.ДатаИзмеренияПроверкиВыполнения = ТекущаяДатаСеанса();
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура РезультатПроверкиПриИзмененииНаСервере()
	ПустаяДатаИзмерения = (Объект.ДатаИзмеренияПроверкиВыполнения = Дата(1, 1, 1));
	Если Объект.РезультатПроверки И ЗначениеЗаполнено(Объект.ВыполнениеОперации) 
	И  ПустаяДатаИзмерения Тогда
		Объект.ДатаИзмеренияПроверкиВыполнения = ТекущаяДатаСеанса();
	КонецЕсли;
КонецПроцедуры

&НаСервере
