&НаСервереБезКонтекста
Функция ВидыРемонтов(ОбъектЭксплуатации)
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("ОбъектЭксплуатации", ОбъектЭксплуатации);

	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОбъектыЭксплуатации.Класс КАК Класс
	|ПОМЕСТИТЬ вт_Классы
	|ИЗ
	|	Справочник.ОбъектыЭксплуатации КАК ОбъектыЭксплуатации
	|ГДЕ
	|	ОбъектыЭксплуатации.Ссылка = &ОбъектЭксплуатации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВидыРемонтов.Ссылка КАК ВидРемонта
	|ИЗ
	|	вт_Классы КАК вт_Классы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыРемонтов КАК ВидыРемонтов
	|		ПО (ВидыРемонтов.Владелец = вт_Классы.Класс)";

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат Результат.Выгрузить().ВыгрузитьКолонку("ВидРемонта");
	КонецЕсли;

КонецФункции

Процедура ОбновитьИсполнителейВНаряде(ЗаданиеНаРемонт)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаданиеНаРемонт", ЗаданиеНаРемонт);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	мп_НарядНаРемонтРаботы.Ссылка КАК НарядНаРемонт,
	|	мп_НарядНаРемонтРаботы.ИдентификаторСтроки КАК ИдентификаторСтроки
	|ИЗ
	|	Документ.мп_НарядНаРемонт.Работы КАК мп_НарядНаРемонтРаботы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.мп_ЗаданиеНаРемонт КАК мп_ЗаданиеНаРемонт
	|		ПО ((ВЫРАЗИТЬ(мп_НарядНаРемонтРаботы.Работа КАК Документ.мп_ЗаданиеНаРемонт)) = мп_ЗаданиеНаРемонт.Ссылка)
	|			И (&ЗаданиеНаРемонт = мп_ЗаданиеНаРемонт.Ссылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.мп_НарядНаРемонт КАК мп_НарядНаРемонт
	|		ПО (мп_НарядНаРемонтРаботы.Ссылка = мп_НарядНаРемонт.Ссылка)
	|ГДЕ
	|	НЕ мп_НарядНаРемонт.ПометкаУдаления";

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	НарядНаРемонт = Выборка.НарядНаРемонт.ПолучитьОбъект();
	
	ТЗИсполнители = НарядНаРемонт.Исполнители.Выгрузить();
	
	Отбор = Новый Структура;
	Отбор.Вставить("ИдентификаторСтрокиРаботы", Выборка.ИдентификаторСтроки);
	СтрокиИсполнителей = ТЗИсполнители.НайтиСтроки(Отбор);
	Для Каждого ТекСтрока Из СтрокиИсполнителей Цикл
		ТЗИсполнители.Удалить(ТекСтрока);
	КонецЦикла;
	Ответственные = Новый Массив;
	Для Каждого ТекСтрока Из Объект.Исполнители Цикл
		НоваяСтрока = ТЗИсполнители.Добавить();
		НоваяСтрока.Ответственный = ТекСтрока.Ответственный;
		НоваяСтрока.ИдентификаторСтрокиРаботы = Выборка.ИдентификаторСтроки;
		Ответственные.Добавить(ТекСтрока.Ответственный);
	КонецЦикла;
	НарядНаРемонт.Исполнители.Загрузить(ТЗИсполнители);
	Для Каждого ТекСтрока Из НарядНаРемонт.Работы Цикл
		Если ТекСтрока.ИдентификаторСтроки = Выборка.ИдентификаторСтроки Тогда
			ТекСтрока.Исполнители = СтрСоединить(Ответственные, ", ");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	НарядНаРемонт.Записать(РежимЗаписиДокумента.Запись);
	
КонецПроцедуры

#КонецОбласти