&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИменаСтраниц = Новый Массив;
	ИменаСтраниц.Добавить("ГруппаШапка");
	ИменаСтраниц.Добавить("ГруппаОсновная");
	ИменаСтраниц.Добавить("ГруппаОсновная2");
	ИменаСтраниц.Добавить("ГруппаФото");
	ИменаСтраниц.Добавить("ГруппаСписание");
	ИменаСтраниц.Добавить("ГруппаОприходование");
	ИменаСтраниц.Добавить("ГруппаИсполнители");
	ИменаСтраниц.Добавить("ГруппаДополнительно");
	
	ЭтотОбъект.КоличествоСтраниц = ИменаСтраниц.Количество() - 1;
	
	ТекущийИндексСтраницы = 0;
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
	ДоступностьРеквизитовНаКлиенте();
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
	ЭтотОбъект.ТекущийПользователь = РеквизитыКонстант["ТекущийПользователь"];
	Если Параметры.Ключ.Пустая() Тогда
		Объект.Подразделение = РеквизитыКонстант["ПодразделениеПользователя"];
		Объект.Ответственный = ЭтотОбъект.ТекущийПользователь;
		Объект.СтатусОбмена = Перечисления.мп_СтатусыОбмена.Создан;
		Объект.Источник = Перечисления.мп_ИсточникиДокументов.МечелТОиР;
	Иначе
		ЭтотОбъект.ТаблицаФотографии.Загрузить(Объект.Фотографии.Выгрузить());
		Для Каждого ТекСтрока Из ЭтотОбъект.ТаблицаФотографии Цикл
			ДвоичныеДанные = Base64Значение(ТекСтрока.Фото);
			АдресФото = ПоместитьВоВременноеХранилище(ДвоичныеДанные, ТекСтрока.ИдентификаторСтроки);
			ТекСтрока.ФотоПредставление = АдресФото;
		КонецЦикла;
	КонецЕсли;
	Если Параметры.Свойство("ОткрытИзНаряда") Тогда
		ЭтотОбъект.ОткрытИзНаряда = Параметры.ОткрытИзНаряда;
	КонецЕсли;
	Если Параметры.Свойство("НомерСтрокиНаряда") Тогда
		ЭтотОбъект.НомерСтрокиНаряда = Параметры.НомерСтрокиНаряда;
	КонецЕсли;
	
//	ДоступностьРеквизитов();

	ВидимостьРеквизитов();

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ЧтениеНаСервере();
	ВидимостьРеквизитов();
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ЧтениеНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)

	Если ИсточникВыбора.ИмяФормы = "Документ.мп_ЗаданиеНаРемонт.Форма.ФормаСтрокиСписания" Тогда

		ДанныеСтроки = Объект.МатериалыКСписанию.НайтиПоИдентификатору(ИсточникВыбора.НомерСтроки);
		Если ИсточникВыбора.СохранитьИзменения Тогда
	
			Модифицированность = Истина;

			ЗаполнитьЗначенияСвойств(ДанныеСтроки, ИсточникВыбора);
			ДанныеСтроки.ЭтоНоваяСтрока = Ложь;
			ЧтениеНаСервере();
		Иначе

			Если ДанныеСтроки.ЭтоНоваяСтрока Тогда
				НомерСтроки = Объект.МатериалыКСписанию.Количество();
				Объект.МатериалыКСписанию.Удалить(НомерСтроки - 1);
			КонецЕсли;

		КонецЕсли;
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Документ.мп_ЗаданиеНаРемонт.Форма.ФормаСтрокиОприходования" Тогда
		ДанныеСтроки = Объект.МатериалыКОприходованию.НайтиПоИдентификатору(ИсточникВыбора.НомерСтроки);
		Если ИсточникВыбора.СохранитьИзменения Тогда
	
			Модифицированность = Истина;

			ЗаполнитьЗначенияСвойств(ДанныеСтроки, ИсточникВыбора);
			ДанныеСтроки.ЭтоНоваяСтрока = Ложь;
			ЧтениеНаСервере();
		Иначе

			Если ДанныеСтроки.ЭтоНоваяСтрока Тогда
				НомерСтроки = Объект.МатериалыКОприходованию.Количество();
				Объект.МатериалыКОприходованию.Удалить(НомерСтроки - 1);
			КонецЕсли;

		КонецЕсли;
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Справочник.Пользователи.Форма.ФормаВыбораИзДокумента" Тогда
		ДанныеСтроки = Объект.Исполнители.НайтиПоИдентификатору(ИсточникВыбора.НомерСтроки);
		Если ИсточникВыбора.СохранитьИзменения Тогда
			Модифицированность = Истина;
			ВыбранныеИсполнители(ИсточникВыбора.Ответственный);
//			ДанныеСтроки.ЭтоНоваяСтрока = Ложь;
		//Иначе
		//	Если ДанныеСтроки.ЭтоНоваяСтрока Тогда
		//		НомерСтроки = Объект.Исполнители.Количество();
		//		Объект.Исполнители.Удалить(НомерСтроки - 1);
		//	КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ВыбранныеИсполнители(Знач ИсполнителиИзФормыПодбора)
	ТаблицаИсполнителей = Объект.Исполнители.Выгрузить();
	Для Каждого ИсполнительИзФормы Из ИсполнителиИзФормыПодбора Цикл
		Если ТаблицаИсполнителей.Найти(ИсполнительИзФормы.Значение, "Ответственный") = Неопределено Тогда
			НоваяСтрока = ТаблицаИсполнителей.Добавить();
			НоваяСтрока.Ответственный = ИсполнительИзФормы.Значение;
		КонецЕсли;
	КонецЦикла;
	Объект.Исполнители.Загрузить(ТаблицаИсполнителей);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		СписокОшибок = КонтрольОстатковМатериаловСписания();
		Если СписокОшибок.Количество() Тогда
			Отказ = Истина;
			СтрСообщение = "Превышен остаток:";
			РаздСтрок = Символы.ПС;
			Для Каждого ТекСтрока Из СписокОшибок Цикл
				ОписаниеОшибки = СтрШаблон("Для %1 на %2", ТекСтрока.Номенклатура, ТекСтрока.Факт - ТекСтрока.Остаток);
				СтрСообщение = СтрСообщение + РаздСтрок + ОписаниеОшибки;
			КонецЦикла;
			СтрСообщение = СтрСообщение +РаздСтрок + "Обновить остатки?";
			ОповещениеОшибки = Новый ОписаниеОповещения("ОбновлениеОстатков", ЭтотОбъект);
			ПоказатьВопрос(ОповещениеОшибки, СтрСообщение, РежимДиалогаВопрос.ДаНет, 60);
		Иначе
			ИзменитьСтатусОбмена();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)

	Если ЭтотОбъект.ОткрытИзНаряда Тогда
		ЗначениеФормы = Новый Структура;
		ЗначениеФормы.Вставить("ОткрытИзНаряда", ЭтотОбъект.ОткрытИзНаряда);
		ОповеститьОВыборе(ЗначениеФормы);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если Не ЭтотОбъект.ОткрытИзНаряда И ЗначениеЗаполнено(Объект.Ссылка) Тогда
		АктуальныеРежимы = Новый Массив;
		АктуальныеРежимы.Добавить(РежимЗаписиДокумента.Запись);
		АктуальныеРежимы.Добавить(РежимЗаписиДокумента.Проведение);
		Если Не АктуальныеРежимы.Найти(ПараметрыЗаписи.РежимЗаписи) = Неопределено Тогда
			ОбновитьИсполнителейВНаряде(Объект.Ссылка);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

