&НаСервереБезКонтекста
Функция ВычислитьРазностьДат(Знач ДатаНачала, Знач ДатаЗавершения)

	Разность = ДатаЗавершения - ДатаНачала;
	СекундВДне = 86400;
	СекундВЧасе = 3600;
	МинутВЧасе = 60;
	ЧислоДесять = 10;
	
	Если Разность > 0 Тогда
		Дней  = Цел(Разность / СекундВДне);
		Часов = Цел((Разность - Дней * СекундВДне) / СекундВЧасе);
		Минут = Цел(((Разность - (Дней * СекундВДне) - (Часов * СекундВЧасе))) / МинутВЧасе);
		
		Возврат ?(Дней > 0, Строка(Дней) + "дн.", "") + ?((Часов + Минут) > 0, " " + Строка(Часов) + ":" 
			+ ?(Минут < ЧислоДесять, "0", "") + Строка(Минут), ""); 
	Иначе
		Возврат "";
	КонецЕсли;

КонецФункции

