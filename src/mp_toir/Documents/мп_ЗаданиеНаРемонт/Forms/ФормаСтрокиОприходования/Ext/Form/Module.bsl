КонецПроцедуры

&НаКлиенте
Процедура СкладНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	Склады = ОбщегоНазначенияВызовСервера.СкладыПоКонстанте();
	Если Склады = Неопределено Тогда
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;
	МассивЭлементов = Новый Массив;
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", Склады);
	МассивЭлементов.Добавить(НовыйПараметр);
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);

КонецПроцедуры

&НаКлиенте
Процедура НоменклатураОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	ПустаяНоменклатура = ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
	ЭтоЗаменяемаяНоменклатура = ЗаданиеНаРемонтВызовСервераЛокализация.ЭтоИзменяемаяНоменклатура(
		ВыбранноеЗначение, ЭтотОбъект.ЗаменяемыеВидыНоменклатуры, ПустаяНоменклатура);

	Если ЭтоЗаменяемаяНоменклатура Тогда

		ВидНоменклатуры = ПредставлениеВидаНоменклатуры(ВыбранноеЗначение);
		ТекстСообщения = СтрШаблон("Номенклатуру с видом %1 нужно указывать в качестве заменяемой на закладке Материалы к списанию", ВидНоменклатуры);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		ВыбранноеЗначение = ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
		СтандартнаяОбработка = Истина;

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура НоменклатураПриИзменении(Элемент)
	ДоступностьРеквизитов();
КонецПроцедуры

&НаКлиенте
Процедура НоменклатураВозвратНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	СписокВосстановление = СписокНоменклатурыБрак(ЭтотОбъект.Номенклатура);

	Если СписокВосстановление.Количество() = 0 Тогда
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;

	МассивЭлементов = Новый Массив;
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", СписокВосстановление);
	МассивЭлементов.Добавить(НовыйПараметр);
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);

КонецПроцедуры

&НаКлиенте
Процедура НоменклатураВозвратПриИзменении(Элемент)
	ДоступностьРеквизитов();
КонецПроцедуры

