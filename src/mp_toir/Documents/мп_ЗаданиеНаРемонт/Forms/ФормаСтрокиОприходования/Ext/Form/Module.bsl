
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ИменаЭлементов = "Номенклатура, Характеристика, Серия, Склад, Количество, НоменклатураВозврат, ХарактеристикаВозврат"
		+ ", СерияВозврат, СтатусУказанияСерий, Источник, СтатусОбмена, ТолькоПросмотр, НомерСтроки, ОбъектЭксплуатации"
		+ ", ВыбранныйУзел";

	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры, ИменаЭлементов);
	ЭтотОбъект.МатериалыКОприходованию.Загрузить(Параметры.МатериалыКОприходованию.Выгрузить());
	ЭтотОбъект.МатериалыКСписанию.Загрузить(Параметры.МатериалыКСписанию.Выгрузить());
	
	ЗаданиеНаРемонтВызовСервераЛокализация.ЗаполнитьСписокИзменяемыхВидовНоменклатуры(ЭтотОбъект);

	ДоступностьРеквизитов();

КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	ЗначенияСтроки = Новый Структура;
	ЗначенияСтроки.Вставить("Номенклатура", ЭтотОбъект.Номенклатура);
	ЗначенияСтроки.Вставить("Характеристика", ЭтотОбъект.Характеристика);
	ЗначенияСтроки.Вставить("Серия", ЭтотОбъект.Серия);
	ЗначенияСтроки.Вставить("Склад", ЭтотОбъект.Склад);
	ЗначенияСтроки.Вставить("НоменклатураВозврат", ЭтотОбъект.НоменклатураВозврат);
	ЗначенияСтроки.Вставить("ХарактеристикаВозврат", ЭтотОбъект.ХарактеристикаВозврат);
	ЗначенияСтроки.Вставить("Количество", ЭтотОбъект.Количество);
	ЗначенияСтроки.Вставить("НомерСтроки", ЭтотОбъект.НомерСтроки);
	ЗначенияСтроки.Вставить("СохранитьИзменения", ЭтотОбъект.СохранитьИзменения);
	ОповеститьОВыборе(ЗначенияСтроки);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ИсточникВыбора.ИмяФормы = "Документ.мп_ЗаданиеНаРемонт.Форма.ФормаУстановленныеТМЦ" Тогда
		Если ИсточникВыбора.СохранитьИзменения Тогда
			ЭтотОбъект.Номенклатура = ИсточникВыбора.ВыбраннаяНоменклатура;
			ЭтотОбъект.Характеристика = ИсточникВыбора.ВыбраннаяХарактеристика;
			ЭтотОбъект.Серия = ИсточникВыбора.ВыбраннаяСерия;
			Если Не ЗначениеЗаполнено(ЭтотОбъект.НоменклатураВозврат) Тогда
				СписокВосстановление = СписокНоменклатурыБрак(ЭтотОбъект.Номенклатура);
				Если СписокВосстановление.Количество() = 1 Тогда
					ЭтотОбъект.НоменклатураВозврат = СписокВосстановление[0];
				КонецЕсли;
			КонецЕсли;
			Если ЗначениеЗаполнено(ЭтотОбъект.НоменклатураВозврат) И Не ЗначениеЗаполнено(ЭтотОбъект.ХарактеристикаВозврат) Тогда
				Характеристики = ОбщегоНазначенияВызовСервера.ХарактеристикиПоНоменклатуре(ЭтотОбъект.НоменклатураВозврат);
				Если Не Характеристики = Неопределено Тогда
					ЭтотОбъект.ХарактеристикаВозврат = ЭтотОбъект.Характеристика;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ХарактеристикаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(ЭтотОбъект.Номенклатура) Тогда
		МассивЭлементов = Новый Массив;
		Характеристики = ОбщегоНазначенияВызовСервера.ХарактеристикиПоНоменклатуре(ЭтотОбъект.Номенклатура);
		Если Не Характеристики = Неопределено Тогда
			НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", Характеристики);
			МассивЭлементов.Добавить(НовыйПараметр);
		Иначе
			СтандартнаяОбработка = Ложь;
			Возврат;
		КонецЕсли;
		Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);
	Иначе 
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
КонецПроцедуры

