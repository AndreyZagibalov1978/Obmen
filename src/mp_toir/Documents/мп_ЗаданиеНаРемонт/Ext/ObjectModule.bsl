	//ОшибкиОприходования = Новый Массив;
	//Пока ВыборкаНоменклатура.Следующий() Цикл
	//	
	//	ИмяНоменклатуры = СокрЛП(ВыборкаНоменклатура.Номенклатура.Наименование);
	//	ОшибкиСтроки = Новый Массив;
	//	ВыборкаДетальныеЗаписи = ВыборкаНоменклатура.Выбрать();
	//	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	//		ОшибкиСтроки.Добавить(ВыборкаДетальныеЗаписи.Ошибка);
	//	КонецЦикла;
	//	ОшибкиОприходования.Добавить(ИмяНоменклатуры 
	//		+ ":  " +СтрСоединить(ОшибкиСтроки, ", "));
	//КонецЦикла;
	
	//СписокОшибок.Вставить("ОшибкиОприходования", ОшибкиОприходования);
	
	Возврат СписокОшибок;

КонецФункции

Функция ЕстьФото()

	Если Не ФотоотчетОбязателен Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Фотографии.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	Фотографии.УдалитьСтроку КАК УдалитьСтроку
	|ПОМЕСТИТЬ вт_Фотографии
	|ИЗ
	|	&Фотографии КАК Фотографии
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИСТИНА КАК ЕстьФото
	|ИЗ
	|	вт_Фотографии КАК вт_Фотографии
	|ГДЕ
	|	НЕ вт_Фотографии.УдалитьСтроку";
	
	Запрос.УстановитьПараметр("Фотографии", Фотографии);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();

КонецФункции

Функция НоменклатураБезЗамены(ЗаменяемыеВидыНоменклатуры)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаменяемыеВидыНоменклатуры", ЗаменяемыеВидыНоменклатуры);
	Запрос.УстановитьПараметр("ТЗСписаниеМатериалов", МатериалыКСписанию);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.Характеристика КАК Справочник.ХарактеристикиНоменклатуры) КАК Характеристика,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.Серия КАК Справочник.СерииНоменклатуры) КАК Серия,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.Склад КАК Справочник.Склады) КАК Склад,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.ЗаменаНоменклатура КАК Справочник.Номенклатура) КАК ЗаменаНоменклатура,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.ЗаменаХарактеристика КАК Справочник.ХарактеристикиНоменклатуры) КАК ЗаменаХарактеристика,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.ЗаменаСерия КАК Справочник.СерииНоменклатуры) КАК ЗаменаСерия,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.План КАК ЧИСЛО(15, 3)) КАК План,
	|	ВЫРАЗИТЬ(ТЗСписаниеМатериало.Факт КАК ЧИСЛО(15, 3)) КАК Факт
	|ПОМЕСТИТЬ вт_СписаниеМатериалов
	|ИЗ
	|	&ТЗСписаниеМатериалов КАК ТЗСписаниеМатериало
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(вт_СписаниеМатериалов.Номенклатура) КАК Номенклатура
	|ИЗ
	|	Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_СписаниеМатериалов КАК вт_СписаниеМатериалов
	|		ПО ВидыНоменклатуры.Ссылка = вт_СписаниеМатериалов.Номенклатура.ВидНоменклатуры
	|ГДЕ
	|	ВидыНоменклатуры.Ссылка В(&ЗаменяемыеВидыНоменклатуры)
	|	И вт_СписаниеМатериалов.ЗаменаНоменклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)";

	Результат = Запрос.Выполнить();
	Возврат Результат;
КонецФункции

#КонецОбласти

#Иначе

	ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
	
