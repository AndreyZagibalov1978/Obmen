#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Ошибки = Неопределено;
	
	АдминТОиР = РольДоступна("мп_АдминистрированиеТОиР");
	Если АдминТОиР Тогда
		Возврат;
	КонецЕсли;
	
	СписокОшибок = ЗапретПроведения();
	
	ПС = Символы.ПС;
	Таб = " ~";
	
	//Если СписокОшибок.МатериалыКОприходованию Тогда
	//	ОшибкаМатериалыКОприходованию = "Ошибки в оприходовании:";
	//	Для Каждого СтрОшибка Из СписокОшибок.ОшибкиОприходования Цикл
	//		ОшибкаМатериалыКОприходованию = ОшибкаМатериалыКОприходованию +ПС + Таб + СтрОшибка;
	//	КонецЦикла;
	//	ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, , ОшибкаМатериалыКОприходованию);
	//КонецЕсли;
	
	Если СписокОшибок.НетВидПроверки Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, , "Укажите вид проверки");
	КонецЕсли;
	
	Если СписокОшибок.НетРезультатПроверки Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, , "Укажите результат проверки");
	КонецЕсли;

	Если СписокОшибок.НетЗаменыНоменклатуры Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, , "Укажите заменяемую номенклатуру в материалах для списания:");
		Для Каждого ТекСтрока Из СписокОшибок.НоменклатураДляЗамены Цикл
			СтрОшибка = Таб +ТекСтрока;
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, , СтрОшибка);
		КонецЦикла;
	КонецЕсли;
	
	Если Не СписокОшибок.ЕстьФото Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, , "Прикрепите фото");
	КонецЕсли;

	Если Не Ошибки = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки, Отказ);
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	НарядНаРемонтВызовСервераЛокализация.ПроверкаСтатусаНарядаНаРемонт(Ссылка);
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	СтатусОбмена = Перечисления.мп_СтатусыОбмена.КВыгрузкеВКИС;
КонецПроцедуры

Процедура ПриЗаписи(Отказ)

	Если ЭтотОбъект.СтатусОбмена = Перечисления.мп_СтатусыОбмена.КВыгрузкевКИС Тогда
		УзелЦентральнойБазы = ОбщегоНазначенияПовтИсп.ПолучитьУзелЦентральнойБазы();
		ПланыОбмена.ЗарегистрироватьИзменения(УзелЦентральнойБазы, ЭтотОбъект);
	КонецЕсли;

КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ВыполнениеОперации = "";
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЗапретПроведения()
	СписокОшибок = Новый Структура;
	СписокОшибок.Вставить("НетВидПроверки", Ложь);
	
	Если ЗначениеЗаполнено(НаименованиеРабот)  Тогда
		Мечел_ИзмерениеОбязательно = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НаименованиеРабот, "Мечел_ИзмерениеОбязательно");
		Если Мечел_ИзмерениеОбязательно Тогда
			СписокОшибок.НетВидПроверки = Не ЗначениеЗаполнено(ВидПроверки);
		КонецЕсли;
	КонецЕсли;
	
	СписокОшибок.Вставить("НетРезультатПроверки", Ложь);
	Если ЗначениеЗаполнено(ВидПроверки) Тогда
		СписокОшибок.НетРезультатПроверки = Не РезультатПроверки;
	КонецЕсли;

	ЗаменяемыеВидыНоменклатуры = 
		ЗаданиеНаРемонтВызовСервераЛокализация.ЗаменяемыеВидыНоменклатуры();
	СписокОшибок.Вставить("НетЗаменыНоменклатуры", Ложь);
	Если ЗаменяемыеВидыНоменклатуры.Количество() Тогда
		Результат = НоменклатураБезЗамены(ЗаменяемыеВидыНоменклатуры);
		СписокОшибок.НетЗаменыНоменклатуры = Не Результат.Пустой();
		НоменклатураДляЗамены = Новый Массив;
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоменклатураДляЗамены.Добавить(Выборка.Номенклатура);
		КонецЦикла;
		СписокОшибок.Вставить("НоменклатураДляЗамены", НоменклатураДляЗамены);
	КонецЕсли;
	
	СписокОшибок.Вставить("ЕстьФото", ЕстьФото());

	//Результат = ПроверкаМатериаловКОприходованию();
	//
	//СписокОшибок.Вставить("МатериалыКОприходованию", Не Результат.Пустой());
