// Выбрать изменения (регистрация) документа ОрдерНаОтражениеИзлишковТоваров
//
// Возвращаемое значение:
//  РезультатЗапроса, Неопределено - Результат запроса.
//
Функция ВыбратьИзменения() Экспорт

	Запрос = Новый Запрос;

	Запрос.Текст =
	"ВЫБРАТЬ
	|	мп_РегистрацияПроверокОборудования.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.мп_РегистрацияПроверокОборудования.Изменения КАК мп_РегистрацияПроверокОборудования
	|ГДЕ
	|	мп_РегистрацияПроверокОборудования.Ссылка.Проведен";
	
	РезультатЗапроса = Запрос.Выполнить();

	Возврат РезультатЗапроса;

КонецФункции

