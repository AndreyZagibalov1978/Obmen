#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Страница1(Команда)
	НовыйИндекс = Макс(ТекущийИндексСтраницы - 1, 0);
	ТекущийИндексСтраницы = НовыйИндекс;
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
КонецПроцедуры

&НаКлиенте
Процедура Страница2(Команда)
	НовыйИндекс = Мин(ТекущийИндексСтраницы + 1, ЭтотОбъект.КоличествоСтраниц);
	ТекущийИндексСтраницы = НовыйИндекс;
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьСтроку(Команда)

	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;

	СтрокаИсходная = Элементы.Проверки.ТекущиеДанные;
	Строка = Объект.Проверки.Добавить();
	Строка.ЭтоНоваяСтрока = Истина;
	ЗаполнитьЗначенияСвойств(Строка, СтрокаИсходная, "ТехнологическоеМесто, ОбъектЭксплуатации, УзелОбъектаЭксплуатации");
	ОткрытьФормуРедактирования(Строка);

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьСтроку(Команда)

	Строка = Элементы.Проверки.ТекущиеДанные;
	Строка.ЭтоНоваяСтрока = Ложь;
	ОткрытьФормуРедактирования(Строка);

КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтроку(Команда)

	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	ИндексСтроки = Элементы.Проверки.ТекущиеДанные.НомерСтроки - 1;
	Объект.Проверки.Удалить(ИндексСтроки);

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПроверку(Команда)

	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	Строка = Объект.Проверки.Добавить();
	Строка.ЭтоНоваяСтрока = Истина;

	ОткрытьФормуРедактирования(Строка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОткрытьФормуРедактирования(Строка)
	
	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("НомерСтроки", Строка.ПолучитьИдентификатор());
	ДанныеСтроки.Вставить("ТехнологическоеМесто", Строка.ТехнологическоеМесто);
	ДанныеСтроки.Вставить("ОбъектЭксплуатации", Строка.ОбъектЭксплуатации);
	ДанныеСтроки.Вставить("УзелОбъектаЭксплуатации", Строка.УзелОбъектаЭксплуатации);
	ДанныеСтроки.Вставить("ВидПроверки", Строка.ВидПроверки);
	ДанныеСтроки.Вставить("Комментарий", Строка.Комментарий);
	ДанныеСтроки.Вставить("РезультатПроверки", Строка.РезультатПроверки);
	ДанныеСтроки.Вставить("ТолькоПросмотр", ЭтотОбъект.ТолькоПросмотр);

	ОткрытьФорму("Документ.мп_РегистрацияПроверокОборудования.Форма.ФормаСтрокиПроверки",
		ДанныеСтроки, ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

&НаСервере
Процедура ЧтениеНаСервере()

	Проверки = РеквизитыТаблицыПроверки(Объект.Проверки);
	
	Если Не Проверки = Неопределено Тогда
		
		Для Каждого ТекПроверка Из Объект.Проверки Цикл
			Если ЗначениеЗаполнено(ТекПроверка.УзелОбъектаЭксплуатации) Тогда
				ТекПроверка.ТехнологическоеМесто = Проверки.Найти(ТекПроверка.УзелОбъектаЭксплуатации).ТехнологическоеМесто;
				ТекПроверка.ОбъектЭксплуатации = Проверки.Найти(ТекПроверка.УзелОбъектаЭксплуатации).ОбъектЭксплуатации;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция РеквизитыТаблицыПроверки(Знач Проверки)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗПроверки.УзелОбъектаЭксплуатации КАК УзелОбъектаЭксплуатации
	|ПОМЕСТИТЬ вт_УзлыОС
	|ИЗ
	|	&ТЗПроверки КАК ТЗПроверки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УзлыОбъектовЭксплуатации.Ссылка КАК УзелОбъектаЭксплуатации,
	|	УзлыОбъектовЭксплуатации.Владелец КАК ОбъектЭксплуатации,
	|	ОбъектыЭксплуатации.ТехнологическоеМесто КАК ТехнологическоеМесто
	|ИЗ
	|	вт_УзлыОС КАК вт_УзлыОС
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УзлыОбъектовЭксплуатации КАК УзлыОбъектовЭксплуатации
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОбъектыЭксплуатации КАК ОбъектыЭксплуатации
	|			ПО УзлыОбъектовЭксплуатации.Владелец = ОбъектыЭксплуатации.Ссылка
	|		ПО вт_УзлыОС.УзелОбъектаЭксплуатации = УзлыОбъектовЭксплуатации.Ссылка";
	
	Запрос.УстановитьПараметр("ТЗПроверки", Проверки.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат РезультатЗапроса.Выгрузить();
	КонецЕсли;

КонецФункции

&НаСервереБезКонтекста
Функция ЕстьДублиДанныхСтроки(Знач Проверки, ТекстОшибки)

	ТЗПроверки = Проверки.Выгрузить();
	
	Если ТЗПроверки.Количество() < 2 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗПроверки.ИсходныйНомерСтроки КАК ИсходныйНомерСтроки,
	|	ТЗПроверки.НомерСтроки КАК НомерСтроки,
	|	ТЗПроверки.УзелОбъектаЭксплуатации КАК УзелОбъектаЭксплуатации,
	|	ТЗПроверки.ВидПроверки КАК ВидПроверки,
	|	ТЗПроверки.Комментарий КАК Комментарий,
	|	ТЗПроверки.РезультатПроверки КАК РезультатПроверки,
	|	1 КАК КоличествоПовторов
	|ПОМЕСТИТЬ вт_Проверки
	|ИЗ
	|	&ТЗПроверки КАК ТЗПроверки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_Проверки.УзелОбъектаЭксплуатации КАК УзелОбъектаЭксплуатации,
	|	вт_Проверки.ВидПроверки КАК ВидПроверки,
	|	СУММА(вт_Проверки.КоличествоПовторов) КАК КоличествоПовторов
	|ПОМЕСТИТЬ вт_дубли
	|ИЗ
	|	вт_Проверки КАК вт_Проверки
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_Проверки.УзелОбъектаЭксплуатации,
	|	вт_Проверки.ВидПроверки
	|
	|ИМЕЮЩИЕ
	|	СУММА(вт_Проверки.КоличествоПовторов) > 1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_Проверки.НомерСтроки КАК НомерСтроки,
	|	вт_Проверки.УзелОбъектаЭксплуатации КАК УзелОбъектаЭксплуатации,
	|	вт_Проверки.ВидПроверки КАК ВидПроверки
	|ИЗ
	|	вт_Проверки КАК вт_Проверки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_дубли КАК вт_дубли
	|		ПО (вт_дубли.УзелОбъектаЭксплуатации = вт_Проверки.УзелОбъектаЭксплуатации)
	|			И (вт_дубли.ВидПроверки = вт_Проверки.ВидПроверки)";

	Запрос.УстановитьПараметр("ТЗПроверки", ТЗПроверки);
	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат Ложь;
		
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	
	Выборка.Следующий();
		ТекстОшибки = СтрШаблон(
			"В строке %1 узел %2 по виду проверки %3 дубль строки", 
			Выборка.НомерСтроки, Выборка.УзелОбъектаЭксплуатации, Выборка.ВидПроверки);

	Возврат Истина;

КонецФункции

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	ТекстОшибки = "";
	Если ЕстьДублиДанныхСтроки(Объект.Проверки, ТекстОшибки) Тогда
		Отказ = Истина;
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы)
	ИмяСтраницы = ИменаСтраниц[ТекущийИндексСтраницы];
	Страница = Элементы.Найти(ИмяСтраницы);
	Если Страница = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Элементы.ПредставлениеСтраницы.Заголовок = Страница.Заголовок;
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Страница;
	ЗаголовокГруппыСтраниц = СтрШаблон("Всего: %1 этапа", ЭтотОбъект.КоличествоСтраниц + 1);
	Элементы.ГруппаКнопкиСтраниц.Заголовок = ЗаголовокГруппыСтраниц;
КонецПроцедуры

#КонецОбласти