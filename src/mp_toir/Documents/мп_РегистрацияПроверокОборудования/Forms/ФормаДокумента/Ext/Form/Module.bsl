#Область ОписаниеПеременных

&НаКлиенте
Перем ИменаСтраниц;

&НаКлиенте
Перем ТекущийИндексСтраницы;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ИменаСтраниц = Новый Массив;
	ИменаСтраниц.Добавить("ГруппаПроверки");
	ИменаСтраниц.Добавить("ГруппаОсновная");
	
	ЭтотОбъект.КоличествоСтраниц = ИменаСтраниц.Количество() - 1;

	ТекущийИндексСтраницы = 0;
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Ключ.Пустая() Тогда

		РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
		Объект.Организация = РеквизитыКонстант["ОрганизацияПользователя"];
		Объект.Подразделение = РеквизитыКонстант["ПодразделениеПользователя"];
		Объект.Ответственный = РеквизитыКонстант["ТекущийПользователь"];
		Объект.СтатусОбмена = Перечисления.мп_СтатусыОбмена.Создан;

	Иначе

		ТолькоПросмотр = 
			Не ОбщегоНазначенияВызовСервера.РедактированиеФормыДокументаТОиР(
				Объект.Подразделение, Объект.Ответственный, Объект.СтатусОбмена);
			
		ЭтотОбъект.ТолькоПросмотр = ТолькоПросмотр;

	КонецЕсли;

	ЧтениеНаСервере();

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	ЧтениеНаСервере();

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ЧтениеНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)

	Если ИсточникВыбора.ИмяФормы = "Документ.мп_РегистрацияПроверокОборудования.Форма.ФормаСтрокиПроверки" Тогда

		ДанныеСтроки = Объект.Проверки.НайтиПоИдентификатору(ИсточникВыбора.НомерСтроки);
		Если ИсточникВыбора.СохранитьИзменения Тогда
			
			Модифицированность = Истина;
			
			ЗаполнитьЗначенияСвойств(ДанныеСтроки, ИсточникВыбора);
			ДанныеСтроки.ЭтоНоваяСтрока = Ложь;
			ЧтениеНаСервере();
		ИначеЕсли ДанныеСтроки.ЭтоНоваяСтрока Тогда
			
			НомерСтроки = Объект.Проверки.Количество();
			Объект.Проверки.Удалить(НомерСтроки - 1);
			
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	ТекущийИндексСтраницы = ИменаСтраниц.Найти(ТекущаяСтраница.Имя);
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПроверки

&НаКлиенте
Процедура ПроверкиПередНачаломИзменения(Элемент, Отказ)

	Отказ = Истина;

КонецПроцедуры

