#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Ключ.Пустая() Тогда
		РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
		Объект.Подразделение = РеквизитыКонстант["ПодразделениеПользователя"];
		Объект.Ответственный = РеквизитыКонстант["ТекущийПользователь"];
		Объект.СтатусОбмена = Перечисления.мп_СтатусыОбмена.Создан;
		Объект.Статус = Перечисления.СтатусыНарядаНаРемонт.Создан;
	КонецЕсли;

	ДоступностьРеквизитов();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	ЧтениеНаСервере();

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ЧтениеНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ИсточникВыбора.ИмяФормы = "Документ.мп_НарядНаРемонт.Форма.ФормаРедактированияСтрокиРабота" Тогда
		ДанныеСтроки = Объект.Работы.НайтиПоИдентификатору(ИсточникВыбора.НомерСтроки);
		Если ДанныеСтроки = Неопределено Тогда
			Возврат;
		КонецЕсли;
		Если ИсточникВыбора.СохранитьИзменения Тогда
			Модифицированность = Истина;
			ЗаполнитьЗначенияСвойств(ДанныеСтроки, ИсточникВыбора, "Работа");
			ДанныеСтроки.Исполнители = ОбновитьИсполнителей(ИсточникВыбора.Исполнители, ДанныеСтроки.ИдентификаторСтроки);
			ЧтениеНаСервере();
		Иначе
			Если ДанныеСтроки.ЭтоНоваяСтрока Тогда
				НомерСтроки = Объект.Работы.Количество();
				Объект.Работы.Удалить(НомерСтроки - 1);
				ЧтениеНаСервере();
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Документ.РегистрацияДефекта.Форма.ФормаПодборДляНаряда"
		Или ИсточникВыбора.ИмяФормы = "Документ.мп_ЗаданиеНаРемонт.Форма.ФормаПодборДляНаряда" Тогда
		Если ИсточникВыбора.СохранитьИзменения Тогда
			Модифицированность = Истина;
			ЗаполнитьИзПодбора(ИсточникВыбора.ВыбранныеДокументы);
			ЧтениеНаСервере();
		КонецЕсли;
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Документ.РегистрацияДефекта.Форма.ФормаДокумента"
		Или ИсточникВыбора.ИмяФормы = "Документ.мп_ЗаданиеНаРемонт.Форма.ФормаДокумента" Тогда
		Если ИсточникВыбора.ОткрытИзНаряда Тогда
			ЭтотОбъект.Прочитать();
			ЭтотОбъект.ОбновитьОтображениеДанных();
			Если ТипЗнч(ИсточникВыбора.Объект.Ссылка) = Тип("ДокументСсылка.мп_ЗаданиеНаРемонт") Тогда
				ДанныеСтроки = Объект.Работы.НайтиПоИдентификатору(ИсточникВыбора.НомерСтрокиНаряда);
				ДанныеСтроки.Исполнители = ОбновитьИсполнителей(
					ИсточникВыбора.Объект.Исполнители, ДанныеСтроки.ИдентификаторСтроки);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Справочник.Пользователи.Форма.ФормаВыбораИзДокумента" Тогда
		Если ИсточникВыбора.СохранитьИзменения Тогда
			Модифицированность = Истина;
			ВыбранныеИсполнители(ИсточникВыбора.Ответственный);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыРаботы

&НаКлиенте
Процедура ДобавитьРаботу(Команда)
	ДобавитьРаботуНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура РаботыПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры


&НаКлиенте
Процедура ИзменитьРаботу(Команда)
	Строка = Элементы.Работы.ТекущиеДанные;
	Строка.ЭтоНоваяСтрока = Ложь;
	ОткрытьФормуРедактированияСтрокаРабота(Строка);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьРаботу(Команда)
	ИндексСтроки = Элементы.Работы.ТекущиеДанные.НомерСтроки - 1;
	УдалитьИсполнителей(Элементы.Работы.ТекущиеДанные.ИдентификаторСтроки);
	Объект.Работы.Удалить(ИндексСтроки);
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Асинх Процедура ПодборРабот(Команда)

	СписокВыбора = Новый СписокЗначений;
	СписокВыбора.Добавить("Регистрация дефекта");
	СписокВыбора.Добавить("Задание на ремонт");
	ВыбранноеЗначение = Ждать СписокВыбора.ВыбратьЭлементАсинх("Вид документа");
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДляФормы = Новый Структура;
	ДанныеДляФормы.Вставить("Подразделение", Объект.Подразделение);
	ДанныеДляФормы.Вставить("ИсключаемыеДокументы", ИсключатьИзПодбора(ВыбранноеЗначение.Значение));
	Если ВыбранноеЗначение.Значение = "Регистрация дефекта" Тогда
		ДанныеДляФормы.Вставить("Статус", ПредопределенноеЗначение("Перечисление.СтатусыДефектов.Зарегистрирован"));
		ОткрытьФорму("Документ.РегистрацияДефекта.Форма.ФормаПодборДляНаряда",
			ДанныеДляФормы, ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	ИначеЕсли ВыбранноеЗначение.Значение = "Задание на ремонт" Тогда
		
		ОткрытьФорму("Документ.мп_ЗаданиеНаРемонт.Форма.ФормаПодборДляНаряда",
			ДанныеДляФормы, ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьРаботу(Команда)
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			"Перед открытием работы запишите наряд");
		Возврат;
	КонецЕсли;
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			"Перед открытием работы запишите наряд");
		Возврат;
	КонецЕсли;
	РаботаСсылка = Элементы.Работы.ТекущиеДанные.Работа;
	Если ЗначениеЗаполнено(РаботаСсылка) Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ключ", РаботаСсылка);
		ПараметрыФормы.Вставить("ОткрытИзНаряда", Истина);
		ПараметрыФормы.Вставить("НомерСтрокиНаряда", Элементы.Работы.ТекущиеДанные.ПолучитьИдентификатор());
		
		ОткрытьФорму("Документ." + ИмяДокументаПоСсылке(РаботаСсылка) + ".ФормаОбъекта", ПараметрыФормы,
			ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаполнитьИсполнителей(Команда)
	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("НомерСтроки", Новый УникальныйИдентификатор);
	ДанныеСтроки.Вставить("ТаблицаРаботы", Истина);
	ПраваДоступа = ОбщегоНазначенияВызовСервера.ДоступныеПрава();
	Если Не ПраваДоступа.АдминТОиР Тогда
		ДанныеСтроки.Вставить("Подразделение", Объект.Подразделение);
	КонецЕсли;

	ОткрытьФорму("Справочник.Пользователи.Форма.ФормаВыбораИзДокумента",
		ДанныеСтроки, ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Процедура ВыбранныеИсполнители(Знач ИсполнителиИзФормыПодбора)

	ТЗИсполнители = Объект.Исполнители.Выгрузить();
	Для Каждого ТекРабота Из Объект.Работы Цикл
		Отбор = Новый Структура;
		Отбор.Вставить("ИдентификаторСтрокиРаботы", ТекРабота.ИдентификаторСтроки);
		НайденныеИсполнители = ТЗИсполнители.НайтиСтроки(Отбор);
		Для Каждого ТекИсполнитель Из НайденныеИсполнители Цикл
			ТЗИсполнители.Удалить(ТекИсполнитель);
		КонецЦикла;
		Ответственные = Новый Массив;
		Для Каждого ИсполнительИзФормы Из ИсполнителиИзФормыПодбора Цикл
			Ответственные.Добавить(Строка(ИсполнительИзФормы));
			НоваяСтрока = ТЗИсполнители.Добавить();
			НоваяСтрока.ИдентификаторСтрокиРаботы = ТекРабота.ИдентификаторСтроки;
			НоваяСтрока.Ответственный = ИсполнительИзФормы.Значение;
		КонецЦикла;
		ТекРабота.Исполнители = СтрСоединить(Ответственные, ", ");
	КонецЦикла;
	Объект.Исполнители.Загрузить(ТЗИсполнители);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИмяДокументаПоСсылке(Знач ДокументСсылка)

	Возврат ДокументСсылка.Метаданные().Имя;

КонецФункции

&НаСервере
Функция ИсключатьИзПодбора(Знач ВыбранноеЗначение)
	ТЗРаботы = Объект.Работы.Выгрузить();
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗРаботы.Работа КАК Работа
	|ПОМЕСТИТЬ вт_Работы
	|ИЗ
	|	&ТЗРаботы КАК ТЗРаботы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Работы.Работа КАК Работа,
	|	""Из ТЗРабота регистрация дефекта"" КАК Пояснение
	|ИЗ
	|	вт_Работы КАК вт_Работы
	|ГДЕ
	|	&ВыбранноеЗначение ПОДОБНО ""%Регистрация дефекта%""
	|	И вт_Работы.Работа ССЫЛКА Документ.РегистрацияДефекта
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Работы.Работа,
	|	""Из ТЗРабота задание на ремонт""
	|ИЗ
	|	вт_Работы КАК вт_Работы
	|ГДЕ
	|	&ВыбранноеЗначение ПОДОБНО ""%Задание на ремонт%""
	|	И вт_Работы.Работа ССЫЛКА Документ.мп_ЗаданиеНаРемонт
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	мп_НарядНаРемонтРаботы.Работа,
	|	""в других нарядах ищем регистр дефекта""
	|ИЗ
	|	Документ.мп_НарядНаРемонт.Работы КАК мп_НарядНаРемонтРаботы
	|ГДЕ
	|	&ВыбранноеЗначение ПОДОБНО ""%Регистрация дефекта%""
	|	И мп_НарядНаРемонтРаботы.Работа ССЫЛКА Документ.РегистрацияДефекта
	|	И НЕ мп_НарядНаРемонтРаботы.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	мп_НарядНаРемонтРаботы.Работа,
	|	""в других нарядах ищем зад на ремонт""
	|ИЗ
	|	Документ.мп_НарядНаРемонт.Работы КАК мп_НарядНаРемонтРаботы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.мп_ЗаданиеНаРемонт КАК мп_ЗаданиеНаРемонт
	|		ПО ((ВЫРАЗИТЬ(мп_НарядНаРемонтРаботы.Работа КАК Документ.мп_ЗаданиеНаРемонт)) = мп_ЗаданиеНаРемонт.Ссылка)
	|			И (НЕ мп_ЗаданиеНаРемонт.ВыполнениеОперации = """"""Нет"""""")
	|ГДЕ
	|	&ВыбранноеЗначение ПОДОБНО ""%Задание на ремонт%""
	|	И НЕ мп_НарядНаРемонтРаботы.Ссылка = &ТекущийДокумент
	|	И НЕ мп_НарядНаРемонтРаботы.Ссылка.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ВыбранноеЗначение", ВыбранноеЗначение);
	Запрос.УстановитьПараметр("ТЗРаботы", ТЗРаботы);
	Запрос.УстановитьПараметр("ТекущийДокумент", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();

	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Работа");
	
КонецФункции

&НаСервере
Процедура ЗаполнитьИзПодбора(Знач ВыбранныеДокументы)
	
	Для Каждого ТекСтрока Из ВыбранныеДокументы Цикл
		НоваяСтрока = Объект.Работы.Добавить();
		НоваяСтрока.ИдентификаторСтроки = Строка(Новый УникальныйИдентификатор());
		НоваяСтрока.Работа = ТекСтрока.Значение;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьИсполнителей(Знач ИдентификаторСтроки)

	ТЗИсполнители = Объект.Исполнители.Выгрузить();

	Отбор = Новый Структура;
	Отбор.Вставить("ИдентификаторСтрокиРаботы", ИдентификаторСтроки);
	СтрокиИсполнителей = ТЗИсполнители.НайтиСтроки(Отбор);
	Для Каждого ТекСтрока Из СтрокиИсполнителей Цикл
		ТЗИсполнители.Удалить(ТекСтрока);
	КонецЦикла;
	Объект.Исполнители.Загрузить(ТЗИсполнители);

КонецПроцедуры

&НаСервере
Функция ОбновитьИсполнителей(Знач ИсполнителиПоРаботе, Знач ИдентификаторСтрокиПоРаботе)
	ТЗИсполнители = Объект.Исполнители.Выгрузить();
	
	Отбор = Новый Структура;
	Отбор.Вставить("ИдентификаторСтрокиРаботы", ИдентификаторСтрокиПоРаботе);
	СтрокиИсполнителей = ТЗИсполнители.НайтиСтроки(Отбор);
	Для Каждого ТекСтрока Из СтрокиИсполнителей Цикл
		ТЗИсполнители.Удалить(ТекСтрока);
	КонецЦикла;
	Ответственные = Новый Массив;
	Для Каждого ТекСтрока Из ИсполнителиПоРаботе Цикл
		НоваяСтрока = ТЗИсполнители.Добавить();
		НоваяСтрока.Ответственный = ТекСтрока.Ответственный;
		НоваяСтрока.ИдентификаторСтрокиРаботы = ИдентификаторСтрокиПоРаботе;
		Ответственные.Добавить(ТекСтрока.Ответственный);
	КонецЦикла;
	Объект.Исполнители.Загрузить(ТЗИсполнители);
	
	Возврат СтрСоединить(Ответственные, ", ");
	
КонецФункции

&НаКлиенте
Процедура ДобавитьРаботуНаСервере()
	СтрокаРабота = Объект.Работы.Добавить();
	СтрокаРабота.ЭтоНоваяСтрока = Истина;
	СтрокаРабота.ИдентификаторСтроки = Строка(Новый УникальныйИдентификатор());
	ОткрытьФормуРедактированияСтрокаРабота(СтрокаРабота);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРедактированияСтрокаРабота(Знач Строка)

	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("Работа", Строка.Работа);
	ДанныеСтроки.Вставить("Ответственный", Строка.Исполнители);
	ДанныеСтроки.Вставить("ИдентификаторСтроки", Строка.ИдентификаторСтроки);
	ДанныеСтроки.Вставить("НомерСтроки", Строка.ПолучитьИдентификатор());

	ДанныеСтроки.Вставить("ТолькоПросмотр", ТолькоПросмотрСтроки());
	ДанныеСтроки.Вставить("СтатусОбмена", Объект.СтатусОбмена);
	ДанныеСтроки.Вставить("Статус", Объект.Статус);
	ДанныеСтроки.Вставить("Подразделение", Объект.Подразделение);
	ДанныеСтроки.Вставить("Исполнители", ИсполнителиПоСтроке(Строка.ИдентификаторСтроки));

	ОткрытьФорму("Документ.мп_НарядНаРемонт.Форма.ФормаРедактированияСтрокиРабота",
		ДанныеСтроки, ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаСервере
Функция ИсполнителиПоСтроке(Знач ИдентификаторСтроки)

	ИсполнителиПоСтроке = Объект.Исполнители.Выгрузить();
	Отбор = Новый Структура;
	Отбор.Вставить("ИдентификаторСтрокиРаботы", ИдентификаторСтроки);
	Результат = ИсполнителиПоСтроке.Скопировать(Отбор);
	Возврат Результат.ВыгрузитьКолонку("Ответственный");

КонецФункции

&НаСервере
Процедура ЧтениеНаСервере()

	ТЗРаботы = СтатусВыполненияРаботы(Объект.Работы.Выгрузить());
	Для Каждого ТекСтрока Из Объект.Работы Цикл
		СтрокаВыполненныхРабот = ТЗРаботы.Найти(ТекСтрока.Работа);
		Если Не СтрокаВыполненныхРабот = Неопределено Тогда
			ТекСтрока.ВыполнениеОперации = СтрокаВыполненныхРабот.ВыполнениеОперации;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтатусВыполненияРаботы(Знач ТЗРаботы)

	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("ТЗРаботы", ТЗРаботы);

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗРаботы.Работа КАК Работа
	|ПОМЕСТИТЬ вт_Работы
	|ИЗ
	|	&ТЗРаботы КАК ТЗРаботы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_Работы.Работа КАК Работа,
	|	ВЫБОР
	|		КОГДА РегистрацияДефекта.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДефектов.Зарегистрирован)
	|			ТОГДА ""Зарегистрирован""
	|		КОГДА РегистрацияДефекта.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДефектов.Отклонен)
	|			ТОГДА ""Отклонен""
	|		КОГДА РегистрацияДефекта.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДефектов.Признан)
	|			ТОГДА ""Признан""
	|		КОГДА РегистрацияДефекта.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДефектов.ОтложеноУстранение)
	|			ТОГДА ""ОтложеноУстранение""
	|		КОГДА РегистрацияДефекта.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДефектов.Устранен)
	|			ТОГДА ""Устранен""
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ВыполнениеОперации
	|ИЗ
	|	Документ.РегистрацияДефекта КАК РегистрацияДефекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_Работы КАК вт_Работы
	|		ПО ((ВЫРАЗИТЬ(вт_Работы.Работа КАК Документ.РегистрацияДефекта)) = РегистрацияДефекта.Ссылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	вт_Работы.Работа,
	|	мп_ЗаданиеНаРемонт.ВыполнениеОперации
	|ИЗ
	|	Документ.мп_ЗаданиеНаРемонт КАК мп_ЗаданиеНаРемонт
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_Работы КАК вт_Работы
	|		ПО ((ВЫРАЗИТЬ(вт_Работы.Работа КАК Документ.мп_ЗаданиеНаРемонт)) = мп_ЗаданиеНаРемонт.Ссылка)";

	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выгрузить();
	
КонецФункции

&НаСервере
Процедура ДоступностьРеквизитов()

	ПраваДоступа = ОбщегоНазначенияВызовСервера.ДоступныеПрава();

	ТолькоПросмотрСтроки = ТолькоПросмотрСтроки();

	ДоступноДляРедактирования = Новый Массив;
	ДоступноДляРедактирования.Добавить("ФормаКоманднаяПанель");
	ДоступноДляРедактирования.Добавить("ФормаПровестиИЗакрыть");
	Если ПраваДоступа.АдминТОиР Тогда
		ДоступноДляРедактирования.Добавить("Подразделение");
	КонецЕсли;
	
	ДоступноДляРедактирования.Добавить("Работы");
	ДоступноДляРедактирования.Добавить("РаботыКонтекстноеМеню");
	Если Не ТолькоПросмотрСтроки Тогда
		ДоступноДляРедактирования.Добавить("РаботыКоманднаяПанель");
		ДоступноДляРедактирования.Добавить("РаботыПодборРабот");
		ДоступноДляРедактирования.Добавить("РаботыПоказатьПерестановкуСтрок");
		ДоступноДляРедактирования.Добавить("РаботыКонтекстноеМенюОткрытьРаботу");
		ДоступноДляРедактирования.Добавить("РаботыГруппаОбщая");
		ДоступноДляРедактирования.Добавить("РаботыГруппаНомерСтроки");
	КонецЕсли;
	
	Если ПраваДоступа.МеханикТОиР Тогда
		ДоступноДляРедактирования.Добавить("РаботыКонтекстноеМенюОткрытьРаботу");
	КонецЕсли;

	ЗакрытьДляРедактирования = Новый Массив;
	ЗакрытьДляРедактирования = 
		ОбщегоНазначения.ЗапрещаемыеЭлементы(Элементы, ДоступноДляРедактирования, ЗакрытьДляРедактирования);

	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, ДоступноДляРедактирования, "Доступность", Истина, Истина);

	Если ТолькоПросмотрСтроки Или ПраваДоступа.МеханикТОиР Тогда
		ЗакрытьДляРедактирования.Добавить("РаботыКонтекстноеМенюУдалитьРаботу");
	КонецЕсли;

	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, ЗакрытьДляРедактирования, "Доступность", Ложь);

КонецПроцедуры

&НаСервере
Функция ТолькоПросмотрСтроки()

	ПраваДоступа = ОбщегоНазначенияВызовСервера.ДоступныеПрава();
	Если Не Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыНарядаНаРемонт.Создан")
			Или ПраваДоступа.ПросмотрТОиР Тогда
		УстановитьПросмотр = Истина;
	Иначе
		УстановитьПросмотр = Ложь;
	КонецЕсли;

	Возврат УстановитьПросмотр;

КонецФункции

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	АктуальныеРежимы = Новый Массив;
	АктуальныеРежимы.Добавить(РежимЗаписиДокумента.Запись);
	АктуальныеРежимы.Добавить(РежимЗаписиДокумента.Проведение);
	Если Не АктуальныеРежимы.Найти(ПараметрыЗаписи.РежимЗаписи) = Неопределено Тогда
		ТаблицаИсполнителей = Объект.Исполнители.Выгрузить();
		Для Каждого ТекСтрока Из Объект.Работы Цикл
			Отбор = Новый Структура;
			Отбор.Вставить("ИдентификаторСтрокиРаботы", ТекСтрока.ИдентификаторСтроки);
			СписокИсполнителей = ТаблицаИсполнителей.Скопировать(Отбор);
			ЗаменаИсполнителей(ТекСтрока.Работа, СписокИсполнителей);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаменаИсполнителей(Работа, СписокИсполнителей)
	РаботаОбъект = Работа.ПолучитьОбъект();
	Если ТипЗнч(Работа) = Тип("ДокументСсылка.мп_ЗаданиеНаРемонт") Тогда
		РаботаОбъект.Исполнители.Очистить();
		Для Каждого ТекСтрока Из СписокИсполнителей Цикл
			НоваяСтрока = РаботаОбъект.Исполнители.Добавить();
			НоваяСтрока.Ответственный = ТекСтрока.Ответственный;
		КонецЦикла;
		РаботаОбъект.Записать(РежимЗаписиДокумента.Запись);
	Иначе
		Возврат;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти