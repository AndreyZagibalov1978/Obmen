ВЫБРАТЬ РАЗЛИЧНЫЕ
	мп_НарядНаРемонтРаботы.Ссылка КАК Наряд
ПОМЕСТИТЬ вт_ЗаданиеНаРемонт
ИЗ
	Документ.мп_НарядНаРемонт.Работы КАК мп_НарядНаРемонтРаботы
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.мп_ЗаданиеНаРемонт КАК мп_ЗаданиеНаРемонт
		ПО ((ВЫРАЗИТЬ(мп_НарядНаРемонтРаботы.Работа КАК Документ.мп_ЗаданиеНаРемонт)) = мп_ЗаданиеНаРемонт.Ссылка)
ГДЕ
	ВЫБОР
			КОГДА &amp;ПлановаяДата = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ИСТИНА
			КОГДА НАЧАЛОПЕРИОДА(мп_ЗаданиеНаРемонт.ДатаНачала, ДЕНЬ) &lt;= НАЧАЛОПЕРИОДА(&amp;ПлановаяДата, ДЕНЬ)
					И НАЧАЛОПЕРИОДА(мп_ЗаданиеНаРемонт.ДатаЗавершения, ДЕНЬ) &gt;= НАЧАЛОПЕРИОДА(&amp;ПлановаяДата, ДЕНЬ)
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ВыбранноеПодразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ мп_ЗаданиеНаРемонт.Подразделение = &amp;ВыбранноеПодразделение
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ДатаВыполнения = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ИСТИНА
			ИНАЧЕ мп_ЗаданиеНаРемонт.ВыполнениеОперации = """Да"""
					И мп_ЗаданиеНаРемонт.ДатаИзмеренияПроверкиВыполнения &gt;= НАЧАЛОПЕРИОДА(&amp;ДатаВыполнения, ДЕНЬ)
					И мп_ЗаданиеНаРемонт.ДатаИзмеренияПроверкиВыполнения &lt;= КОНЕЦПЕРИОДА(&amp;ДатаВыполнения, ДЕНЬ)
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ОбъектЭксплуатации = ЗНАЧЕНИЕ(Справочник.ОбъектыЭксплуатации.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ мп_ЗаданиеНаРемонт.ОбъектЭксплуатации = &amp;ОбъектЭксплуатации
		КОНЕЦ
;

