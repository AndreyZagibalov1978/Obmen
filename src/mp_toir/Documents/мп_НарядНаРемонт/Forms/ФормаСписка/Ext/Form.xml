	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	мп_НарядНаРемонтРаботы.Ссылка КАК Наряд
ПОМЕСТИТЬ вт_РегистрацияДефекта
ИЗ
	Документ.мп_НарядНаРемонт.Работы КАК мп_НарядНаРемонтРаботы
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РегистрацияДефекта.Дефекты КАК РегистрацияДефектаДефекты
		ПО ((ВЫРАЗИТЬ(мп_НарядНаРемонтРаботы.Работа КАК Документ.РегистрацияДефекта)) = РегистрацияДефектаДефекты.Ссылка)
ГДЕ
	ВЫБОР
			КОГДА &amp;ОбъектЭксплуатации = ЗНАЧЕНИЕ(Справочник.ОбъектыЭксплуатации.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ РегистрацияДефектаДефекты.Узел.Владелец = &amp;ОбъектЭксплуатации
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ПлановаяДата = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ИСТИНА
			ИНАЧЕ РегистрацияДефектаДефекты.Ссылка.Дата &gt;= НАЧАЛОПЕРИОДА(&amp;ПлановаяДата, ДЕНЬ)
					И РегистрацияДефектаДефекты.Ссылка.Дата &lt;= КОНЕЦПЕРИОДА(&amp;ПлановаяДата, ДЕНЬ)
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ДатаВыполнения = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ИСТИНА
			ИНАЧЕ РегистрацияДефектаДефекты.ДатаУстранения &gt;= НАЧАЛОПЕРИОДА(&amp;ДатаВыполнения, ДЕНЬ)
					И РегистрацияДефектаДефекты.ДатаУстранения &lt;= КОНЕЦПЕРИОДА(&amp;ДатаВыполнения, ДЕНЬ)
					И РегистрацияДефектаДефекты.ДефектУстранен = 1
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ВыбранноеПодразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ РегистрацияДефектаДефекты.Ссылка.Подразделение = &amp;ВыбранноеПодразделение
		КОНЕЦ
;

