#Область ОписаниеПеременных

&НаКлиенте
Перем ИменаСтраниц;

&НаКлиенте
Перем ТекущийИндексСтраницы;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		
		РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
		Объект.Организация = РеквизитыКонстант["ОрганизацияПользователя"];
		Объект.Подразделение = РеквизитыКонстант["ПодразделениеПользователя"];
		Объект.Ответственный = РеквизитыКонстант["ТекущийПользователь"];
		Объект.мп_СтатусОбмена = Перечисления.мп_СтатусыОбмена.Создан;
		
	Иначе
		ТолькоПросмотр = 
			Не ОбщегоНазначенияВызовСервера.РедактированиеФормыДокументаТОиР(
				Объект.Подразделение, Объект.Ответственный, Объект.мп_СтатусОбмена);
			
		ЭтотОбъект.ТолькоПросмотр = ТолькоПросмотр;
	КонецЕсли;

	ЧтениеНаСервере();

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	ЧтениеНаСервере();

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)

	ЧтениеНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ИсточникВыбора.ИмяФормы = "Документ.НаработкаОбъектовЭксплуатации.Форма.ФормаСтрокиНаработки" Тогда

		ДанныеСтроки = Объект.Наработки.НайтиПоИдентификатору(ИсточникВыбора.НомерСтроки);
		Если ИсточникВыбора.СохранитьИзменения Тогда
			
			Модифицированность = Истина;
			
			ЗаполнитьЗначенияСвойств(ДанныеСтроки, ИсточникВыбора);
			ДанныеСтроки.ЭтоНоваяСтрока = Ложь;
			ЧтениеНаСервере();
		ИначеЕсли ДанныеСтроки.ЭтоНоваяСтрока Тогда
			
			НомерСтроки = Объект.Наработки.Количество();
			Объект.Наработки.Удалить(НомерСтроки - 1);
			
		КонецЕсли;

	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ИменаСтраниц = Новый Массив;
	ИменаСтраниц.Добавить("Показатели");
	ИменаСтраниц.Добавить("Основная");

	ЭтотОбъект.КоличествоСтраниц = ИменаСтраниц.Количество() - 1;

	ТекущийИндексСтраницы = 0;
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)

	ТекущийИндексСтраницы = ИменаСтраниц.Найти(ТекущаяСтраница.Имя);
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНаработки

&НаКлиенте
Процедура ИзменитьСтроку(Команда)
	Строка = Элементы.Наработки.ТекущиеДанные;
	Строка.ЭтоНоваяСтрока = Ложь;
	ОткрытьФормуРедактирования(Строка);
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьСтроку(Команда)
	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	СтрокаИсходная = Элементы.Наработки.ТекущиеДанные;
	Строка = Объект.Наработки.Добавить();
	Строка.ЭтоНоваяСтрока = Истина;
	ЗаполнитьЗначенияСвойств(Строка, СтрокаИсходная, "ТехнологическоеМесто, ОбъектЭксплуатации, Узел");
	ОткрытьФормуРедактирования(Строка);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтроку(Команда)

	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;

	ИндексСтроки = Элементы.Наработки.ТекущиеДанные.НомерСтроки - 1;
	Объект.Наработки.Удалить(ИндексСтроки);

КонецПроцедуры

