&НаКлиенте
Процедура НаработкиПоказательНаработкиНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	Узел = ЭтотОбъект.ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.Узел;
	МассивЭлементов = Новый Массив;
	Если ЗначениеЗаполнено(Узел) Тогда
		Наработки = НаработкиУзла(Узел);
		Если Не Наработки = Неопределено Тогда
			НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", Наработки);
			МассивЭлементов.Добавить(НовыйПараметр);
		Иначе
			СтандартнаяОбработка = Ложь;
			ПоказатьПредупреждение(, "У класса узла нет показателей наработки", 30);
			Возврат;
		КонецЕсли;
	Иначе
			СтандартнаяОбработка = Ложь;
	КонецЕсли;
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);
КонецПроцедуры

&НаКлиенте
Процедура НаработкиОбъектЭксплуатацииПриИзменении(Элемент)

	ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.ТехнологическоеМесто =
		НаработкиОбъектЭксплуатацииПриИзмененииНаСервере(ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.ОбъектЭксплуатации);

КонецПроцедуры

&НаКлиенте
Процедура ОчиститьПодчиненныеЭлементыТехМеста()

	ТекущиеДанные = ЭтотОбъект.Элементы.Наработки.ТекущиеДанные;
	
	ТекущиеДанные.Узел =
		ПредопределенноеЗначение("Справочник.УзлыОбъектовЭксплуатации.ПустаяСсылка");

	ТекущиеДанные.ПоказательНаработки =
		ПредопределенноеЗначение("Справочник.ПоказателиНаработки.ПустаяСсылка");

	ТекущиеДанные.Значение = 0;

КонецПроцедуры

&НаКлиенте
Процедура НаработкиТехнологическоеМестоПриИзменении(Элемент)

	ОбъектЭксплуатации = ОбщегоНазначенияВызовСервера.ОбъектыЭксплуатацииПоТехМесту(
		ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.ТехнологическоеМесто, Истина);
	
	Если ТипЗнч(ОбъектЭксплуатации) = Тип("СправочникСсылка.ОбъектыЭксплуатации") Тогда
		Если ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.ОбъектЭксплуатации <> ОбъектЭксплуатации Тогда
			ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.ОбъектЭксплуатации = ОбъектЭксплуатации;
			ОчиститьПодчиненныеЭлементыТехМеста();
		КонецЕсли;
	Иначе
		ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.ОбъектЭксплуатации =
			ПредопределенноеЗначение("Справочник.ОбъектыЭксплуатации.ПустаяСсылка");
			
		ОчиститьПодчиненныеЭлементыТехМеста();

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура НаработкиУзелНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	ОбъектЭксплуатации = ЭтотОбъект.Элементы.Наработки.ТекущиеДанные.ОбъектЭксплуатации;
	Если Не ЗначениеЗаполнено(ОбъектЭксплуатации) Тогда
		Возврат;
	КонецЕсли;
	ДоступныеУзлы =
		УзлыПоНаработке(ОбъектЭксплуатации);
		
	Если ДоступныеУзлы = Неопределено Тогда
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;
	
	МассивЭлементов = Новый Массив;
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", ДоступныеУзлы);
	МассивЭлементов.Добавить(НовыйПараметр);
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);
	
КонецПроцедуры

&НаКлиенте
Процедура НаработкиПередНачаломИзменения(Элемент, Отказ)

	Отказ = Истина;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Страница1(Команда)
	НовыйИндекс = Макс(ТекущийИндексСтраницы - 1, 0);
	ТекущийИндексСтраницы = НовыйИндекс;
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
КонецПроцедуры

&НаКлиенте
Процедура Страница2(Команда)
	НовыйИндекс = Мин(ТекущийИндексСтраницы + 1, ЭтотОбъект.КоличествоСтраниц);
	ТекущийИндексСтраницы = НовыйИндекс;
	ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы);
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьНаработку(Команда)

	Если ЭтотОбъект.ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	Строка = Объект.Наработки.Добавить();
	Строка.ЭтоНоваяСтрока = Истина;
	ОткрытьФормуРедактирования(Строка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОткрытьФормуРедактирования(Строка)
	
	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("НомерСтроки", Строка.ПолучитьИдентификатор());
	ДанныеСтроки.Вставить("ТехнологическоеМесто", Строка.ТехнологическоеМесто);
	ДанныеСтроки.Вставить("ОбъектЭксплуатации", Строка.ОбъектЭксплуатации);
	ДанныеСтроки.Вставить("Узел", Строка.Узел);
	ДанныеСтроки.Вставить("ПоказательНаработки", Строка.ПоказательНаработки);
	ДанныеСтроки.Вставить("Значение", Строка.Значение);
	ДанныеСтроки.Вставить("ТолькоПросмотр", ЭтотОбъект.ТолькоПросмотр);

	ОткрытьФорму("Документ.НаработкаОбъектовЭксплуатации.Форма.ФормаСтрокиНаработки",
		ДанныеСтроки, ЭтотОбъект, ЭтотОбъект.УникальныйИдентификатор, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецПроцедуры
	
&НаСервереБезКонтекста
Функция КаталогиОборудованияПоОбъектуЭксплуатации(Знач Наработки)
	
	ОбъектыЭксплуатации = ОбщегоНазначения.ВыгрузитьКолонку(Наработки, "ОбъектЭксплуатации", Истина);
	
	Если ОбъектыЭксплуатации.Количество() = 0 Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОбъектыЭксплуатации.Ссылка КАК ОбъектЭксплуатации,
	|	ОбъектыЭксплуатации.ТехнологическоеМесто КАК ТехнологическоеМесто
	|ИЗ
	|	Справочник.ОбъектыЭксплуатации КАК ОбъектыЭксплуатации
	|ГДЕ
	|	ОбъектыЭксплуатации.Ссылка В (&ОбъектыЭксплуатации)";
	
	Запрос.УстановитьПараметр("ОбъектыЭксплуатации", ОбъектыЭксплуатации);
	
	РезультатЗапроса = Запрос.Выполнить();

	Возврат РезультатЗапроса.Выгрузить();

КонецФункции

&НаСервере
Процедура ЧтениеНаСервере()

	КаталогиОборудования = КаталогиОборудованияПоОбъектуЭксплуатации(Объект.Наработки);
	
	Если Не КаталогиОборудования = Неопределено Тогда
		
		Для Каждого ТекНаработка Из Объект.Наработки Цикл
			Если ЗначениеЗаполнено(ТекНаработка.ОбъектЭксплуатации) Тогда
				ТекНаработка.ТехнологическоеМесто = 
					КаталогиОборудования.Найти(ТекНаработка.ОбъектЭксплуатации).ТехнологическоеМесто;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция НаработкиОбъектЭксплуатацииПриИзмененииНаСервере(Знач ОбъектЭксплуатации)

	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектЭксплуатации, "ТехнологическоеМесто");

КонецФункции

&НаСервере
Функция НаработкиТехнологическоеМестоПриИзмененииНаСервере(Знач ТехнологическоеМесто)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОбъектыЭксплуатации.Ссылка КАК ОбъектЭксплуатации
	|ИЗ
	|	Справочник.ОбъектыЭксплуатации КАК ОбъектыЭксплуатации
	|ГДЕ
	|	ОбъектыЭксплуатации.ТехнологическоеМесто = &ТехнологическоеМесто";
	
	Запрос.УстановитьПараметр("ТехнологическоеМесто", ТехнологическоеМесто);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Количество() = 1 Тогда
		Выборка.Следующий();
		Возврат Выборка.ОбъектЭксплуатации;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

&НаСервереБезКонтекста
Функция УзлыПоНаработке(Знач ОбъектЭксплуатации)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УзлыОбъектовЭксплуатации.Ссылка КАК Узел,
	|	УзлыОбъектовЭксплуатации.Класс КАК Класс
	|ПОМЕСТИТЬ вт_Узлы
	|ИЗ
	|	Справочник.УзлыОбъектовЭксплуатации КАК УзлыОбъектовЭксплуатации
	|ГДЕ
	|	УзлыОбъектовЭксплуатации.Владелец = &ОбъектЭксплуатации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Узлы.Узел КАК Узел
	|ИЗ
	|	вт_Узлы КАК вт_Узлы";
	
	Запрос.УстановитьПараметр("ОбъектЭксплуатации", ОбъектЭксплуатации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Узел");
	КонецЕсли;

КонецФункции

&НаСервереБезКонтекста
Функция НаработкиУзла(Знач Узел)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КлассыОбъектовЭксплуатации.Ссылка КАК Класс
	|ПОМЕСТИТЬ вт_КлассОбъект
	|ИЗ
	|	Справочник.УзлыОбъектовЭксплуатации КАК УзлыОбъектовЭксплуатации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлассыОбъектовЭксплуатации КАК КлассыОбъектовЭксплуатации
	|		ПО УзлыОбъектовЭксплуатации.Класс = КлассыОбъектовЭксплуатации.Ссылка
	|			И (&Узел = УзлыОбъектовЭксплуатации.Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КлассыОбъектовЭксплуатацииПоказателиНаработки.ПоказательНаработки КАК Наработки
	|ИЗ
	|	вт_КлассОбъект КАК вт_КлассОбъект
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлассыОбъектовЭксплуатации.ПоказателиНаработки КАК КлассыОбъектовЭксплуатацииПоказателиНаработки
	|		ПО вт_КлассОбъект.Класс = КлассыОбъектовЭксплуатацииПоказателиНаработки.Ссылка";
	
	Запрос.УстановитьПараметр("Узел", Узел);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Наработки");
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ЗаголовокТекущейСтраницы(ТекущийИндексСтраницы)
	ИмяСтраницы = ИменаСтраниц[ТекущийИндексСтраницы];
	Страница = Элементы.Найти(ИмяСтраницы);
	Если Страница = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Элементы.ПредставлениеСтраницы.Заголовок = Страница.Заголовок;
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Страница;
	ЗаголовокГруппыСтраниц = СтрШаблон("Всего: %1 этапа", ЭтотОбъект.КоличествоСтраниц + 1);
	Элементы.ГруппаКнопкиСтраниц.Заголовок = ЗаголовокГруппыСтраниц;
КонецПроцедуры

#КонецОбласти