&НаКлиенте
Процедура ПроведениеДокументаАдминистратором(РезультатВопроса, ДопПараметры) Экспорт
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ДокПроведения = ДопПараметры.ДокПроведения;
		ПровестиДокументСервер(ДокПроведения);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтменаПроведенияДокументаАдминистратором(РезультатВопроса, ДопПараметры) Экспорт

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ДокПроведения = ДопПараметры.ДокПроведения;
		ПометкаОтменаПроведенияДокументСервер(ДокПроведения, Ложь, "ИнтерактивнаяОтменаПроведения");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПометкаУдаленияДокументаАдминистратором(РезультатВопроса, ДопПараметры) Экспорт

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ДокПроведения = ДопПараметры.ДокПроведения;
		ПометкаОтменаПроведенияДокументСервер(ДокПроведения, Ложь, "ИнтерактивнаяПометкаУдаления");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПровестиДокумент(Команда)

	ДокПроведения = ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока;
	РеквизитыДокумента = РеквизитыДокумента(ДокПроведения);
	ТекущийИсточник = РеквизитыДокумента.Источник;
	Статус = РеквизитыДокумента.Статус;
	СтатусОбмена = РеквизитыДокумента.СтатусОбмена;
	ПометкаУдаления = РеквизитыДокумента.ПометкаУдаления;
	АдминТОиР = ОбщегоНазначенияВызовСервера.АдминистраторТОиР();
	
	Если ПометкаУдаления Тогда
		ПоказатьПредупреждение(,
			"Нельзя проводить помеченный на удаление документ, перед удалением снимите пометку удаления", 30, "Ошибка");
		Возврат;
	КонецЕсли;
	
	Если РегистрацияДефектаЛокализация.УсловиеОтбораДокумента(Статус, ТекущийИсточник, СтатусОбмена) Тогда
		Если АдминТОиР Тогда
			СтрСообщение = "Изменение документа в статусе %1 запрещено для пользователей с обычными правами. "
				+ "Внося изменения в документ, вы осознаёте риск искажения и рассинхронизации информации. Продолжить?";
			СтрСообщение = СтрШаблон(СтрСообщение, Статус);

			ДопПараметры = Новый Структура;
			ДопПараметры.Вставить("ДокПроведения", ДокПроведения);
			ОповещениеПроведения = Новый ОписаниеОповещения("ПроведениеДокументаАдминистратором", ЭтотОбъект, ДопПараметры);
			ПоказатьВопрос(ОповещениеПроведения,  СтрСообщение, РежимДиалогаВопрос.ДаНет, 60);
		КонецЕсли;
	Иначе
		ПровестиДокументСервер(ДокПроведения);
	КонецЕсли;

	Элементы.Список.Обновить();

КонецПроцедуры

&НаКлиенте 
Процедура ПоказатьВопросАдминТОиР(Знач ТекущийИсточник, Знач Статус, Знач ДокПроведения, Знач ПометкаУдаления, Знач ДействиеСДокументом)

	Если ДействиеСДокументом = "ИнтерактивнаяОтменаПроведения" Тогда
		ПроцедураОповещенияСтр = "ОтменаПроведенияДокументаАдминистратором";
	ИначеЕсли ДействиеСДокументом = "ИнтерактивнаяПометкаУдаления" Тогда
		Если ПометкаУдаления Тогда
			ПометкаОтменаПроведенияДокументСервер(ДокПроведения, Ложь, ДействиеСДокументом);
			Возврат;
		КонецЕсли;
		ПроцедураОповещенияСтр = "ПометкаУдаленияДокументаАдминистратором";
	КонецЕсли;
	ДопПараметр = Новый Структура;
	ДопПараметр.Вставить("ДокПроведения", ДокПроведения);
	
	ПроцедураОповещения = Новый ОписаниеОповещения(ПроцедураОповещенияСтр, ЭтотОбъект, ДопПараметр);
	СтрСообщение = "Изменение документа в статусе %1 запрещено для пользователей с обычными правами. "
	+ "Внося изменения в документ, вы осознаёте риск искажения и рассинхронизации информации. Продолжить?";
	СтрСообщение = СтрШаблон(СтрСообщение, Статус);

	ПоказатьВопрос(ПроцедураОповещения, СтрСообщение, РежимДиалогаВопрос.ДаНет, 60);

КонецПроцедуры

&НаКлиенте
Процедура ПометкаУдаленияОтменаПроведения(ДействиеСДокументом)
	
	ДокПроведения = ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока;
	РеквизитыДокумента = РеквизитыДокумента(ДокПроведения);
	ПометкаУдаления = РеквизитыДокумента.ПометкаУдаления;
	ТекущийИсточник = РеквизитыДокумента.Источник;
	Статус = РеквизитыДокумента.Статус;
	СтатусОбмена = РеквизитыДокумента.СтатусОбмена;
	АдминТОиР = ОбщегоНазначенияВызовСервера.АдминистраторТОиР();

	Если РегистрацияДефектаЛокализация.УсловиеОтбораДокумента(
		Статус, ТекущийИсточник, СтатусОбмена) Тогда
		Если АдминТОиР Тогда
			ПоказатьВопросАдминТОиР(ТекущийИсточник, Статус, ДокПроведения, ПометкаУдаления, ДействиеСДокументом);
		Иначе
			ПометкаОтменаПроведенияДокументСервер(ДокПроведения, Истина, ДействиеСДокументом);
		КонецЕсли;
	Иначе
		Если ТекущийИсточник = ПредопределенноеЗначение("Перечисление.мп_ИсточникиДокументов.КИС") Тогда
			Если АдминТОиР Тогда
				Если ДействиеСДокументом = "ИнтерактивнаяОтменаПроведения" Тогда
					СтрСообщение = "Факт отмены проведения не будет выгружен в КИС";
				ИначеЕсли ДействиеСДокументом = "ИнтерактивнаяПометкаУдаления" Тогда
					Если ПометкаУдаления Тогда
						СтрСообщение = "Снятие пометки на удаление не будет выгружено в КИС";
					Иначе
						СтрСообщение = "Пометка на удаление не будет выгружена в КИС";
					КонецЕсли;
				КонецЕсли;
				ПоказатьПредупреждение(, СтрСообщение, 30, "Предупреждение");
				ПометкаОтменаПроведенияДокументСервер(ДокПроведения, Ложь, ДействиеСДокументом);
			Иначе
				ПометкаОтменаПроведенияДокументСервер(ДокПроведения, Истина, ДействиеСДокументом);
			КонецЕсли;
		Иначе
			ПометкаОтменаПроведенияДокументСервер(ДокПроведения, Истина, ДействиеСДокументом);	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтменитьПроведениеДокумента(Команда)

	ПометкаУдаленияОтменаПроведения("ИнтерактивнаяОтменаПроведения");

КонецПроцедуры

&НаКлиенте
Процедура УстановитьПометкуУдаленияДокумента(Команда)

	ПометкаУдаленияОтменаПроведения("ИнтерактивнаяПометкаУдаления");

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ПравоНаДокумент(Знач ВидПроверки)
	Возврат ПравоДоступа(ВидПроверки, Метаданные.Документы.РегистрацияДефекта);
КонецФункции

&НаСервере
Процедура ПометкаОтменаПроведенияДокументСервер(Знач ДокПроведения, ВыполнитьПроверку, ДействиеСДокументом)

	ПроверкаПройдена = ПравоНаДокумент(ДействиеСДокументом);
	Если Не ПроверкаПройдена Тогда
		Возврат;
	КонецЕсли;
	ДокОбъект = ДокПроведения.ПолучитьОбъект();
	РеквизитыДокумента = 
		ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокПроведения, "СтатусОбмена, Источник");
	Если ВыполнитьПроверку Тогда
		ПроверкаПройдена = Не ОбщегоНазначенияСервер.ЗапретПометкиУдаленияДокументовТОиР(
			РеквизитыДокумента.СтатусОбмена, РеквизитыДокумента.Источник);
	Иначе
		ПроверкаПройдена = Истина;
	КонецЕсли;

	Если ПроверкаПройдена Тогда
		Если ДействиеСДокументом = "ИнтерактивнаяОтменаПроведения" Тогда
			ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		ИначеЕсли ДействиеСДокументом = "ИнтерактивнаяПометкаУдаления" Тогда
			Действие = Не ДокПроведения.ПометкаУдаления;
			ДокОбъект.УстановитьПометкуУдаления(Действие);
		КонецЕсли;
		УзелОбмена = ОбщегоНазначенияПовтИсп.ПолучитьУзелЦентральнойБазы();
		ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ДокПроведения);
		ОбновитьСписок();
	Иначе
		ИсточникКИС = (РеквизитыДокумента.Источник = Перечисления.мп_ИсточникиДокументов.КИС);
		СтатусДокумента = Перечисления.мп_СтатусыОбмена.СтатусПредставленияДокумента(РеквизитыДокумента.СтатусОбмена);
		Если ДействиеСДокументом = "ИнтерактивнаяОтменаПроведения" Тогда
			Если ИсточникКИС Тогда
				СообщениеПользователю = "Документ загружен из КИС: нельзя отменять проведение";
			Иначе
				СообщениеПользователю = СтатусДокумента + ": нельзя отменять проведение";
			КонецЕсли;
		ИначеЕсли ДействиеСДокументом = "ИнтерактивнаяПометкаУдаления" Тогда
			Если ИсточникКИС Тогда
				СообщениеПользователю = "Документ загружен из КИС: нельзя помечать на удаление";
			Иначе
				СообщениеПользователю = СтатусДокумента + ": Нельзя помечать на удаление";
			КонецЕсли;
		КонецЕсли;
		ОбщегоНазначения.СообщитьПользователю(СообщениеПользователю);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПровестиДокументСервер(Знач ДокПроведения)

	Если Не ПравоНаДокумент("ИнтерактивноеПроведение") Тогда
		Возврат;
	КонецЕсли;

	Если ДокПроведения.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;

	ДокОбъект = ДокПроведения.ПолучитьОбъект();
	ПроверкаПройдена = ДокОбъект.ПроверитьЗаполнение();
	Если ПроверкаПройдена Тогда
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		ОбновитьСписок();
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция РеквизитыДокумента(ДокПроведения)
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокПроведения, "Источник, ПометкаУдаления, Статус, СтатусОбмена");
КонецФункции

&НаСервереБезКонтекста
Функция СписокОтветственных(Знач Подразделение)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Пользователи.Ссылка КАК ОтветственныеЗаУстранение
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка) = &Подразделение
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Пользователи.Подразделение = &Подразделение
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ОтветственныеЗаУстранение");
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Функция СписокДокументовСНомерамиКИС(Знач Подразделение, Знач Ответственный)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РегистрацияДефекта.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РегистрацияДефекта КАК РегистрацияДефекта
	|ГДЕ
	|	НЕ СОКРЛП(РегистрацияДефекта.НомерКИС) = """"
	|	И ВЫБОР
	|			КОГДА &Подразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ РегистрацияДефекта.Подразделение = &Подразделение
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &Ответственный = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ РегистрацияДефекта.Ответственный = &Ответственный
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("Ответственный", Ответственный);
	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		Возврат Новый Массив;
	Иначе
		Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;

КонецФункции

&НаСервере
Процедура ОтборСпискаНаСервере()

	Список.Параметры.УстановитьЗначениеПараметра("Подразделение", ЭтотОбъект.Подразделение);
	Список.Параметры.УстановитьЗначениеПараметра("Ответственный", ЭтотОбъект.Ответственный);
	Список.Параметры.УстановитьЗначениеПараметра(
		"ТекущийПользовательБригадир", ЭтотОбъект.ПраваДоступаТекущегоПользователя.БригадирТОиР);
	Список.Параметры.УстановитьЗначениеПараметра("НомерКИС", ЭтотОбъект.НомерКИСОтбор);
	Список.Параметры.УстановитьЗначениеПараметра("ОтветственныйЗаУстранение", ЭтотОбъект.ОтветственныйЗаУстранение);
	Список.Параметры.УстановитьЗначениеПараметра("ОбъектЭксплуатации", ЭтотОбъект.ОбъектЭксплуатации);

	СтатусыОбменаВЗапрос = Новый Массив;
	Для Каждого ТекСтатус Из ЭтотОбъект.СтатусОбмена Цикл
		СтатусыОбменаВЗапрос.Добавить(ТекСтатус.Значение);
	КонецЦикла;
	Список.Параметры.УстановитьЗначениеПараметра("СтатусыОбмена", СтатусыОбменаВЗапрос);
	
	СтатусыДефектов = Новый Массив;
	Для Каждого ТекСтатус Из ЭтотОбъект.Статус Цикл
		СтатусыДефектов.Добавить(ТекСтатус.Значение);
	КонецЦикла;
	Список.Параметры.УстановитьЗначениеПараметра("СтатусыДефектов", СтатусыДефектов);
	
	СортировкаПоДате();
	
КонецПроцедуры

&НаСервере
Процедура СортировкаПоДате()
	Порядок = Список.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
		Список.Порядок.ИдентификаторПользовательскойНастройки);
	Порядок.Элементы.Очистить();
	НовыйПорядок = Порядок.Элементы.Добавить(Тип("ЭлементПорядкаКомпоновкиДанных"));
	НовыйПорядок.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Авто;
	НовыйПорядок.Поле = Новый ПолеКомпоновкиДанных("Дата");
	НовыйПорядок.ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных.Возр;
	НовыйПорядок.Использование = Истина;
	ОбновитьСписок();
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписок()

	Элементы.Список.Обновить();

КонецПроцедуры

#КонецОбласти