
#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	СортировкаПоДате();

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
	ТекущийПользователь = РеквизитыКонстант["ТекущийПользователь"];
	ДоступностьОтбора = ОбщегоНазначенияВызовСервера.ДоступностьПараметраОтбораДокументов(ТекущийПользователь);

	Если Не ДоступностьОтбора = Неопределено Тогда
		Элементы.ПодразделениеОтбор.Доступность = ДоступностьОтбора.Подразделение;
		Элементы.ОтветственныйОтбор.Доступность = ДоступностьОтбора.Ответственный;
		Если РольДоступна("мп_ДобавлениеИзменениеДокументовТОиР") Или РольДоступна("мп_БригадирТОиР") Тогда
			ЭтотОбъект.Подразделение = РеквизитыКонстант["ПодразделениеПользователя"];
			ЭтотОбъект.Ответственный = ТекущийПользователь;
		КонецЕсли;
	КонецЕсли;
	
	ЭтотОбъект.СтатусОбмена.Добавить(Перечисления.мп_СтатусыОбмена.Создан);
	ЭтотОбъект.СтатусОбмена.Добавить(Перечисления.мп_СтатусыОбмена.ЗагруженИзКИС);

	ЭтотОбъект.Статус.Добавить(Перечисления.СтатусыДефектов.Зарегистрирован);
	ЭтотОбъект.Статус.Добавить(Перечисления.СтатусыДефектов.Признан);
	ЭтотОбъект.Статус.Добавить(Перечисления.СтатусыДефектов.Устранен);
	ЭтотОбъект.Статус.Добавить(Перечисления.СтатусыДефектов.ОтложеноУстранение);

	НастройкиПоУмолчанию = Новый Структура;
	НастройкиПоУмолчанию.Вставить("СтатусОбмена", ЭтотОбъект.СтатусОбмена);
	НастройкиПоУмолчанию.Вставить("Статус", ЭтотОбъект.Статус);
	
	ПерсональныеНастройки = ОбщегоНазначенияВызовСервера.ПолучитьПерсональныеНастройки(
		ТекущийПользователь, ЭтотОбъект.ИмяФормы, НастройкиПоУмолчанию);

	ЭтотОбъект.Статус = ПерсональныеНастройки["Статус"];
	ЭтотОбъект.СтатусОбмена = ПерсональныеНастройки["СтатусОбмена"];
	
	ПраваДоступа = ОбщегоНазначенияВызовСервера.ДоступныеПрава();
	ЭтотОбъект.ПраваДоступаТекущегоПользователя = ПраваДоступа;
	
	ОтборСпискаНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)

	ПриЗакрытииНаСервере();

КонецПроцедуры

&НаСервере
Процедура ПриЗакрытииНаСервере()

	РеквизитыКонстант = ОбщегоНазначенияСервер.ПолучитьЗначенияКонстант();
	ТекущийПользователь = РеквизитыКонстант["ТекущийПользователь"];
	ОбщегоНазначенияВызовСервера.СохранитьПерсональнуюНастройку(
		ТекущийПользователь, ЭтотОбъект.ИмяФормы, "СтатусОбмена", ЭтотОбъект.СтатусОбмена);
		
	ОбщегоНазначенияВызовСервера.СохранитьПерсональнуюНастройку(
		ТекущийПользователь, ЭтотОбъект.ИмяФормы, "Статус", ЭтотОбъект.Статус);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПодразделениеОтборОчистка(Элемент, СтандартнаяОбработка)
	ПраваДоступа = ЭтотОбъект.ПраваДоступаТекущегоПользователя;
	Если ПраваДоступа.БригадирТОиР Тогда
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтветственныйЗаУстранениеОтборНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	ОтветственныеЗаУстранение = СписокОтветственных(ЭтотОбъект.Подразделение);
	
	Если Не ОтветственныеЗаУстранение = Неопределено Тогда
		МассивЭлементов = Новый Массив;
		НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", ОтветственныеЗаУстранение);
		МассивЭлементов.Добавить(НовыйПараметр);
		Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НомерКИСОтборНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	ДокументыОтбора = СписокДокументовСНомерамиКИС(ЭтотОбъект.Подразделение, ЭтотОбъект.Ответственный);

	Если Не ДокументыОтбора = Неопределено Тогда
		МассивЭлементов = Новый Массив;
		НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", ДокументыОтбора);
		МассивЭлементов.Добавить(НовыйПараметр);
		Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивЭлементов);
	КонецЕсли;

КонецПроцедуры

