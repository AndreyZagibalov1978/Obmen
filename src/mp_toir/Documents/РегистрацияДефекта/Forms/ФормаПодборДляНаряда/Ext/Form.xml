			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	РегистрацияДефекта.Ссылка КАК Ссылка,
	РегистрацияДефекта.Номер КАК Номер,
	РегистрацияДефекта.НомерКИС КАК НомерКИС,
	РегистрацияДефекта.Дата КАК Дата,
	РегистрацияДефекта.Статус КАК Статус,
	РегистрацияДефекта.Ответственный КАК Ответственный,
	РегистрацияДефекта.ОтветственныйЗаУстранение КАК ОтветственныйЗаУстранение,
	РегистрацияДефекта.Подразделение КАК Подразделение,
	РегистрацияДефекта.ОбъектЭксплуатации КАК ОбъектЭксплуатации
ИЗ
	Документ.РегистрацияДефекта КАК РегистрацияДефекта
ГДЕ
	ВЫБОР
			КОГДА &amp;Ответственный = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ РегистрацияДефекта.Ответственный = &amp;Ответственный
		КОНЕЦ
	И РегистрацияДефекта.Подразделение В ИЕРАРХИИ(&amp;Подразделение)
	И РегистрацияДефекта.Статус В(&amp;Статус)
	И ВЫБОР
			КОГДА &amp;ОтветственныйЗаУстранение = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ РегистрацияДефекта.ОтветственныйЗаУстранение = &amp;ОтветственныйЗаУстранение
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;НомерКИС = ЗНАЧЕНИЕ(Документ.РегистрацияДефекта.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ РегистрацияДефекта.Ссылка = &amp;НомерКИС
		КОНЕЦ
	И НЕ РегистрацияДефекта.Ссылка В (&amp;ИсключаемыеДокументы)
	И РегистрацияДефекта.Проведен</QueryText>
